                                                            disabled="@(!CommsCanFence(commsShip))"
                                                            title="@(DarkWebCanTrade() ? "" : DarkWebDisabledReason())"
                                                            @onclick="() => CommsSellTrack(commsShip)">
                                                        🕸 Fence this track@(CommsFencePrice(commsShip) is { } fencePrice ? $" — +{fencePrice:N0} cr" : " — needs ≥50% quality at a haven")
                                                    </button>
                                                }
                                                else
                                                {
                                                    <div class="text-secondary">Not on your telescope ledger — track her at the <span class="text-light">Sensors desk</span> to hail, laser-range, or fence the track.</div>
                                                }
                                                @if (SelectedTrackedTarget() is { } pinTarget && pinTarget.Ship.Id == commsShip.Ship.Id)
                                                {
                                                    <button type="button" class="btn btn-sm @(_pinned ? "btn-warning" : "btn-outline-light") py-0 px-1 text-start" @onclick="TogglePin">
                                                        📌 Pin: brakes at @BodyName(pinTarget.Ship.DestinationId)
                                                    </button>
                                                }
                                            </div>
                                            @if (_commsActionMessage is not null)
                                            {
                                                <div class="text-warning mt-1">@_commsActionMessage</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="card-body p-2 small text-secondary">
                                            Select a contact in the tree — its dossier and comms actions (hail, laser ranging, fencing the track) show here.
                                            Ships missing from the board are found at the <span class="text-light">Sensors desk</span> or bought at the <span class="text-light">dark web market</span>.
