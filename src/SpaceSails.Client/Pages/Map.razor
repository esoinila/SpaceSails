    @* THE DICE TRAY (#305) — the shared 2D6 reveal a dice-scripted event casts into (aerobrake episodes
       now; Reevers/BUSTED/drinks next). Any system raises one via RaiseDiceEvent(DiceEvent). *@
    <DiceTray Event="_diceTrayEvent" OnDismiss="DismissDiceTray" />
</div>

@code {

    @* #355 — the offer-a-drink affordance for ONE bar contact, rendered IDENTICALLY from both doorways:
       the barkeep's counter card and the patron's own table. It reads the one shared state machine
       (_pendingContactDrink / _roundThisVisit), so a moment opened at the table shows the same confirm at
       the counter and vice versa. keep gives the price/pour, resolved the same way at either doorway. *@
    private RenderFragment ContactDrinkOffer(string giver, string display, Core.Interior.Barkeep keep) => @<text>
        @{
            Core.Drink? knownFav = KnownFavoriteDrink(giver);
            bool poursUsual = BarPoursFavorite(giver);
        }
        @if (_pendingContactDrink == giver)
        {
            <div class="deck-offer-actions">
                <span class="bar-offer-moment small">Offer @display a drink? They'll choose their own pour.</span>
                <button type="button" class="btn btn-sm btn-warning" disabled="@(_credits < keep.DrinkPrice)"
                        title="@($"Offer {display} a drink ({keep.DrinkPrice} cr) — they pick their own pour; only if they take it is it poured, and the 2D6 decides if they open up or you slip a tell")"
                        @onclick="@(() => BuyContactDrink(giver))">🥃 Offer it · @keep.DrinkPrice cr</button>
                @if (poursUsual && knownFav is { } fav)
                {
                    <button type="button" class="btn btn-sm btn-success" disabled="@(_credits < keep.DrinkPrice)"
                            title="@($"Stand {display} the {fav.Name} — their usual. A small honest edge (+1) to the offer, and a warmer glass.")"
                            @onclick="@(() => BuyContactDrink(giver, true))">🥃 Their usual — @fav.Name · @keep.DrinkPrice cr</button>
                }
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        title="Changed your mind — no harm done" @onclick="CancelContactDrinkOffer">Cancel</button>
            </div>
        }
        else if (_roundThisVisit)
        {
            <div class="deck-offer-actions">
                <span class="bar-toasted small">🍻 @display toasted you with the room@(knownFav is { } kf ? $" · drinks {kf.Name}" : "")</span>
                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < keep.DrinkPrice)"
                        title="@($"Offer {display} a personal glass on top of the round — they may still refuse; extra warmth, never demanded")"
                        @onclick="@(() => OfferContactDrink(giver))">🥃 Offer another · @keep.DrinkPrice cr</button>
            </div>
        }
        else
        {
            <div class="deck-offer-actions">
                <button type="button" class="btn btn-sm btn-warning"
                        title="@($"Offer {display} a drink ({keep.DrinkPrice} cr) — a sign of trust they may accept or refuse; if taken, the 2D6 decides if they open up or you slip a tell")"
                        @onclick="@(() => OfferContactDrink(giver))">🥃 Offer @display a drink · @keep.DrinkPrice cr</button>
            @if (knownFav is { } kf2)
            {
                <span class="bar-favorite small" title="You've learned what they drink">❤ @kf2.Name</span>
            }
            </div>
        }
    </text>;

    private void DrawPyramids()
    {
        for (int i = 0; i < AncientsRule.PyramidCount; i++)
        {
            if (!AncientsRule.Revealed(i, _ship.Position, SimTime))
            {
                continue;
            }

            Vector2d position = AncientsRule.PyramidPosition(i, SimTime);
            (float sx, float sy) = _camera.WorldToScreen(position);
            Span<float> triangle = stackalloc float[8];
            triangle[0] = sx; triangle[1] = sy - 6;
            triangle[2] = sx - 5; triangle[3] = sy + 4;
            triangle[4] = sx + 5; triangle[5] = sy + 4;
            triangle[6] = sx; triangle[7] = sy - 6;
            _renderer!.DrawPolyline(triangle, PyramidColor, 1.6f);
            _renderer.DrawText(sx + 8, sy - 6, "◬ ???", PyramidColor);
        }
    }

    private void DrawOrdnance()
    {
        foreach (OrdnanceState round in _ordnance)
        {
            if (round.Spent)
            {
                continue;
            }

            (float sx, float sy) = _camera.WorldToScreen(round.State.Position);
            _renderer!.DrawCircle(sx, sy, round.Round.Kind == OrdnanceKind.Missile ? 2.5f : 1.8f,
                OrdnanceColor, OrdnanceColor);
            // A short streak along the velocity so a round reads as MOVING at map zoom.
            Vector2d tail = round.State.Position - round.State.Velocity.Normalized() * (_camera.MetersPerPixel * 6);
            (float tx, float ty) = _camera.WorldToScreen(tail);
            Span<float> streak = stackalloc float[4];
            streak[0] = sx; streak[1] = sy; streak[2] = tx; streak[3] = ty;
            _renderer.DrawPolyline(streak, OrdnanceColor with { A = 120 }, 1f);
        }
    }
}
