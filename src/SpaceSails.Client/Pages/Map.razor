@page "/map"
@implements IDisposable
@implements IHandleEvent
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Globalization
@using Microsoft.AspNetCore.SignalR.Client
@using SpaceSails.Client.Rendering
@using SpaceSails.Contracts
@using SpaceSails.Core

<PageTitle>SpaceSails — Map</PageTitle>

<div @ref="_focusableDiv" class="map-page" tabindex="0" @onkeydown="OnKeyDown" @onkeyup="OnKeyUp" @onfocusout="OnFocusOut">
    <canvas id="@CanvasId" class="map-canvas"
            @onwheel="OnWheel" @onwheel:preventDefault="true"
            @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove"
            @onpointerup="OnPointerUp" @onpointerleave="OnPointerUp">
    </canvas>

    <div class="map-hud">
        <div class="btn-toolbar bg-dark bg-opacity-75 rounded p-2 gap-2 align-items-center" role="toolbar" aria-label="Time warp controls">
            <div class="btn-group me-2" role="group" aria-label="Warp level">
                @foreach (int level in WarpLevels)
                {
                    <button type="button"
                            class="btn btn-sm @(!Paused && Warp == level ? "btn-primary" : "btn-outline-light")"
                            @onclick="() => SetWarp(level)">
                        @level&times;
                    </button>
                }
            </div>
            <button type="button" class="btn btn-sm @(Paused ? "btn-warning" : "btn-outline-light") me-2" @onclick="TogglePause">
                @(Paused ? "Resume" : "Pause")
            </button>
            <button type="button" class="btn btn-sm @(FollowShip ? "btn-info" : "btn-outline-light") me-2" @onclick="ToggleFollow">
                Follow Ship
            </button>
            <button type="button" class="btn btn-sm @(PlotMode ? "btn-success" : "btn-outline-light") me-2" @onclick="TogglePlotMode">
                @(PlotMode ? "Play" : "Plot")
            </button>
            <button type="button" class="btn btn-sm @(_showTraffic ? "btn-primary" : "btn-outline-light") me-2" @onclick="ToggleTraffic">
                Traffic
            </button>
            @if (!_mp)
            {
                <button type="button" class="btn btn-sm @(_showDock ? "btn-success" : "btn-outline-light") me-2"
                        disabled="@(!_docked)" @onclick="ToggleDock">
                    Dock
                </button>
                <button type="button" class="btn btn-sm @(_showTutorial ? "btn-info" : "btn-outline-light")" @onclick="ToggleTutorial">
                    First hunt
                </button>
            }
            <button type="button" class="btn btn-sm @(_showScope ? "btn-info" : "btn-outline-light") ms-2" @onclick="ToggleScope">
                Scope
            </button>
            <button type="button" class="btn btn-sm @(_deckMode ? "btn-warning" : "btn-outline-light")" @onclick="ToggleDeck">
                Deck
            </button>
        </div>

        <div class="map-readouts bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
            <div class="mb-1">
                <span class="fw-bold">@_scenarioName</span>
                @if (_plasma is not null)
                {
                    <span class="badge bg-info text-dark ms-1">EU ⚡</span>
                }
                @if (_mp)
                {
                    <span class="badge bg-success ms-1">MP 🛰️</span>
                }
            </div>
            @if (_mp)
            {
                <div>Crew: @_playerCount aboard</div>
                <div>Link: @ConnectionLabel</div>
            }
            <div>Sim time: @FormatSimTime(SimTime)</div>
            @if (_mp)
            {
                <div>Warp: @(_effectiveWarp == 0 ? "paused" : $"{_effectiveWarp}×") @(_effectiveWarp != Warp ? "(session)" : "")</div>
            }
            else
            {
                <div>Warp: @(Paused ? "paused" : $"{_effectiveWarp}×") @(Warp != _effectiveWarp ? $"(auto-drop from {Warp}×)" : "")</div>
            }
            <div>Zoom: @FormatZoom(_camera.MetersPerPixel)</div>
            <hr />
            <div>Ship speed: @(((_ship.Velocity.Length) / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s</div>
            <div>Mass pulses: @_reactionMassPulses / @ReactionMassCapacity</div>
            <div>Credits: @_credits.ToString("N0", CultureInfo.InvariantCulture)</div>
            <div>Cargo: @_cargoUnits / @CargoCapacity units@(_cargoValue > 0 ? $" (worth {_cargoValue:N0} cr)" : "")</div>
            <div>Nearest: @_nearestBody?.Name (@FormatDistance((_ship.Position - _nearestBodyPosition).Length), @(((_ship.Velocity - _nearestBodyVelocity).Length / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s rel)</div>
            @if (_plasma is not null)
            {
                int chargePct = (int)Math.Round(_ship.Charge * 100);
                string chargeClass = _ship.Charge >= ArcChargeThreshold ? "bg-danger"
                    : _ship.Charge >= 0.6 ? "bg-warning" : "bg-info";
                <hr />
                <div>Charge: @chargePct% @(_ship.Charge >= ArcChargeThreshold ? "— ARCING RISK" : "")</div>
                <div class="progress" role="progressbar" aria-label="Hull charge">
                    <div class="progress-bar @chargeClass" style="width: @chargePct%"></div>
                </div>
                @if (_ship.Charge >= ArcChargeThreshold)
                {
                    <div class="text-danger fw-bold">⚡ ARCING — visible system-wide</div>
                }
            }
            @if (_pulseMessage is not null)
            {
                <div class="text-warning">@_pulseMessage</div>
            }
            @if (_captureEngaged)
            {
                <hr />
                <div class="mb-1">Shuttles away — boarding @_captureTargetCallsign (@((int)(_captureProgress * 100))%)</div>
                <div class="progress" role="progressbar" aria-label="Boarding progress">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                         style="width: @(((int)(_captureProgress * 100)))%"></div>
                </div>
            }
        </div>

        @if (PlotMode)
        {
            <div class="map-plot bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
                <div class="fw-bold mb-1">Plotting</div>
                <div class="mb-1">Scrub: @FormatSimTime(ScrubTime)</div>
                @* stopPropagation: arrow keys must adjust the control, not fire live ship pulses. *@
                <input type="range" class="form-range" min="0" max="@CurrentPlotHorizonSeconds" step="3600"
                       @bind="_scrubOffsetSeconds" @bind:event="oninput" @onkeydown:stopPropagation="true" />
                <div class="d-flex justify-content-between align-items-center mb-2 gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="AddBurnAtScrub">
                        Add burn at scrub
                    </button>
                    <select class="form-select form-select-sm map-plot-horizon" title="Path horizon"
                            @bind="_horizonChoice" @bind:after="ReprojectTrajectory">
                        <option value="auto">auto</option>
                        <option value="7">7 d</option>
                        <option value="30">30 d</option>
                        <option value="180">180 d</option>
                        <option value="730">2 yr</option>
                    </select>
                    <span>Planned: @PlannedPulseTotal() / @_reactionMassPulses</span>
                </div>

                @if (_planNodes.Count == 0)
                {
                    <div class="text-secondary">No maneuver nodes. Scrub to a future time and add a burn.</div>
                }
                else
                {
                    <div class="map-plot-nodes">
                        @foreach (PlanNode node in _planNodes)
                        {
                            <div class="d-flex align-items-center gap-1 mb-1 @(node.Stale ? "text-decoration-line-through text-secondary" : "")">
                                <span class="flex-grow-1">@FormatSimTime(node.SimTime)</span>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Burn direction">
                                    <button type="button"
                                            class="btn @(node.Action == ManeuverAction.Accelerate ? "btn-success" : "btn-outline-secondary")"
                                            @onclick="() => SetAction(node, ManeuverAction.Accelerate)">+</button>
                                    <button type="button"
                                            class="btn @(node.Action == ManeuverAction.Decelerate ? "btn-warning" : "btn-outline-secondary")"
                                            @onclick="() => SetAction(node, ManeuverAction.Decelerate)">&minus;</button>
                                </div>
                                @* stopPropagation: typing -/+/arrows here must edit the number, not fire live pulses. *@
                                <input type="number" class="form-control form-control-sm map-plot-pulses"
                                       min="1" max="@MaxNodePulses" value="@node.Pulses"
                                       @onchange="e => SetPulses(node, e)" @onkeydown:stopPropagation="true" />
                                <button type="button" class="btn btn-sm btn-outline-info" title="Re-time to scrub"
                                        @onclick="() => RetimeToScrub(node)">@@</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" title="Delete"
                                        @onclick="() => DeleteNode(node)">&times;</button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (_showTraffic && _mp)
    {
        <div class="map-traffic">
            <div class="card bg-dark bg-opacity-75 text-light">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span class="fw-bold small">Contacts (@_mpContacts.Count)</span>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="ToggleTraffic"></button>
                </div>
                <div class="card-body p-0 map-traffic-scroll">
                    <table class="table table-sm table-dark align-middle mb-0 small">
                        <thead>
                            <tr><th>Callsign</th><th>Kind</th><th>Cargo</th></tr>
                        </thead>
                        <tbody>
                            @if (_mpContacts.Count == 0)
                            {
                                <tr><td colspan="3" class="text-secondary">No contacts in sensor range.</td></tr>
                            }
                            else
                            {
                                @foreach (ContactDto c in _mpContacts)
                                {
                                    <tr>
                                        <td>@c.Callsign</td>
                                        <td>@c.Kind</td>
                                        <td>@(c.CargoClass ?? "—")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (_showTraffic)
    {
        <div class="map-traffic">
            <div class="card bg-dark bg-opacity-75 text-light">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span class="fw-bold small">Traffic board</span>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="ToggleTraffic"></button>
                </div>
                <div class="card-body p-0 map-traffic-scroll">
                    <table class="table table-sm table-dark table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Callsign</th>
                                <th>Cargo</th>
                                <th>Route</th>
                                <th>Departs</th>
                                <th>Last seen</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (NpcState npc in _npcStates)
                            {
                                <tr class="map-traffic-row @(npc.Ship.Id == _selectedTargetId ? "table-primary" : "")"
                                    @onclick="() => SelectTarget(npc.Ship.Id)">
                                    <td>@npc.Ship.Callsign</td>
                                    <td>@npc.Ship.CargoClass</td>
                                    <td>@RouteLabel(npc.Ship)</td>
                                    <td>@FormatDeparture(npc.Ship.DepartureTime)</td>
                                    <td>@(npc.LastObservation is { } o ? FormatSimTime(o.SimTime) : "—")</td>
                                    <td>@StatusLabel(npc)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (SelectedTrackedTarget() is { } sel)
                {
                    <div class="card-footer py-1">
                        <button type="button" class="btn btn-sm @(_pinned ? "btn-warning" : "btn-outline-light")" @onclick="TogglePin">
                            Pin: brakes at @BodyName(sel.Ship.DestinationId)
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (Adrift)
    {
        <div class="map-adrift">
            <div class="alert alert-danger d-flex align-items-center gap-3 mb-0 shadow" role="alert">
                <span class="fw-bold">Adrift — out of reaction mass.</span>
                <button type="button" class="btn btn-sm btn-light" @onclick="RequestRescue">Request rescue</button>
            </div>
        </div>
    }

    @if (_showDock && !_mp)
    {
        <div class="map-dock">
            <div class="card bg-dark bg-opacity-75 text-light">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span class="fw-bold small">Docked at @BodyName(_dockBodyId ?? "")</span>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="ToggleDock"></button>
                </div>
                <div class="card-body p-2 small">
                    <div class="d-flex gap-2 mb-2">
                        <button type="button" class="btn btn-sm btn-success flex-grow-1" disabled="@(_cargoValue <= 0)" @onclick="SellCargo">
                            Sell cargo (@_cargoValue.ToString("N0", CultureInfo.InvariantCulture) cr)
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-light flex-grow-1" disabled="@(_reactionMassPulses >= ReactionMassCapacity)" @onclick="RefillReactionMass">
                            Refill mass (free)
                        </button>
                    </div>
                    <div class="fw-bold mb-1">Upgrades</div>
                    <table class="table table-sm table-dark mb-0">
                        <tbody>
                            <tr>
                                <td>Reaction mass<br /><span class="text-secondary">Lv @_massLevel → cap @(ReactionMassCapacity + 150)</span></td>
                                <td class="text-end align-middle">
                                    <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_massLevel))" @onclick='() => BuyUpgrade("mass")'>
                                        @UpgradePrice(_massLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td>Sensor range<br /><span class="text-secondary">Lv @_sensorLevel → @FormatDistance(SensorModel.Default.RangeMeters * Math.Pow(1.4, _sensorLevel + 1))</span></td>
                                <td class="text-end align-middle">
                                    <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_sensorLevel))" @onclick='() => BuyUpgrade("sensor")'>
                                        @UpgradePrice(_sensorLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td>Cargo hold<br /><span class="text-secondary">Lv @_holdLevel → @(CargoCapacity + 10) units</span></td>
                                <td class="text-end align-middle">
                                    <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_holdLevel))" @onclick='() => BuyUpgrade("hold")'>
                                        @UpgradePrice(_holdLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (_showTutorial && !_mp)
    {
        <div class="map-tutorial">
            <div class="card bg-dark bg-opacity-75 text-light">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span class="fw-bold small">First hunt</span>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="ToggleTutorial"></button>
                </div>
                <div class="card-body p-2 small">
                    @for (int i = 0; i < TutorialSteps.Length; i++)
                    {
                        bool done = _tutorialStep > i;
                        bool current = _tutorialStep == i;
                        <div class="@(done ? "text-secondary" : current ? "fw-bold text-info" : "")">
                            @(done ? "✓" : "•") @TutorialSteps[i]
                        </div>
                    }
                    @if (_tutorialStep >= TutorialSteps.Length)
                    {
                        <hr />
                        <div class="text-warning">You're a pirate now. The He3 haulers from Saturn are worth 15× more.</div>
                    }
                </div>
            </div>
        </div>
    }
    <div class="map-scope @(_showScope ? "" : "d-none")">
        <div class="card bg-dark bg-opacity-75 text-light">
            <div class="card-header py-1 d-flex justify-content-between align-items-center gap-1">
                <span class="fw-bold small">Scope 🔭</span>
                <div class="btn-group btn-group-sm" role="group" aria-label="Scope target">
                    <button type="button" class="btn btn-outline-light py-0" @onclick="() => CycleScopeTarget(-1)">◀</button>
                    <button type="button" class="btn @(_scopeManualId is null ? "btn-info" : "btn-outline-light") py-0" @onclick="() => _scopeManualId = null">AUTO</button>
                    <button type="button" class="btn btn-outline-light py-0" @onclick="() => CycleScopeTarget(1)">▶</button>
                </div>
                <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="ToggleScope"></button>
            </div>
            <div class="card-body p-1">
                <canvas id="@ScopeCanvasId" class="map-scope-canvas"></canvas>
            </div>
        </div>
    </div>
</div>

@code {
    private const string CanvasId = "map-canvas";
    private static readonly int[] WarpLevels = [1, 10, 100, 1000, 10000];
    private const int OrbitSegments = 128;

    private static readonly RgbaColor Background = new(6, 9, 18);
    private static readonly RgbaColor OrbitColor = new(80, 100, 130, 130);
    private static readonly RgbaColor ShipColor = new(255, 210, 80);
    private static readonly RgbaColor TrajectoryColor = new(255, 165, 0);
    private static readonly RgbaColor LabelColor = new(224, 228, 236);
    private static readonly RgbaColor GhostShipColor = new(255, 210, 80, 120);
    private static readonly RgbaColor AccelNodeColor = new(80, 220, 120);
    private static readonly RgbaColor DecelNodeColor = new(240, 120, 80);
    private static readonly RgbaColor StaleNodeColor = new(140, 140, 140, 128);
    private const byte GhostBodyAlpha = 90; // ~35% of 255

    private readonly Camera _camera = new();
    private CanvasRenderer? _renderer;
    private ICelestialEphemeris? _ephemeris;
    private Simulator? _simulator;
    private Simulator? _npcSimulator;
    private PlasmaEnvironment? _plasma;
    private string _scenarioName = "";
    private ShipState _ship;
    private IReadOnlyList<TrajectorySample> _samples = [];
    private float[] _scratch = [];
    private bool _started;

    private int _viewportWidth = 1280;
    private int _viewportHeight = 800;

    private double SimTime;
    private int Warp = 1;
    private int _effectiveWarp = 1;
    private bool Paused;
    private bool FollowShip = true;

    private double? _lastTimestampMs;
    private double _lastHudUpdateMs;
    private bool _dragging;
    private double _lastPointerX;
    private double _lastPointerY;

    // M3 additions
    private double _simAccumulator;
    private double _lastPulseSimTime = -PulseCooldownSeconds; // so the very first pulse isn't rejected
    private int _reactionMassPulses = 250;
    private const double PulseCooldownSeconds = 1.0;
    // Gravity bends the real path away from a ribbon projected in the past, so re-project after
    // this much sim time even without a pulse (≈2 real seconds at max warp).
    private const double ProjectionRefreshSimSeconds = 6 * 3600;
    private double _nextProjectionSimTime;
    private string? _pulseMessage;
    private double _pulseMessageExpiresMs;
    private const int MaxStepsPerFrame = 20000;

    // M4 additions — plotting mode
    // The ribbon/projection horizon. 60 days from "now"; ProjectAdaptive keeps this cheap
    // (coarse dt in deep space, fine near a mass) and is the single source of truth for the
    // ribbon polyline, the scrub ghost-ship, and node markers.
    // The Saturn metric (owner): one plotting sit-down must cover a whole Earth->Saturn sail.
    // The probe's reference plan (accel 12 @ day 82) arrives day 278; two years leaves slack
    // for lazier sails. The ribbon projects at maxTimeStep 3 h to keep 730-day re-projections
    // cheap in interpreted WASM (~5.8k steps); plan-node times still land exactly.
    private const double PlotHorizonSeconds = 730 * 24 * 3600;

    // Owner request: the future path is adjustable. AUTO follows the plan — last burn + 90
    // days (min 30 d) — so ship-to-ship work stays tight and a plotted Saturn sail stretches
    // the ribbon automatically; presets override.
    private string _horizonChoice = "auto";
    private double CurrentPlotHorizonSeconds
    {
        get
        {
            if (_horizonChoice != "auto" && double.TryParse(_horizonChoice, out double days))
            {
                return days * 86400;
            }

            double lastNode = 0;
            foreach (PlanNode node in _planNodes)
            {
                if (!node.Stale && node.SimTime > lastNode)
                {
                    lastNode = node.SimTime;
                }
            }

            double horizon = lastNode > SimTime ? lastNode - SimTime + 90 * 86400 : 30 * 86400;
            return Math.Clamp(horizon, 30 * 86400, PlotHorizonSeconds);
        }
    }
    private const int MaxNodePulses = 20;
    private const int MinNodePulses = 1;
    private bool PlotMode;
    private int _warpBeforePlot = 1;
    private double _scrubOffsetSeconds;
    private readonly List<PlanNode> _planNodes = [];
    private ManeuverPlan _plan = ManeuverPlan.Empty;

    private double ScrubTime => _ship.SimTime + _scrubOffsetSeconds;

    // M5 additions — traffic & prediction
    private const double SensorSweepSimSeconds = 60;            // sensor cadence, sim seconds
    private const double NpcDespawnRadius = 1e10;               // matches RoutePlanner.ArrivalToleranceMeters
    private const double PredictionRefreshSimSeconds = 6 * 3600; // periodic cone re-solve
    private const double TrackedWindowSimSeconds = 2 * 3600;    // "Tracked" if seen within this
    private const double DaySeconds = 86400;
    private const int ConeTargetPoints = 300;                   // stride the cone down to ~this many points
    private const double ConeMaxHalfWidthMeters = 3e11;        // ~2 AU: stop drawing where prediction is meaningless

    private static readonly RgbaColor NpcColor = new(200, 120, 255);
    private static readonly RgbaColor NpcLastSeenColor = new(200, 120, 255, 90);
    private static readonly RgbaColor ConeCenterColor = new(150, 150, 220, 140);
    private static readonly RgbaColor ConeBoundaryColor = new(150, 150, 220, 80);

    private NpcState[] _npcStates = [];
    private bool _showTraffic;
    private string? _selectedTargetId;

    // M6 additions — piracy economy, capture, dock, tutorial
    // A market body's "port zone" (0.067 AU). Deliberately generous: with ±10% prograde-only
    // pulses, *returning* to a body you've left is the hardest maneuver in the game — offline
    // search showed post-capture orbits graze 5.1e9 from Earth for weeks without re-threading
    // anything tighter. The player spawns inside Earth's zone (fence available immediately —
    // natural onboarding), and the Luna-pod tutorial hunt completes within it; the real hunts
    // (He3 haulers) still demand full interplanetary voyages between zones.
    private const double DockRadiusMeters = 1e10;
    private const int CaptureWarpCap = 10;            // the 60 s window must be holdable
    private static readonly string[] MarketBodies = ["earth", "mars", "venus"];

    private int _credits;
    private int _cargoUnits;
    private int _cargoValue;
    private int _massLevel;                            // reaction-mass capacity: 250 + 150/level
    private int _sensorLevel;                          // sensor range: base × 1.4/level
    private int _holdLevel;                            // cargo hold: 10 + 10/level
    private SensorModel _sensor = SensorModel.Default;

    private double _captureProgress;                   // boarding progress fraction [0,1)
    private bool _captureEngaged;
    private string? _captureTargetCallsign;

    private bool _docked;
    private string? _dockBodyId;
    private bool _showDock;

    private bool _showTutorial = true;
    private int _tutorialStep;                         // 0..5 = current task, 6 = complete

    private static readonly string[] TutorialSteps =
    [
        "Open the traffic board and select the Luna pod",
        "Plot an intercept — enter Plot, add a burn, watch the ribbon cross its cone",
        "Close to boarding range and match velocity",
        "Hold the window — board it",
        "Dock at Earth and sell",
        "Spend it — buy an upgrade",
    ];

    private int ReactionMassCapacity => 250 + 150 * _massLevel;
    private int CargoCapacity => 10 + 10 * _holdLevel;
    private bool Adrift => _reactionMassPulses == 0 && !_docked && !_mp;
    private static int UpgradePrice(int level) => 2000 * (1 << level);
    private bool _pinned;
    private ManeuverPlan? _pinnedPlan;
    private PredictedPath? _predictedPath;
    private bool _predictionDirty;
    private double _nextSweepSimTime;
    private double _nextPredictionSimTime;

    // Scratch buffers for the prediction cone polylines — reused each frame, no per-frame heap churn.
    private float[] _coneCenter = [];
    private float[] _coneUpper = [];
    private float[] _coneLower = [];

    // Live state of one NPC: its immutable schedule entry plus its evolving simulation state and
    // observation history. Mirrors PlanNode's role — mutable client-side wrapper over Core records.
    private sealed class NpcState
    {
        public required NpcShip Ship;
        public ShipState State;
        public bool Active;
        public bool Arrived;
        public bool Boarded;             // cargo taken; keeps flying but empty (M6)
        public bool CurrentlyObserved;   // seen in the most recent sweep
        public Observation? LastObservation;
        public int ObservationCount;
    }

    // Editable client-side node. ManeuverNode is an immutable value type with no notion of
    // "stale"/"executed", so plotting mode tracks those flags here and rebuilds the immutable
    // ManeuverPlan from the non-stale nodes after every edit.
    private sealed class PlanNode
    {
        public double SimTime;
        public ManeuverAction Action;
        public int Pulses = 1;
        public bool Stale;
        public bool Executed;
    }

