@page "/map"
@implements IDisposable
@implements IHandleEvent
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Globalization
@using SpaceSails.Client.Rendering
@using SpaceSails.Contracts
@using SpaceSails.Core
@using SpaceSails.Core.Interior

<PageTitle>SpaceSails — Map</PageTitle>

<div @ref="_focusableDiv" class="map-page @(_peekMap ? "map-peek" : "")" tabindex="0" @onkeydown="OnKeyDown" @onkeyup="OnKeyUp" @onfocusout="OnFocusOut">
    @if (!_worldReady)
    {
        <div class="map-loading d-flex flex-column justify-content-center align-items-center">
            <div class="spinner-border text-info mb-3" role="status" aria-label="Loading"></div>
            <div class="text-light">Rigging the sails…</div>
            <div class="text-secondary small mt-1">planning NPC routes, spinning up the ephemeris</div>
        </div>
    }
    <canvas id="@CanvasId" class="map-canvas"
            @onwheel="OnWheel" @onwheel:preventDefault="true"
            @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove"
            @onpointerup="OnPointerUp" @onpointerleave="OnPointerUp">
    </canvas>

    @* Start picker (2026-07-08): "why always Earth?" — a boot chooser of named start points, over
       the freshly-built world. Skips the long transit for playtesting and lets a run begin at a gas
       giant or already ashore. Suppressed when /map?start=<id> already picked one. Same registry. *@
    @if (_showStartPicker)
    {
        <div class="start-picker-backdrop">
            <div class="start-picker">
                <div class="start-picker-title">Choose your start</div>
                <div class="start-picker-sub">Where does this run begin? Earth is the usual berth — the rest skip the haul out (handy for playtesting).</div>
                <div class="start-picker-list">
                    @* The personal vault (#225): a saved run leads the picker — continue DOCKED at the
                       berth the vault remembers, above the fresh starts. *@
                    @if (_resumeAvailable)
                    {
                        <button type="button" class="start-picker-option start-picker-continue" title="Pick up where you left off — the vault wakes you docked at this berth"
                                @onclick="ContinueFromSave">
                            <span class="start-picker-icon">💾</span>
                            <span class="start-picker-text">
                                <span class="start-picker-label">Continue — docked at @(_resumeHavenName ?? "your last berth")</span>
                                <span class="start-picker-blurb">Resume your saved run: purse, cargo, contacts, hoard and heat, all restored.@(_resumeTampered ? " 📛 ledger marked — the save file was edited outside the game." : "")</span>
                            </span>
                        </button>
                    }
                    @foreach (StartPoint sp in StartPoints.Where(s => !s.Test))
                    {
                        StartPoint option = sp;
                        <button type="button" class="start-picker-option" title="Start the voyage from this berth — skips the long haul out" @onclick="() => ChooseStart(option.Id)">
                            <span class="start-picker-icon">@option.Icon</span>
                            <span class="start-picker-text">
                                <span class="start-picker-label">@option.Label</span>
                                <span class="start-picker-blurb">@option.Blurb</span>
                            </span>
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @* #255 — the diegetic long-haul jump overlay: the one loading bar allowed to be a FEATURE. While
       the world re-seeds at the arrival epoch, the screen SAYS the state — CROSSING THE VOID, the years
       ticking up, and a charming note that the bus does not stop out here. No cancel is offered. *@
    @if (_jumpActive)
    {
        <div class="jump-overlay">
            <div class="jump-overlay-inner">
                <div class="jump-overlay-title">🚀 @LongHaul.VoidTitle</div>
                <div class="jump-overlay-year">@LongHaul.VoidYearLine(_jumpYear, _jumpTotalYears)</div>
                <div class="jump-overlay-bar">
                    <div class="jump-overlay-fill" style="width:@(_jumpTotalYears > 0 ? (int)(100.0 * Math.Clamp(_jumpYear, 0, _jumpTotalYears) / _jumpTotalYears) : 100)%"></div>
                </div>
                <div class="jump-overlay-bound">@LongHaul.VoidBound(_jumpDestName)</div>
                <div class="jump-overlay-note">@_jumpFlavor</div>
                <div class="jump-overlay-nostop">@LongHaul.VoidNoStop</div>
            </div>
        </div>
    }

    @* #261 — the COMPUTED skip's short beat: a jump-scale coast is reckoned in closed form (or chunked with
       yields), never integrated into a frozen tab. A mundane fast-forward, not the long haul's dramatic
       CROSSING THE VOID — so it says "COAST CONSUMED" and lets out in a beat. *@
    @if (_coastSkipActive)
    {
        <div class="jump-overlay">
            <div class="jump-overlay-inner">
                <div class="jump-overlay-title">⏭ @WarpSkip.CoastConsumedTitle</div>
                <div class="jump-overlay-bound">@WarpSkip.CoastConsumedBound(_coastSkipLabel)</div>
                <div class="jump-overlay-note">@WarpSkip.CoastComputingNote(_coastSkipDays)</div>
            </div>
        </div>
    }

    @* View-object popup: a Gen-AI image (a souvenir T-shirt, a fridge magnet, any lore prop) the
       player walks up to and inspects with E. Click away, hit Close, or press E again to dismiss. *@
    @if (_viewObject is { } vo)
    {
        <div class="view-object-backdrop" @onclick="CloseViewObject">
            <div class="view-object" @onclick:stopPropagation="true">
                <div class="view-object-title">@vo.Label</div>
                <img class="view-object-img" src="@vo.ImageUrl" alt="@vo.Label" />
                @if (vo.Caption is { Length: > 0 } cap)
                {
                    <div class="view-object-caption">@cap</div>
                }
                <button type="button" class="view-object-close" title="Put it back down and step away" @onclick="CloseViewObject">Close</button>
            </div>
        </div>
    }

    @* Hatch keypad: brought up by knocking on the specific locked hatch a crack job sent you to. Key in
       the code the Fixer quoted; right code pops the hatch (job → PickedUp), wrong code buzzes red. *@
    @if (_pinJob is { } pinJob)
    {
        <div class="pin-backdrop" @onclick="CancelPin">
            <div class="pin-pad" @onclick:stopPropagation="true">
                <div class="pin-pad-hatch">@(_pinHatch?.Label ?? "LOCKED HATCH")</div>
                <div class="pin-pad-sub">ENTER ACCESS CODE</div>
                <div class="pin-pad-display">@PinDisplay</div>
                <div class="pin-pad-keys">
                    @foreach (string d in new[] { "1", "2", "3", "4", "5", "6", "7", "8", "9" })
                    {
                        string digit = d;
                        <button type="button" class="pin-pad-key" title="Key this digit into the access code" @onclick="() => PinPush(digit)">@digit</button>
                    }
                    <button type="button" class="pin-pad-key pin-pad-key-fn" title="Clear the code and start over" @onclick="PinClear">C</button>
                    <button type="button" class="pin-pad-key" title="Key a zero into the access code" @onclick='() => PinPush("0")'>0</button>
                    <button type="button" class="pin-pad-key pin-pad-key-go" title="Try this code on the hatch" @onclick="SubmitPin">↵</button>
                </div>
                <button type="button" class="pin-pad-cancel" title="Back off — leave the hatch locked" @onclick="CancelPin">Cancel</button>
            </div>
        </div>
    }

    @* Deck / first-person pulse toast: the Nav HUD that normally hosts _pulseMessage is hidden while
       you're walking the ship, so console quips (the HEAD 🚽 gag, cargo tally, vent report, shuttle
       standby) would render nowhere. Surface them over the canvas here, centred near the top. *@
    @if (_deckMode && _pulseMessage is not null)
    {
        <div class="deck-pulse-toast">@_pulseMessage</div>
    }

    @* A bar stranger's contract, slid across the table (go-ashore quests, M-Q1): shown over the deck
       canvas while ashore, with Take / Pass. Same overlay family as the deck-pulse-toast. *@
    @if (_deckMode && _pendingOffer is { } offer)
    {
        <div class="deck-offer-card">
            <div class="deck-offer-giver">◈ @offer.Giver</div>
            <div class="deck-offer-blurb">@offer.Blurb</div>
            <div class="deck-offer-reward">
                @(offer.Reward > 0
                    ? $"Reward: {offer.Reward.ToString("N0", CultureInfo.InvariantCulture)} cr"
                    : "On the house — the tip's the payoff 🕸")
            </div>
            <div class="deck-offer-actions">
                <button type="button" class="btn btn-sm btn-warning" title="Take the stranger's offer — it lands in your logbook" @onclick="AcceptOffer">@(_pendingOffer?.Kind == QuestKind.Intel ? "Take the tip" : "Take the job")</button>
                <button type="button" class="btn btn-sm btn-outline-light" title="Wave the offer off — no hard feelings" @onclick="DeclineOffer">Pass</button>
            </div>
        </div>
    }

    @* PR-WIRE — the favor bank card (FridaySecondPlan §0). Opened at a contact's table with 'b' (in
       person) or from the dark-web desk (wire). Park coin off the purse (safe from confiscation),
       draw it back, or borrow gas money against a favor. Same overlay family as the deck-offer-card. *@
    @if (_bankSession is { } bank)
    {
        long _bankBal = _contacts.For(bank.ContactId).CreditBalance;
        int _bankMissions = _contacts.For(bank.ContactId).MissionsCompleted;
        bool _bankTrusted = ContactSheets.WillStake(_bankMissions);
        TrustTier _bankTier = ContactSheets.TrustFor(_bankMissions);
        <div class="deck-offer-card deck-bank-card">
            <div class="deck-offer-giver">💰 @bank.DisplayName's ledger @(bank.ViaWire ? "· 🕸 wire" : "· 🤝 in person")</div>
            <div class="deck-bank-balance small">
                @if (_bankBal > 0)
                {
                    <span class="text-success">They hold @_bankBal.ToString("N0", CultureInfo.InvariantCulture) cr of yours</span>
                }
                else if (_bankBal < 0)
                {
                    <span class="text-danger">You owe them @((-_bankBal).ToString("N0", CultureInfo.InvariantCulture)) cr</span>
                }
                else
                {
                    <span class="text-secondary">No coin between you yet</span>
                }
                <span class="text-secondary"> · trust: @_bankTier · purse @_credits.ToString("N0", CultureInfo.InvariantCulture) cr</span>
            </div>
            @if (_heat.Level > 0)
            {
                <div class="deck-bank-warn small text-warning">⚠ Heat @_heat.Level — parking coin now is FENCING: a cut comes off the top (still less than the collectors would take).</div>
            }
            <div class="deck-bank-actions">
                <div class="deck-bank-row small">
                    <span class="deck-bank-label">Deposit</span>
                    @foreach (long amt in BankAmounts)
                    {
                        long a = amt;
                        <button type="button" class="btn btn-sm btn-outline-success py-0 px-1"
                                disabled="@(_credits < a)" title="@($"Park {a:N0} cr with {bank.DisplayName} — off the purse, safe from confiscation")"
                                @onclick="() => BankDeposit(a)">@a.ToString("N0", CultureInfo.InvariantCulture)</button>
                    }
                </div>
                <div class="deck-bank-row small">
                    <span class="deck-bank-label">Withdraw</span>
                    @foreach (long amt in BankAmounts)
                    {
                        long a = amt;
                        <button type="button" class="btn btn-sm btn-outline-info py-0 px-1"
                                disabled="@(_bankBal < a)" title="@($"Draw {a:N0} cr back into the purse")"
                                @onclick="() => BankWithdraw(a)">@a.ToString("N0", CultureInfo.InvariantCulture)</button>
                    }
                </div>
                @if (_bankBal < 0)
                {
                    <div class="deck-bank-row small">
                        <span class="deck-bank-label">Repay</span>
                        @foreach (long amt in BankAmounts)
                        {
                            long a = amt;
                            <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1"
                                    disabled="@(_credits < a)" title="@($"Pay {a:N0} cr toward what you owe {bank.DisplayName}")"
                                    @onclick="() => BankRepay(a)">@a.ToString("N0", CultureInfo.InvariantCulture)</button>
                        }
                    </div>
                }
                @if (_bankTrusted && _bankBal >= 0)
                {
                    <div class="deck-bank-row small">
                        <span class="deck-bank-label">Borrow</span>
                        <button type="button" class="btn btn-sm btn-warning py-0 px-1"
                                title="@($"Take {BankLoanPrincipal:N0} cr on a favor — you'll owe {bank.DisplayName} one quiet delivery")"
                                @onclick="() => BorrowFavorFromBank()">📡 favor wire · @BankLoanPrincipal.ToString("N0", CultureInfo.InvariantCulture) cr</button>
                    </div>
                }
            </div>
            @if (bank.Notice is { } notice)
            {
                <div class="deck-bank-notice small">@notice</div>
            }
            <div class="deck-offer-actions">
                <button type="button" class="btn btn-sm btn-outline-light" title="Close the ledger and step back" @onclick="CloseBank">Done</button>
            </div>
        </div>
    }

    @* #247 — the barkeep's counter menu. Owner ashore: "How do I get a drink at the Rusty bar here?"
       Walk up to the bar, press E: buy the house special (routes through the Galley's rum-tot law, so
       overdoing it tilts the deck ashore too), stand a round for the room (warms the regulars), or ask
       for a rumor. Same overlay family as the deck-offer-card. *@
    @if (_deckMode && _barMenu is { } keep)
    {
        <div class="deck-offer-card">
            <div class="deck-offer-giver">🍺 @keep.Name · @keep.BarName</div>
            <div class="deck-offer-blurb">
                House special: <strong>@keep.DrinkName</strong> — @keep.DrinkFlavor
            </div>
            @if (_barNotice is { } note)
            {
                <div class="deck-bank-notice small">@note</div>
            }
            <div class="deck-offer-reward">Purse: @_credits.ToString("N0", CultureInfo.InvariantCulture) cr</div>
            @* #306 The drink as a two-edged trust maneuver: a known contact drinking here can be stood a
               glass — trust up, and the 2D6 decides whether they open up or YOU slip a tell. Refusing
               (waving off) costs a little goodwill: the choice is never free. *@
            @foreach ((string giver, string display) in PresentBarContacts())
            {
                <div class="deck-offer-actions">
                    <button type="button" class="btn btn-sm btn-warning" disabled="@(_credits < keep.DrinkPrice)"
                            title="@($"Stand {display} a drink ({keep.DrinkPrice} cr) — trust up; the 2D6 decides if they open up or you slip a tell")"
                            @onclick="@(() => BuyContactDrink(giver))">🥃 Stand @display a drink · @keep.DrinkPrice cr</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            title="@($"Wave off — {display} reads a refused glass as suspicion (small goodwill hit)")"
                            @onclick="@(() => DeclineContactDrink(giver))">✋ Wave off</button>
                </div>
            }
            <div class="deck-offer-actions">
                <button type="button" class="btn btn-sm btn-warning" disabled="@(_credits < keep.DrinkPrice)"
                        title="@($"Buy the house special — {keep.DrinkPrice} cr")" @onclick="BuyHouseSpecial">🍹 @keep.DrinkName · @keep.DrinkPrice cr</button>
                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < keep.RoundPrice)"
                        title="@($"Buy a round for the room — {keep.RoundPrice} cr — warms the regulars drinking here")" @onclick="BuyRoundForRoom">🍻 Round for the room · @keep.RoundPrice cr</button>
                <button type="button" class="btn btn-sm btn-outline-info" title="Ask the barkeep what they've heard lately" @onclick="AskBarkeepForRumor">👂 Hear a rumor</button>
                <button type="button" class="btn btn-sm btn-outline-light" title="Settle up and step back" @onclick="CloseBarkeep">Done</button>
            </div>
        </div>
    }

    @* The shuttle-bay airlock pop-up (#163, "the door you understand as a flight"): walking up to the
       bay's airlock lists the places within one shuttle hop. An interior berth is pickable — confirm and
       the crossing IS the trip, you step off ashore there; a body in range with nowhere to step off says
       so honestly; nothing in range keeps the door shut. Same overlay family as the deck-offer-card. *@
    @if (_deckMode && _shuttleBayStops is { } shuttleStops)
    {
        <div class="deck-shuttle-card">
            <div class="deck-shuttle-title">🚀 Shuttle bay airlock — in range</div>
            @if (shuttleStops.Count == 0)
            {
                <div class="deck-shuttle-empty">
                    Nothing in shuttle range — no berth within
                    @((ShuttleRange.RangeMeters / 1000).ToString("N0", CultureInfo.InvariantCulture)) km.
                    The hatch stays shut.
                </div>
            }
            else
            {
                <div class="deck-shuttle-rows">
                    @foreach (ShuttleStop stop in shuttleStops)
                    {
                        ShuttleStop local = stop;
                        <div class="deck-shuttle-row">
                            <div class="deck-shuttle-dest">
                                <span class="deck-shuttle-name">@(local.HasBerth ? "⚓" : "🌑") @local.Body.Name</span>
                                <span class="deck-shuttle-meta">@FormatDistance(local.DistanceMeters) · ETA @FormatDuration(local.TravelSeconds)</span>
                            </div>
                            <div class="deck-shuttle-row-actions">
                                @if (local.HasBerth)
                                {
                                    <button type="button" class="btn btn-sm btn-warning"
                                            title="Take the shuttle to @local.Body.Name — the clock advances by the crossing, then you step off ashore"
                                            @onclick="() => TakeShuttleTo(local)">Take the shuttle →</button>
                                }
                                @* #223: a landable moon/asteroid grows the buried-treasure doors. Bury sinks
                                   coin/cargo off the ship (invisible to confiscation); Dig lifts a known cache. *@
                                @if (IsLandableForCache(local.Body))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning"
                                            title="Land on @local.Body.Name and bury a chest on foot — off the ship, off the books (mind the Reevers)"
                                            @onclick="() => OpenBuryChooser(local)">⛏ Bury a chest</button>
                                }
                                @if (_caches.HasCacheAt(local.Body.Id))
                                {
                                    <button type="button" class="btn btn-sm btn-success"
                                            title="Land and dig at the X on foot — the map never lies, but the watchdogs may still be about"
                                            @onclick="() => DigAt(local)">🗺 Dig at the X</button>
                                }
                                @if (!local.HasBerth && !IsLandableForCache(local.Body) && !_caches.HasCacheAt(local.Body.Id))
                                {
                                    <span class="deck-shuttle-noberth"
                                          title="In shuttle range, but there's nowhere to step off yet">no berth ashore yet</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            <div class="deck-shuttle-actions">
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="CloseShuttleBayDoor">Close hatch</button>
            </div>
        </div>
    }

    @* #223: the bury-a-chest chooser — pick how much of the purse to sink; the hold goes in whole
       (it's small). Confirming flies the shuttle down: the clock advances by the crossing, the loot
       leaves the ship, and the map card is minted. *@
    @if (_buryTarget is { } buryStop)
    {
        <div class="deck-shuttle-card">
            <div class="deck-shuttle-title">⛏ Bury a chest on @buryStop.Body.Name</div>
            <div class="bury-chooser-body">
                <div class="bury-row">
                    <span>Coin to bury</span>
                    <span class="bury-coin">@_buryCoin.ToString("N0", CultureInfo.InvariantCulture) cr</span>
                </div>
                <div class="bury-steppers">
                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="() => AdjustBuryCoin(-500)">−500</button>
                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="() => AdjustBuryCoin(-100)">−100</button>
                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="() => AdjustBuryCoin(100)">+100</button>
                    <button type="button" class="btn btn-sm btn-outline-light" @onclick="() => AdjustBuryCoin(500)">+500</button>
                    <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => SetBuryCoin(_credits)">All @_credits.ToString("N0", CultureInfo.InvariantCulture)</button>
                </div>
                <div class="bury-row bury-cargo">
                    <span>Hold buried with it</span>
                    <span>@(_cargoUnits > 0 ? $"{_cargoUnits} units ({HotHoldUnits()} hot)" : "empty")</span>
                </div>
                <div class="bury-note">Buried loot is off the ship — the collectors take only what they can see. You'll carry the chest out on foot; watch for Reevers.</div>
            </div>
            <div class="deck-shuttle-actions">
                <button type="button" class="btn btn-sm btn-warning" disabled="@(_buryCoin <= 0 && _cargoUnits <= 0)"
                        title="Fly the shuttle down and step out onto the surface — you carry the chest to the dig site and bury it on foot"
                        @onclick="() => ConfirmBury(buryStop)">Land &amp; carry it down ⛏ (@FormatDuration(buryStop.TravelSeconds))</button>
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="CancelBury">Never mind</button>
            </div>
        </div>
    }

    @* #223: the treasure-map card — a full-screen artifact (celebration family). Big body image slot
       (placeholder art until the grok lane fills the manifest), the body as a BIG CAPTION, the
       bearing/paces line, and the big red X. X always marks the spot; the barflies swear it never does. *@
    @if (_treasureMapCard is { } map)
    {
        <div class="mission-celebration-backdrop" @onclick="DismissMapCard">
            <div class="treasure-map-card" @onclick:stopPropagation="true">
                <div class="tm-art" style="background-image: @TreasureMapArtCss(map.BodyId);">
                    <div class="tm-x">✗</div>
                </div>
                <div class="tm-caption">@map.Caption(BodyName(map.BodyId))</div>
                <div class="tm-bearing">🧭 @map.BearingLine</div>
                <div class="tm-contents">🧰 @map.ContentsLine()</div>
                @if (map.ReeverLevel > 0)
                {
                    <div class="tm-bearing">🐕 @map.ReeverLevel Reever@(map.ReeverLevel == 1 ? "" : "s") haunt this ground — the most dangerous lock in the system.</div>
                }
                <div class="tm-flavor">✗ marks the spot. (The barflies swear it never does — out here, they're wrong every time.)</div>
                <button type="button" class="btn btn-warning btn-sm mt-2" title="Tuck the map into the Captain's ledger" @onclick="DismissMapCard">Into the ledger 🗺</button>
            </div>
        </div>
    }

    @* The chooser (owner: "if many objects under click we let the user choose what they
       meant"): candidates ranked contacts → depots → bodies, lane and sky scan last. *@
    @if (_pickMenu is { Count: > 0 } pickList)
    {
        @* #253: header + one row per candidate, flipped away from the near edge. *@
        var pickAt = ClampMenu(_pickMenuX, _pickMenuY, pickList.Count);
        <div class="map-body-menu bg-dark bg-opacity-75 rounded p-2 text-light small shadow"
             style="left: @(pickAt.X.ToString("F0", CultureInfo.InvariantCulture))px; top: @(pickAt.Y.ToString("F0", CultureInfo.InvariantCulture))px">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="text-secondary me-2">Which one?</span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close" title="Close this chooser"
                        @onclick="ClosePickMenu"></button>
            </div>
            <div class="d-grid gap-1">
                @foreach (PickCandidate pick in pickList)
                {
                    PickCandidate local = pick;
                    <button type="button" class="btn btn-sm btn-outline-info text-start py-0" title="@PickHint(local)"
                            @onclick="() => OpenPickCandidate(local)">@local.Icon @local.Label</button>
                }
            </div>
        </div>
    }

    @* 🗺 Layers (owner: "filter what is being shown on the map screens"): per-desk checkbox
       panel, Gemini-consulted placement — small toggle, never a modal over the sky. Only shown on
       the desks that actually render the solar map (Nav, Sensors, the War-room orrery); the other
       desks cover the map with a full-screen panel, so the filter would be dead UI there — and on
       the Captain desk it overlapped the (now three-wide) view-toggle. *@
    @if (_activeDesk is ShipDesk.Nav or ShipDesk.Sensors or ShipDesk.WarRoom)
    {
        <div class="map-layers">
            <button type="button" class="btn btn-sm @(_layersOpen ? "btn-info" : "btn-outline-info")"
                    title="Choose what the map draws on this desk"
                    @onclick="() => _layersOpen = !_layersOpen">🗺 Layers</button>
            @if (_layersOpen)
            {
                <div class="map-layers-panel bg-dark bg-opacity-75 rounded p-2 small shadow text-light">
                    @foreach ((string key, string label, string icon) in MapLayerDefs)
                    {
                        string layerKey = key;
                        <label class="d-block map-layers-row">
                            <input type="checkbox" checked="@LayerVisible(layerKey)" title="Show or hide this layer on the map"
                                   @onchange="() => ToggleLayer(layerKey)" /> @icon @label
                        </label>
                    }
                    <div class="text-secondary mt-1">remembered per desk</div>
                </div>
            }
        </div>
    }

    @* #195 (owner ruling, Friday playtest): the Captain's-desk tutorial pop-up is gone. It floated over
       the Nav toolbar and, like the #169 Luna lesson, presumed onboarding it shouldn't own — the tutorial
       flow (#160) will carry that. The lessons stay reachable at the Captain's desk (0) → Tutorials. *@

    @* First-person ⇄ deck-plan toggle. The F key does this, but it isn't discoverable, so give it a
       visible button while you're aboard (top-down or first person). Mirrors HandleDeckKey's 'f'. *@
    @if (_deckMode)
    {
        <button type="button" class="deck-view-toggle btn btn-sm btn-outline-info"
                title="@(_fpMode ? "Back to the top-down deck plan" : "Step into first person and walk the ship")"
                @onclick="ToggleFirstPerson">
            @(_fpMode ? "🗺 Deck plan (F)" : "🧍 First person (F)")
        </button>
    }

    @* M24: planet click menu — set the body as THE destination so orbit assist tracks it.
       M29: also live on the Sensors desk, where the map is clickable through the desk layer. *@
    @if (_activeDesk is ShipDesk.Nav or ShipDesk.Sensors && _bodyMenuBody is { } menuBody)
    {
        @* #253/#290: up to four action rows on Nav (set dest · arm · 🚀 long haul · 🪂 aerobrake), two on Sensors. *@
        var bodyAt = ClampMenu(_bodyMenuX, _bodyMenuY, 4);
        <div class="map-body-menu bg-dark bg-opacity-75 rounded p-2 text-light small shadow"
             style="left: @(bodyAt.X.ToString("F0", CultureInfo.InvariantCulture))px; top: @(bodyAt.Y.ToString("F0", CultureInfo.InvariantCulture))px">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-bold me-2">@menuBody.Name</span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close" title="Close this body's menu"
                        @onclick="CloseBodyMenu"></button>
            </div>
            <div class="d-grid gap-1">
                @* PR-C desk separation (F7): navigation verbs live on the Nav desk; the same
                   click on Sensors talks scanning. Navigation is done at the Navigation desk. *@
                @if (_activeDesk == ShipDesk.Nav)
                {
                    @if (_destinationBodyId == menuBody.Id)
                    {
                        <button type="button" class="btn btn-sm btn-outline-warning" title="Drop this body as the destination — the autopilot stops steering to it"
                                @onclick="() => SetDestination(null)">
                            ✕ Clear destination
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-info"
                                title="@(HarborClassOf(menuBody.Id) == HarborClass.Dock ? "Make this haven the destination — the autopilot flies you in to its dock" : "Make this body the destination — the autopilot navigates to its orbit")"
                                @onclick="() => SetDestination(menuBody.Id)">
                            🎯 Set destination — @(HarborClassOf(menuBody.Id) == HarborClass.Dock ? "navigate to dock" : "navigate to orbit")
                        </button>
                    }
                    <button type="button" class="btn btn-sm @(!NavLockedByDock && _armedOrbitBodyId == menuBody.Id ? "btn-success" : "btn-outline-info")"
                            disabled="@NavLockedByDock" title="@(NavLockedByDock ? DockNavLockTip : ArmMenuHint(menuBody.Id))"
                            @onclick="() => ToggleArmedInsertionFromMenu(menuBody.Id)">
                        @(_armedOrbitBodyId == menuBody.Id
                            ? "🛰 Armed — click to disarm"
                            : HarborClassOf(menuBody.Id) == HarborClass.Dock
                                ? HarborVocabulary.ArmAction(HarborClass.Dock, menuBody.Name)
                                : "🛰 Arm auto-insert at window")
                    </button>
                    @* #246/#249 🚀 LONG HAUL — the PRIMARY entry (owner: "autopilot into vicinity from clicking
                       the target"). When the clicked body sits across the void, the menu recognizes the long-
                       haul distance and offers it as a third action that SETS the destination AND engages in
                       one press — no card-hunting. Visible-but-disabled with the reason (#212), even docked
                       (the undock is part of engaging). *@
                    @if (LongHaulTargetPlanet(menuBody.Id) is { } lhMenuPlanet)
                    {
                        LongHaul.Departure lhMenuDep = LongHaul.SolveDeparture(_ship, _ephemeris!, lhMenuPlanet);
                        string? lhMenuBlock = LongHaulOfferBlock(lhMenuDep, lhMenuPlanet, LongHaulClearanceBlock(lhMenuDep, lhMenuPlanet));
                        <button type="button" class="btn btn-sm @(lhMenuBlock is null ? "btn-warning" : "btn-outline-secondary")"
                                disabled="@(lhMenuBlock is not null)"
                                title="@(lhMenuBlock ?? $"Set {menuBody.Name} as destination and autopilot the whole void in one jump — wake at {lhMenuPlanet.Name}'s capture range; the last mile stays premium")"
                                @onclick="() => EngageLongHaulFromMenu(menuBody.Id)">
                            @(lhMenuDep.Ok
                                ? LongHaul.MenuAction(lhMenuPlanet.Name, lhMenuDep.DeparturePulses, FormatSimTime(lhMenuDep.ArrivalCenterTime))
                                : $"🚀 Long haul to {lhMenuPlanet.Name} — no window from here")
                        </button>
                    }
                    @* #290 🪂 AEROBRAKE — the third way to pay the arrival bill (beside the propulsive insert
                       and the warn-and-coast). Shown only for skim-atmosphere worlds (Uranus first; the
                       giants, Earth, Mars — never Titan/Venus). Quotes the honest trade, or is visible-but-
                       disabled with the reason (#212). The quote is priced once on menu-open (it flies drag). *@
                    @if (AerobrakeMenuQuote(menuBody) is { } abQuote)
                    {
                        bool abArmed = _aerobrakeArmedBodyId == menuBody.Id;
                        <button type="button" class="btn btn-sm @(abArmed ? "btn-success" : abQuote.Offered ? "btn-warning" : "btn-outline-secondary")"
                                disabled="@(!abQuote.Offered && !abArmed)"
                                title="@Aerobrake.Trade(menuBody.Name, abQuote)"
                                @onclick="() => EngageAerobrakeFromMenu(menuBody.Id)">
                            @(abArmed ? $"🪂 Aerobrake armed at {menuBody.Name} — click to disarm" : Aerobrake.MenuAction(menuBody.Name, abQuote))
                        </button>
                    }
                }
                else
                {
                    double vicinity = Math.Max(1.2e10, 8 * menuBody.BodyRadius);
                    Vector2d bodyPosition = _ephemeris!.Position(menuBody.Id, SimTime);
                    string bodyScanLabel = $"scan around {menuBody.Name}";
                    <div class="text-secondary">@ScanCostText(bodyPosition, vicinity)</div>
                    <button type="button" class="btn btn-sm btn-info" title="Sweep the telescope around this body — approaches and local space"
                            @onclick="() => ScanAreaFromMenu(bodyPosition, vicinity, bodyScanLabel)">
                        🔭 Scan around @menuBody.Name — approaches &amp; local space
                    </button>
                }
            </div>
        </div>
    }

    @* M29: the contact menu — clicking a ship selects it for the scope AND offers the real
       actions: telescope tracking and the war-room interest (intercept clock, firing solutions). *@
    @if (_activeDesk is ShipDesk.Nav or ShipDesk.Sensors or ShipDesk.WarRoom && _shipMenuId is { } menuShipId && FindNpc(menuShipId) is { } menuNpc)
    {
        @* #253: a vitals line plus up to three actions (interest · track · scan). *@
        var shipAt = ClampMenu(_shipMenuX, _shipMenuY, 4);
        <div class="map-body-menu bg-dark bg-opacity-75 rounded p-2 text-light small shadow"
             style="left: @(shipAt.X.ToString("F0", CultureInfo.InvariantCulture))px; top: @(shipAt.Y.ToString("F0", CultureInfo.InvariantCulture))px">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-bold me-2">@menuNpc.Ship.Callsign</span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close" title="Close this contact's menu"
                        @onclick="CloseShipMenu"></button>
            </div>
            @if (menuNpc.CurrentlyObserved)
            {
                <div class="text-secondary mb-1">
                    @FormatDistance((menuNpc.State.Position - _ship.Position).Length) ·
                    rel @(((menuNpc.State.Velocity - _ship.Velocity).Length / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s ·
                    @* #210: the SIGNED range-rate — are we closing or opening — same voice as the dossier card. *@
                    @RelativeMotion.WordedBefore(RelativeMotion.ClosingSpeed(_ship.Position, _ship.Velocity, menuNpc.State.Position, menuNpc.State.Velocity)) ·
                    scope tracking her now
                </div>
            }
            else
            {
                @* PR-C, the Barnacle case: a labeled contact with no live fix is never mute. *@
                <div class="text-warning mb-1">
                    no live fix — last seen @(((SimTime - menuNpc.LastObservation!.Value.SimTime) / 86400.0).ToString("F1", CultureInfo.InvariantCulture))d ago
                </div>
            }
            <div class="d-grid gap-1">
                @if (menuNpc.CurrentlyObserved)
                {
                    <button type="button" class="btn btn-sm btn-info" title="Mark her a target of interest — intercept clock and firing solutions"
                            @onclick="() => InterestFromMenu(menuShipId)">
                        🎯 Target of interest — intercept clock &amp; firing solutions
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-info" title="Put the telescope on her — sharpen the fix"
                            @onclick="() => TrackShipFromMenu(menuShipId)">
                        📡 Track with telescope — sharpen the intel
                    </button>
                }
                @if (_activeDesk == ShipDesk.Sensors)
                {
                    Vector2d scanCenter = menuNpc.CurrentlyObserved
                        ? menuNpc.State.Position
                        : menuNpc.LastObservation!.Value.Position;
                    string shipScanLabel = $"scan near {menuNpc.Ship.Callsign}";
                    <button type="button" class="btn btn-sm btn-outline-info" title="Sweep the telescope around here to find her"
                            @onclick="() => ScanAreaFromMenu(scanCenter, 8e9, shipScanLabel)">
                        🔭 Scan around here@(menuNpc.CurrentlyObserved ? "" : " — find out where she went")
                    </button>
                }
            </div>
        </div>
    }

    @* PR-C: the trade-lane menu — the corridor the owner drew by hand, now a clickable region.
       Replaces the tracking post's "— manual aim —" dropdown: the lane IS the control. *@
    @if (_activeDesk == ShipDesk.Sensors && _corridorMenuLane is { } menuLane)
    {
        @* #253: a sweep-cost line plus the two sweep actions. *@
        var corridorAt = ClampMenu(_corridorMenuX, _corridorMenuY, 3);
        <div class="map-body-menu bg-dark bg-opacity-75 rounded p-2 text-light small shadow"
             style="left: @(corridorAt.X.ToString("F0", CultureInfo.InvariantCulture))px; top: @(corridorAt.Y.ToString("F0", CultureInfo.InvariantCulture))px">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-bold me-2">📦 @menuLane.Name</span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close" title="Close this lane's menu"
                        @onclick="CloseCorridorMenu"></button>
            </div>
            <div class="text-secondary mb-1">
                @{ ScanJob laneJob = TradeCorridors.SweepJobFor(menuLane, _ship.Position); }
                sweep arc @((int)(laneJob.ArcWidthRad * 180 / Math.PI))° from here ·
                @SweepCostText(laneJob)
            </div>
            <div class="d-grid gap-1">
                <button type="button" class="btn btn-sm btn-info" title="Sweep this trade lane once, right now"
                        @onclick="() => SweepCorridorFromMenu(menuLane, standing: false)">
                    📡 Sweep this lane now
                </button>
                <button type="button" class="btn btn-sm btn-outline-info" title="Keep re-sweeping this lane every carousel round"
                        @onclick="() => SweepCorridorFromMenu(menuLane, standing: true)">
                    🔁 Standing lane watch — re-sweep every carousel round
                </button>
            </div>
        </div>
    }

    @* PR-C: the open-sky menu — even empty space answers. What a scan here would take, and the
       guideline hint when the spot sits near a known lane. *@
    @if (_activeDesk == ShipDesk.Sensors && _skyMenuWorld is { } skyPoint)
    {
        @* #253: a scan-cost line plus the scan action (and, near a lane, a sweep). *@
        var skyAt = ClampMenu(_skyMenuX, _skyMenuY, 4);
        <div class="map-body-menu bg-dark bg-opacity-75 rounded p-2 text-light small shadow"
             style="left: @(skyAt.X.ToString("F0", CultureInfo.InvariantCulture))px; top: @(skyAt.Y.ToString("F0", CultureInfo.InvariantCulture))px">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-bold me-2">✨ Open sky</span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close" title="Close this patch's menu"
                        @onclick="CloseSkyMenu"></button>
            </div>
            <div class="text-secondary mb-1">
                @FormatDistance((skyPoint - _ship.Position).Length) out ·
                patch radius @FormatDistance(_skyMenuRadius) · @ScanCostText(skyPoint, _skyMenuRadius)
            </div>
            <div class="d-grid gap-1">
                <button type="button" class="btn btn-sm btn-info" title="Point the telescope at this patch — it always resolves something"
                        @onclick="() => ScanAreaFromMenu(skyPoint, _skyMenuRadius, SkyScanLabel(skyPoint))">
                    🔭 Scan this area — the telescope always resolves <em>something</em>
                </button>
                @if (NearLaneFor(skyPoint) is { } nearLane)
                {
                    <div class="text-info">near the @nearLane.Name</div>
                    <button type="button" class="btn btn-sm btn-outline-info" title="Sweep the nearby trade lane instead"
                            @onclick="() => SweepCorridorFromMenu(nearLane, standing: false)">
                        📡 Sweep the @nearLane.PairName lane instead
                    </button>
                }
            </div>
        </div>
    }

    @* #195 (owner ruling: the NOW/NEXT banner covered the toolbar's 'checklist' and '?' buttons):
       the desk tabs, the pilot banner and the ship-alert strip live in ONE in-FLOW column now (was three
       independently top-anchored absolute layers whose fixed `top`s assumed a one-row banner). Because
       they claim real document-flow height, and the Nav toolbar/readout HUD (.map-hud) below is in flow
       too, a 2–3 row banner PUSHES the toolbar down instead of floating over it — a status surface can
       never again hide a control (#123). *@
    <div class="map-topstack">

    @* Station tab bar (StationDesks.md rule 3): always visible, top center, works on every desk —
       the keyboard-shortcut equivalent for players who'd rather click. Captain (PR-15) leads the
       bar with its `0` key, ahead of Nav's `1` — the captain's word comes before the helm's. *@
    <div class="desk-tab-bar bg-dark bg-opacity-75 rounded p-1">
        @foreach (ShipDesk desk in TabBarOrder)
        {
            <button type="button" class="btn btn-sm desk-tab @(_activeDesk == desk ? "btn-info" : "btn-outline-light")"
                    title="Switch to the @DeskLabel(desk) desk"
                    @onclick="() => SwitchDesk(desk)">
                @DeskKeyLabel(desk) @DeskLabel(desk)
            </button>
        }
        @* Owner request: temporarily clear every panel to read the map, and back. Toggles the
           .map-peek class (CSS fades the overlays, click passes through to the canvas). Hotkey ` . *@
        <button type="button" class="btn btn-sm desk-tab @(_peekMap ? "btn-warning" : "btn-outline-light")"
                title="Peek at the map — hide the panels (` toggles)" @onclick="TogglePeekMap">
            @(_peekMap ? "👁 Show panels" : "👁 Peek")
        </button>
    </div>

    @* #127 (owner ruling: "WHO IS FLYING THE SHIP must be big and unmissable" — he watched the
       autopilot fly him into Saturn thinking he had the stick). One persistent banner at the top of
       the flight view, on every desk. Derived from the same source NavChip reads (_armedOrbitBodyId):
       armed auto-orbit = the autopilot is in command and will fly the approach + insertion itself;
       anything else = the helm answers to you. Click jumps to Nav, where the disarm control lives. *@
    @if (_worldReady && !_deckMode)
    {
        string? _armed = _armedOrbitBodyId;
        bool _autopilot = _armed is not null;
        @* #159/#184: the banner speaks the whole plan. FlightNowNext() is the ONE source (the Nav
           header and desk chips read it too), returning an ordered row list: the pinned NOW row, then
           the queue — each pending burn, then the orbit-insert as its OWN plain-language row (#171/#173,
           no more "step 1/1" crash-or-orbit doubt). The ▲▼ arrows page the queue when it runs past NEXT;
           the NOW row is always the active step, so the list auto-scrolls to what the ship is doing. *@
        FlightPlanStatus _banner = FlightNowNext();
        IReadOnlyList<FlightPlanRow> _rows = _banner.Rows;
        int _queueCount = Math.Max(0, _rows.Count - 1);
        int _rowOffset = _queueCount == 0 ? 0 : Math.Clamp(_bannerRowOffset, 0, _queueCount - 1);
        @* NOW text: the row list, except a #155 dock-ready SUCCESS still speaks its own line while manual. *@
        string _nowText = _rows.Count > 0 ? _rows[0].Text : "NOW: coasting";
        if (!_autopilot && !AutopilotStoodDown && _dockReadyStatus is not null && _nowText == "NOW: coasting")
        {
            _nowText = _dockReadyStatus;
        }
        <div class="pilot-banner @(_autopilot ? "pilot-banner-auto" : "pilot-banner-manual")"
             role="button" tabindex="0"
             title="@(_autopilot ? "The autopilot is flying the ship — click to go to Nav and take back the stick" : "You are flying the ship by hand")"
             @onclick="() => SwitchDesk(ShipDesk.Nav)">
            <span class="pilot-banner-who">@(_autopilot ? "🛰 AUTOPILOT HAS THE SHIP" : "🧭 YOU HAVE THE SHIP")</span>
            <div class="pilot-banner-rows">
                <div class="pilot-banner-mode pilot-banner-now">@_nowText</div>
                @if (_queueCount > 0)
                {
                    <div class="pilot-banner-queue">
                        <span class="pilot-banner-mode pilot-banner-next">@_rows[1 + _rowOffset].Text</span>
                        @if (_queueCount > 1)
                        {
                            <span class="pilot-banner-pager">
                                <button type="button" class="pilot-banner-arrow" title="Earlier step"
                                        disabled="@(_rowOffset == 0)"
                                        @onclick="BannerPageUp" @onclick:stopPropagation="true">▲</button>
                                <span class="pilot-banner-pageno">@(_rowOffset + 1)/@_queueCount</span>
                                <button type="button" class="pilot-banner-arrow" title="Later step"
                                        disabled="@(_rowOffset >= _queueCount - 1)"
                                        @onclick="BannerPageDown" @onclick:stopPropagation="true">▼</button>
                            </span>
                        }
                    </div>
                }
            </div>
        </div>

        @* #166: the ship-wide alert strip — collision, fuel, orbit-decay, one voice. Unacknowledged
           alerts shout (red/amber, ✕ to silence); an acknowledged alert lingers dimmed while its
           condition holds. Reads the same ShipAlerts channel the parrot and the ledger read. *@
        if (_shipAlerts.Any)
        {
            <div class="ship-alert-strip">
                @foreach (ShipAlert _alert in _shipAlerts.Active)
                {
                    <div class="ship-alert @(_alert.Severity == AlertSeverity.Red ? "ship-alert-red" : "ship-alert-amber") @(_alert.Acknowledged ? "ship-alert-ack" : null)">
                        <span class="ship-alert-msg">@_alert.Message</span>
                        @* #205: an ACTIONABLE alert (a boarding window) carries its subject — the approve/
                           stand-down chips are reachable HERE, on every desk, even when the alert is dimmed.
                           These are the second door the owner couldn't find on the war-room/captain desks. *@
                        @if (_alert.ActionTargetId is not null)
                        {
                            <button type="button" class="btn btn-sm btn-danger py-0 ship-alert-action"
                                    title="Send the shuttles across and board her — this is piracy" @onclick="AuthorizePlunder">🏴 Board her</button>
                            <button type="button" class="btn btn-sm btn-outline-light py-0 ship-alert-action"
                                    title="Stand the shuttles down — leave her be" @onclick="DeclinePlunder">Stand down</button>
                        }
                        @if (!_alert.Acknowledged)
                        {
                            <button type="button" class="ship-alert-silence" title="Silence this alert (it stays until the condition clears)"
                                    @onclick="() => AcknowledgeAlert(_alert.Kind)">✕</button>
                        }
                    </div>
                }
            </div>
        }
    }
    </div>@* /.map-topstack — tabs · banner · alert strip; the Nav HUD (.map-hud) flows below it *@

    @if (_activeDesk == ShipDesk.Nav)
    {
    <div class="map-hud">
        <div class="btn-toolbar bg-dark bg-opacity-75 rounded p-2 gap-2 align-items-center" role="toolbar" aria-label="Time warp controls">
            <div class="d-flex align-items-center gap-1 me-2 map-warp-control">
                <span class="text-light small">warp</span>
                <input type="range" class="form-range" min="0" max="100" step="1"
                       value="@WarpSliderValue" title="Time warp (log scale)"
                       @oninput="OnWarpSliderInput" @onkeydown:stopPropagation="true" />
                <span class="text-light small text-nowrap map-warp-readout">@WarpReadout</span>
            </div>
            @* #172 — ⏭ skip to next event, beside the warp slider (#236: a button, in the toolbar band).
               Jumps time forward to the next burn/arrival; anything important still pulls you back to 1×.
               Disabled when nothing is armed (no next event to skip to). Becomes ■ stop skip while running. *@
            <button type="button" class="btn btn-sm @(_skipActive ? "btn-warning" : "btn-outline-info") me-2"
                    title="Jump time forward to the next burn/arrival — anything important (a burn, an arrival, an alert) still pulls you back to 1×"
                    disabled="@(!_skipActive && !_skipNext.Found)" @onclick="ToggleSkip">
                @(_skipActive ? "■ stop skip" : "⏭ next event")
            </button>
            @* The long-coast advert: on a >1-day dead coast the ship OFFERS the cheap ride. A button, so
               it lives in the toolbar band, never the banner. The coast is free — the skip spends only time. *@
            @if (ShowLongCoastAdvert)
            {
                <button type="button" class="btn btn-sm btn-outline-warning me-2"
                        title="The coast costs nothing — the skip spends only time. Jump to the next event."
                        @onclick="StartSkip">
                    ⏭ Long coast ahead (@LongCoastDays d) — skip it
                </button>
            }
            @* #246/#249 🚀 the long haul as a toolbar chip — a SECONDARY surface (the map context menu is
               the primary entry) mirroring the offer while a long destination is set. Placement per #236,
               beside the ⏭ advert. Visible-but-disabled with the reason (#212). *@
            @if (LongHaulTargetPlanet(_destinationBodyId) is { } lhChipPlanet && _longHaulDeparture is { Ok: true } lhChipDep)
            {
                string? lhChipBlock = LongHaulOfferBlock(_longHaulDeparture, lhChipPlanet, _longHaulClearanceBlock);
                <button type="button" class="btn btn-sm @(lhChipBlock is null ? "btn-warning" : "btn-outline-secondary") me-2"
                        disabled="@(lhChipBlock is not null)"
                        title="@(lhChipBlock ?? $"Autopilot the whole void to {lhChipPlanet.Name} vicinity in one jump — wake at the capture gate; the last mile stays premium")"
                        @onclick="EngageLongHaul">
                    🚀 Long haul (@lhChipDep.DeparturePulses p)
                </button>
            }
            <button type="button" class="btn btn-sm @(Paused ? "btn-warning" : "btn-outline-light") me-2" title="Pause or resume the flow of sim time" @onclick="TogglePause">
                @(Paused ? "Resume" : "Pause")
            </button>
            <button type="button" class="btn btn-sm @(FollowShip ? "btn-info" : "btn-outline-light") me-2" title="Keep the camera locked on the ship as she flies" @onclick="ToggleFollow">
                Follow Ship
            </button>
            @* #237 — clickable zoom: not every captain has a mouse wheel (and automation drives one
               poorly). One real step per press, zooming toward the viewport centre. *@
            <button type="button" class="btn btn-sm btn-outline-light" title="Zoom the map in one step — no mouse wheel needed" @onclick="() => ZoomStep(zoomIn: true)">
                🔍+
            </button>
            <button type="button" class="btn btn-sm btn-outline-light me-2" title="Zoom the map out one step — no mouse wheel needed" @onclick="() => ZoomStep(zoomIn: false)">
                🔍−
            </button>
            <button type="button" class="btn btn-sm @(PlotMode ? "btn-success" : "btn-outline-light") me-2" title="Switch between flying live and plotting a course on the map" @onclick="TogglePlotMode">
                @(PlotMode ? "Play" : "Plot")
            </button>
            @* Berth at a grey-market dock (a station haven) — clamps on, no steering, the heat bleeds
               off. #212: the button reads the ONE dock truth (_dockAffordance), the nearest DOCKABLE
               haven passing DockRule — never the raw nearest body — so it can never disagree with the
               envelope line. #211: latched so it doesn't blink as the drift phases. #213: when in range
               but too hot it becomes ⚓ Match & clamp, quoting the terminal-match burn (visible paused). *@
            @if (_dockedHavenId is not null)
            {
                <button type="button" class="btn btn-sm btn-warning me-2" @onclick="Undock"
                        title="Release the dock clamps and fly off">🚀 Undock</button>
            }
            else if (_dockAffordance.CanClampNow)
            {
                <button type="button" class="btn btn-sm btn-outline-info me-2" @onclick="ToggleDock"
                        title="Clamp onto the dock and lie low — the heat bleeds off while you're berthed">⚓ Dock</button>
            }
            else if (_dockAffordance.NeedsMatch)
            {
                @* Alongside but coasting too hot to clamp — one press flies the terminal match (the same
                   burn the armed autopilot flies), then leaves the plain ⚓ Dock. *@
                <button type="button" class="btn btn-sm btn-info me-2" @onclick="MatchAndClamp"
                        title="@($"Fly the terminal match — nulls the {(_dockAffordance.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)} km/s drift into the clamp window, then hit ⚓ Dock")">
                    ⚓ Match &amp; clamp — ≈@(_dockAffordance.MatchPulses) p
                </button>
            }
            else if (_dockAffordance.Phase == DockPhase.TooHot)
            {
                @* In range but the match is unaffordable — refuse with the numbers, greyed so it teaches. *@
                <button type="button" class="btn btn-sm btn-outline-secondary me-2" disabled
                        title="@($"Too hot to clamp — the terminal match needs ≈{_dockAffordance.MatchPulses} p, only {_reactionMassPulses} aboard")">
                    ⚓ Match &amp; clamp — needs ≈@(_dockAffordance.MatchPulses) p
                </button>
            }
            <button type="button" class="btn btn-sm @(_showScope ? "btn-info" : "btn-outline-light") ms-2" title="Open or close the telescope scope window" @onclick="ToggleScope">
                Scope
            </button>
            <a class="btn btn-sm btn-outline-secondary" href="/guide" target="_blank" title="Captain's Guide">?</a>
            @* #292: the nav screen is not a billboard. The checklist toggle is a minimal pointer that
               appears ONLY while a lesson is actually in hand (or its card is open) — no persistent
               tutorial chrome for a veteran. Starting or replaying a lesson lives at the Captain's desk
               (0) → Tutorials, the quieter room where the picker already moved. *@
            @if (ActiveTutorialIndex() >= 0 || _showTutorial)
            {
                <a class="btn btn-sm @(_showTutorial ? "btn-info" : "btn-outline-light")" role="button" @onclick="ToggleTutorial" title="Show/hide the current lesson's checklist — pick or replay lessons at the Captain's desk (0) → Tutorials">
                    🏴 checklist
                </a>
            }
            @* SATURDAY-ANCHOR: toolbar — parallel lanes append one button line each below *@
        </div>

        <div class="map-readouts bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
            <div class="mb-1">
                <span class="fw-bold">@_scenarioName</span>
                @if (_plasma is not null)
                {
                    <span class="badge bg-info text-dark ms-1">EU ⚡</span>
                }
            </div>
            <div>Sim time: @FormatSimTime(SimTime)</div>
            @if (_skipActive)
            {
                @* #172: while skipping, the roomy line states the whole thing — where we're headed and the ETA. *@
                <div class="text-info">⏭ skipping to @_skipTargetLabel — ETA @FormatDuration(Math.Max(0, _skipTargetEpoch - SimTime)) @(_effectiveWarp < Warp ? $"(held at {_effectiveWarp}× near a body)" : $"({_effectiveWarp}×)")</div>
            }
            else
            {
                <div>Warp: @(Paused ? "paused" : $"{_effectiveWarp}×") @(Warp != _effectiveWarp ? $"(auto-drop from {Warp}×)" : "")</div>
            }
            <div>Zoom: @FormatZoom(_camera.MetersPerPixel)</div>
            <hr />
            <div>
                Ship speed: @(((_ship.Velocity.Length) / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s
                <span class="text-secondary">(circular here: @((CircularSpeedHere / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s)</span>
            </div>
            <div>Mass pulses: @_reactionMassPulses / @ReactionMassCapacity</div>
            <div>Credits: @_credits.ToString("N0", CultureInfo.InvariantCulture)</div>
            <div>Cargo: @_cargoUnits / @CargoCapacity units@(_cargoValue > 0 ? $" (worth {_cargoValue:N0} cr)" : "")</div>
            @if (OrbitInfo() is { } oi)
            {
                <div class="mt-1 small">
                    @* #175: this body is a cargo run's destination — say the delivery next action right
                       in the nav-target box so the parcel's last step is never invisible. *@
                    @if (ActiveCargoRunTo(oi.Body.Id) is not null)
                    {
                        <div class="map-cargo-deliver">📦 @CargoNextAction(oi.Body)</div>
                    }
                    @if (IsDockableHaven(oi.Body))
                    {
                        @* A mass-less haven has no Hill sphere — you clamp its ⚓ dock, you don't orbit.
                           Same panel slot, dock language, so the capture-range math never lies here. *@
                        <div class="d-flex justify-content-between align-items-center">
                            <span>⚓ Dock at @oi.Body.Name — @DockStatusLine(oi)</span>
                        </div>
                        @if (oi.IsDestination)
                        {
                            <div class="text-secondary">
                                @FormatDistance(oi.Distance) out · clamp within @((DockReachMeters / 1000).ToString("N0", CultureInfo.InvariantCulture)) km ·
                                rel @((oi.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s
                                (match ≤ @((DockMatchSpeedMps / 1000).ToString("N0", CultureInfo.InvariantCulture)))
                                @if (DestinationEta() is { } eta)
                                {
                                    <text> · @eta</text>
                                }
                                <a role="button" class="text-info text-decoration-none ms-1" title="Drop this destination — stop tracking it"
                                   @onclick="() => SetDestination(null)">clear</a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                @(oi.IsDestination ? "🎯" : "🛰") Orbit @oi.Body.Name — @OrbitStatusLine(oi)
                            </span>
                            @if (oi.WindowOpen && oi.RadiusInStableBand)
                            {
                                <button type="button" class="btn btn-sm py-0 @(oi.CanEngage && !NavLockedByDock ? "btn-success" : "btn-outline-secondary")"
                                        disabled="@(!oi.CanEngage || NavLockedByDock)"
                                        title="@(NavLockedByDock ? DockNavLockTip : "Circularize into orbit now — the autopilot holds the park")" @onclick="EnterOrbit">
                                    Enter orbit (@oi.Cost p / O)
                                </button>
                            }
                            else if (oi.WindowOpen)
                            {
                                @* #180 moon-grade orbit: this radius is in the tide-chaotic band (Lab 16 — the
                                   owner's ≈0.53-Hill Enceladus park that silently stripped). NEVER circularize
                                   here silently; the button hands the descent to the autopilot, which parks at
                                   the tide-stable radius. The O-key (EnterOrbit) follows the same logic. *@
                                <button type="button" class="btn btn-sm py-0 @(!NavLockedByDock ? "btn-info" : "btn-outline-secondary")"
                                        disabled="@NavLockedByDock"
                                        title="@(NavLockedByDock ? DockNavLockTip : $"this radius is tide-chaotic (Lab 16) — the autopilot descends to the stable park at {FormatDistance(OrbitRule.ParkingRadius(oi.Body, oi.Hill))}")"
                                        @onclick="EnterOrbit">
                                    🛰 Autopilot to stable park (≈@oi.ApproachCost p)
                                </button>
                            }
                            else if (oi.Bound)
                            {
                                @* #176: already in orbit — the button isn't "off", there's just nothing to arm.
                                   Say so instead of a mute grey "Auto-orbit" that reads like a dead control. *@
                                <button type="button" class="btn btn-sm py-0 btn-outline-success" disabled
                                        title="already orbiting — burn prograde to leave, or ⚓ Dock if it's a haven">
                                    In orbit ✓
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm py-0 @(!NavLockedByDock && oi.Armed ? "btn-success" : !NavLockedByDock && oi.InCaptureRange ? "btn-info" : "btn-outline-secondary")"
                                        disabled="@((!oi.InCaptureRange && !oi.Armed) || NavLockedByDock)"
                                        title="@(NavLockedByDock ? DockNavLockTip : "Arm the autopilot to capture into orbit when she's in range")" @onclick="EnterOrbit">
                                    @(oi.Armed
                                        ? (_disarmConfirmBodyId == oi.Body.Id
                                            ? "Disarm? click again"
                                            : oi.InCaptureRange ? "Autopilot ON — flying" : "Autopilot ON — disarm")
                                        : $"Auto-orbit (≈{oi.ApproachCost} p / O)")
                                </button>
                            }
                        </div>
                        <div class="progress map-orbit-bar" title="distance vs capture range">
                            <div class="progress-bar @(oi.InCaptureRange ? "bg-success" : "bg-info")"
                                 style="width: @(Math.Clamp(100 * oi.CaptureRange / Math.Max(oi.Distance, 1), 2, 100).ToString("F0", CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <div class="progress map-orbit-bar" title="relative speed vs 5 km/s limit">
                            <div class="progress-bar @(oi.RelSpeed < OrbitRule.MaxRelativeSpeed ? "bg-success" : "bg-danger")"
                                 style="width: @(Math.Clamp(100 * OrbitRule.MaxRelativeSpeed / Math.Max(oi.RelSpeed, 1), 2, 100).ToString("F0", CultureInfo.InvariantCulture))%"></div>
                        </div>
                        @if (oi.IsDestination)
                        {
                            <div class="text-secondary">
                                @FormatDistance(oi.Distance) out · capture ≤ @FormatDistance(oi.CaptureRange) ·
                                rel @((oi.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s
                                (max @((OrbitRule.MaxRelativeSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)))
                                @if (DestinationEta() is { } eta)
                                {
                                    <text> · @eta</text>
                                }
                                <a role="button" class="text-info text-decoration-none ms-1" title="Drop this destination — stop tracking it"
                                   @onclick="() => SetDestination(null)">clear</a>
                            </div>
                        }
                    }
                </div>
            }
            <div>
                Nearest: @_nearestBody?.Name (@FormatDistance((_ship.Position - _nearestBodyPosition).Length), @(((_ship.Velocity - _nearestBodyVelocity).Length / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s rel)@if (_nearestBody is { } nb && IsDockableHaven(nb) && _dockedHavenId is null)
                {
                    <span class="text-info"> · ⚓ dockable haven — coast within @((DockReachMeters / 1000).ToString("N0", CultureInfo.InvariantCulture)) km, ≤@((DockMatchSpeedMps / 1000).ToString("N0", CultureInfo.InvariantCulture)) km/s to clamp on</span>
                }
            </div>
            @if (_activeRadar)
            {
                <div class="text-danger">📡 ACTIVE RADAR — loud; everyone in earshot knows where we are</div>
            }
            @if (_plasma is not null)
            {
                int chargePct = (int)Math.Round(_ship.Charge * 100);
                string chargeClass = _ship.Charge >= ArcChargeThreshold ? "bg-danger"
                    : _ship.Charge >= 0.6 ? "bg-warning" : "bg-info";
                <hr />
                <div>Charge: @chargePct% @(_ship.Charge >= ArcChargeThreshold ? "— ARCING RISK" : "")</div>
                <div class="progress" role="progressbar" aria-label="Hull charge">
                    <div class="progress-bar @chargeClass" style="width: @chargePct%"></div>
                </div>
                @if (_ship.Charge >= ArcChargeThreshold)
                {
                    <div class="text-danger fw-bold">⚡ ARCING — visible system-wide</div>
                }
            }
            @if (_pulseMessage is not null)
            {
                <div class="text-warning">@_pulseMessage</div>
            }
            @if (_captureEngaged)
            {
                <hr />
                <div class="fw-bold text-success">🚀 SHUTTLES AWAY — boarding @_captureTargetCallsign</div>
                <div class="progress my-1" role="progressbar" aria-label="Boarding progress" style="height: 1.1rem;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                         style="width: @(((int)(_captureProgress * 100)))%">@((int)(_captureProgress * 100))%</div>
                </div>
                @* Owner ("let's make it more clear"): the autosteal crawls because boarding runs on
                   WALL-CLOCK, not sim time — cranking warp does nothing. Say the ETA, say warp won't
                   help, and say how to hurry it (a tighter, slower match cuts RequiredSecondsFor). *@
                <div class="small">
                    ≈ @(Math.Max(0, (1 - _captureProgress) * _captureRequiredSeconds).ToString("F0", CultureInfo.InvariantCulture)) s left ·
                    <span class="text-warning">real-time — warp won't hurry it</span>
                    <span class="text-secondary">· hold the match; closer &amp; slower boards faster</span>
                </div>
                @* #202: show what is being taken AS it transfers — no more forensic accounting. The
                   take is the hull's cargo capped by our free hold; priced through the same fence market
                   the loot line and the credited value read. *@
                @if (SelectedCaptureTarget() is { } prey && prey.Ship.CargoUnits > 0)
                {
                    int hold = CargoCapacity - _cargoUnits;
                    int take = Math.Max(0, Math.Min(prey.Ship.CargoUnits, hold));
                    <div class="small text-warning">
                        📦 Prising loose @take units of @prey.Ship.CargoClass — est.
                        @((take * CargoMarket.UnitValue(prey.Ship.CargoClass)).ToString("N0", CultureInfo.InvariantCulture)) cr
                        @(take < prey.Ship.CargoUnits ? "(hold's filling — the rest stays with her)" : "")
                    </div>
                }
            }
            @* #177/#178 — a boardable hull is in range, but piracy is never automatic. Offer it;
               the shuttles do not move until the captain says so. Standing down is free and silent. *@
            @if (_plunderOpportunityTargetId is not null)
            {
                <hr />
                <div class="fw-bold text-warning">🏴 PLUNDER OPPORTUNITY — @_captureTargetCallsign in boarding range</div>
                <div class="small text-secondary mb-1">
                    Boarding @_captureTargetCallsign is PIRACY — you'll take their cargo and carry the heat.
                    Hostile acts need the captain's word.
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-danger" title="Send the shuttles across and board her — this is piracy" @onclick="AuthorizePlunder">🏴 Board her — commit piracy</button>
                    <button type="button" class="btn btn-sm btn-outline-light" title="Stand the shuttles down — leave her be" @onclick="DeclinePlunder">Stand down</button>
                </div>
            }
        </div>

        @* #135/#143 — reference-frame selector. Near a gas giant a moon-to-moon course is useless in
           the solar frame: the primary's ~10 km/s solar orbit drowns the interesting motion. Pick the
           body every time-parameterized draw is expressed co-moving with. Default Sun (inertial); inside
           a giant's Hill sphere that giant is suggested (✦) but never auto-selected — the owner asked for
           a CHOICE. The v-readout is quoted in, and labelled with, the chosen frame. #143: this ONE
           selection governs BOTH the Play-view ribbon/scrub path and the Plot curves, so the chip lives
           OUTSIDE the Plot panel and is visible in both views — the ruler is never silent. *@
        <div class="map-frame bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
            <div class="map-plot-frame d-flex flex-wrap align-items-center gap-1">
                <span class="text-secondary">frame:</span>
                @foreach (FrameOption opt in FrameOptions())
                {
                    bool active = opt.Id == _plotFrameBodyId;
                    <button type="button"
                            class="btn btn-sm py-0 @(active ? "btn-info" : opt.Suggested ? "btn-outline-warning" : "btn-outline-light")"
                            title="@opt.Title"
                            @onclick="() => SetPlotFrame(opt.Id)">@opt.Label@(opt.Suggested && !active ? " ✦" : "")</button>
                }
                @* #206 — the compact chips above are contextual (Sun · local giant · target); this overflow
                   makes EVERY body pickable as origin from anywhere (owner: "All planets and moons need it"),
                   grouped by parent. The pick gives it an active chip; #144's law holds (one frame rules map
                   + plotting ribbon + readouts). *@
                <select class="form-select form-select-sm py-0 map-frame-picker"
                        value="@(_plotFrameBodyId ?? "")" @onchange="OnFramePicked"
                        title="Pick ANY planet, moon, or station as the map/plot origin — the choice rules both views (#206)">
                    @* value="" (Sun / inertial) shows this placeholder; an exotic frame shows its own name,
                       so the picker always reads the live origin and pairs with its chip. *@
                    <option value="">frame… ▾</option>
                    @foreach ((string groupLabel, List<CelestialBody> members) in FramePickerGroups())
                    {
                        <optgroup label="@groupLabel">
                            @foreach (CelestialBody b in members)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </optgroup>
                    }
                </select>
                <span class="text-secondary ms-1" title="Ship speed in the selected frame">@FrameSpeedReadout()</span>
            </div>
        </div>

        @if (PlotMode)
        {
            <div class="map-plot bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
                <div class="fw-bold mb-1">Plotting</div>
                <div class="mb-1">Scrub: @FormatSimTime(ScrubTime)</div>
                @* stopPropagation: arrow keys must adjust the control, not fire live ship pulses. *@
                <input type="range" class="form-range" min="0" max="@CurrentPlotHorizonSeconds" step="3600"
                       title="Scrub the plot clock forward and back along the course"
                       @bind="_scrubOffsetSeconds" @bind:event="oninput" @onkeydown:stopPropagation="true" />
                <div class="mb-1 d-flex justify-content-between align-items-center">
                    <span>Path length: @FormatHorizon(CurrentPlotHorizonSeconds)</span>
                    <button type="button" class="btn btn-sm py-0 @(_horizonChoice == "auto" ? "btn-info" : "btn-outline-light")"
                            title="Let the nav line pick its own length automatically"
                            @onclick="SetHorizonAuto">auto</button>
                </div>
                @* Same full-width form-range as the scrub slider above it. *@
                <input type="range" class="form-range" min="0" max="100" step="1"
                       value="@HorizonSliderValue" title="Length of the navigation line (log scale)"
                       @oninput="OnHorizonSliderInput" @onkeydown:stopPropagation="true" />
                @* #209 — say the state: when a frame crop or the projection cap makes the drawn ribbon
                   shorter than the full picture, name why (never a silently short path). *@
                @{ var _ribbonNote = RibbonHorizonNote(); }
                @if (_ribbonNote is { } _rn)
                {
                    <div class="small map-ribbon-note @(_rn.Warn ? "text-warning fw-bold" : "text-info")"
                         title="How long a stretch of the plotted course the ribbon actually draws, and why">@_rn.Text</div>
                }
                @* #168: this pass/insertion block appears and vanishes at plot cadence (a closest pass
                   comes and goes as the sim ticks / the scrub moves) and its text reflows. Reserve its
                   tallest state (pass line + insert button) in an always-rendered fixed-height container
                   so the burn steps below never jump under a repeated ±15° click. *@
                <div class="map-plot-passline">
                    @if (_closestPass is { } cp)
                    {
                        <div class="small mb-1 @(cp.Impact ? "text-danger fw-bold" : cp.Severity < 5 ? "text-warning" : "text-secondary")">
                            Closest pass: @cp.BodyName @FormatDistance(cp.Distance) (@cp.Severity.ToString("0.0", CultureInfo.InvariantCulture) R)
                            @(cp.Impact ? "— IMPACT, captain! 🦜" : "")
                        </div>
                        @if (_armablePass is { } ap && PassIsOrbitable(ap) is { } est)
                        {
                            <div class="small mb-1">
                                <button type="button" class="btn btn-sm py-0 @(_armedOrbitBodyId == ap.BodyId ? "btn-success" : "btn-outline-info")"
                                        title="Arm the autopilot to insert into orbit at this pass"
                                        @onclick="() => ToggleArmedInsertion(ap.BodyId)">
                                    🛰 @(_armedOrbitBodyId == ap.BodyId
                                        ? $"Insertion ARMED — will orbit {ap.BodyName} (≈{est} p)"
                                        : $"Insert at {ap.BodyName} pass — {FormatDistance(ap.Distance)} (≈{est} p)")
                                </button>
                            </div>
                        }
                    }
                    else if (_armedOrbitBodyId is not null)
                    {
                        <div class="small mb-1 text-info">🛰 Insertion armed: @_armedOrbitBodyId</div>
                    }
                </div>
                @* PR-D2 · the flight plan OWNS the step editors (docs/WednesdayPlan/UnifiedNavListNotes.md,
                   GeminiUINotes.md). The burn list IS the plan; the old floating sling/skim panels are now
                   scratchpad COMPOSE rows (FMS pattern — solve→preview→commit); every committed step
                   expands in place (accordion — one open at a time), so each step's buttons live inside
                   its own row, not loose on the HUD. The NOW/NEXT line is derived through the same Core
                   helper the pilot banner reads, so the two never disagree. *@
                @{
                    FlightPlanStatus _fp = FlightNowNext();
                    int _fpCount = FlightPlanStepCount();
                }
                <div class="map-flightplan-head mb-2">
                    <div class="d-flex justify-content-between align-items-baseline">
                        <span class="fw-bold">🗺 Flight plan</span>
                        @if (_fpCount > 0)
                        {
                            <span class="text-secondary">step @FlightPlanCurrentStep() of @_fpCount</span>
                        }
                    </div>
                    @* #168: NowLine wraps 1↔3 lines and NextLine toggles as the autopilot text changes.
                       Reserve the common 2-line case (now + next) so the frequent 1↔2 flicker can't shove
                       the burn steps below mid-click; a rare 3+-line NowLine may still grow (acceptable). *@
                    <div class="map-flightplan-status">
                        <div class="map-flightplan-now">@_fp.NowLine</div>
                        @if (_fp.NextLine is { } _nextLine)
                        {
                            <div class="map-flightplan-next">@_nextLine</div>
                        }
                    </div>
                </div>
                @* Compose new steps (scratchpad). Add-burn seeds a step at the scrub and opens it; a
                   slingable / skimmable pass offers its own solver as a compose editor that COMMITS a step. *@
                @* #168: the sling / skim compose buttons appear only when the current plot has a
                   slingable / skimmable pass — they toggle at plot cadence and can wrap this row 1↔2
                   lines. Reserve the tallest state so the burn steps below never jump under a click. *@
                <div class="map-plot-compose d-flex flex-wrap align-items-center mb-2 gap-2">
                    <button type="button" class="btn btn-sm btn-outline-light" title="Drop a new burn onto the plan at the scrub time" @onclick="AddBurnAtScrub">
                        + Add burn at scrub
                    </button>
                    @if (_slingablePass is { } sp)
                    {
                        <button type="button" class="btn btn-sm @(_openEditor == FlightEditorKind.Sling ? "btn-info" : "btn-outline-info")"
                                title="Open the sling solver for this flyby" @onclick="ToggleSlingPanel">⤴ Add sling past @sp.BodyName</button>
                    }
                    @if (_skimmablePass is { } kp)
                    {
                        <button type="button" class="btn btn-sm @(_openEditor == FlightEditorKind.Skim ? "btn-danger" : "btn-outline-danger")"
                                title="Open the skim solver for this atmosphere pass" @onclick="ToggleSkimPanel">🔥 Add skim @kp.BodyName</button>
                    }
                    <span class="ms-auto text-nowrap">Planned: @PlannedPulseTotal() / @_reactionMassPulses</span>
                </div>
                @* PR-G · the sling compose editor — SOLVE previews against the real integrator (labs 19/20's
                   crank); "Add the burn" COMMITS the solved node into the plan below. *@
                @if (_openEditor == FlightEditorKind.Sling && _slingablePass is { } slp)
                {
                    <div class="map-step-editor map-sling-body bg-dark bg-opacity-50 rounded p-2 mb-2">
                        <div class="fw-bold small mb-1">⤴ Compose sling past @slp.BodyName</div>
                        <div class="btn-group btn-group-sm w-100 mb-2" role="group" aria-label="Sling side">
                            <button type="button" class="btn @(_slingSide == SlingPlanner.PassSide.Lead ? "btn-success" : "btn-outline-secondary")"
                                    title="Pass on the leading side — steal speed, boost outward" @onclick="() => SetSlingSide(SlingPlanner.PassSide.Lead)">Lead — boost</button>
                            <button type="button" class="btn @(_slingSide == SlingPlanner.PassSide.Trail ? "btn-warning" : "btn-outline-secondary")"
                                    title="Pass on the trailing side — shed speed, brake" @onclick="() => SetSlingSide(SlingPlanner.PassSide.Trail)">Trail — brake</button>
                        </div>
                        <div class="mb-1">Pass distance:
                            <strong>@_slingPassRadii.ToString("0.#", CultureInfo.InvariantCulture) planet radii</strong>
                            <span class="text-secondary">(point-mass floor @SlingMinRadii.ToString("0", CultureInfo.InvariantCulture) R)</span>
                        </div>
                        @* stopPropagation: arrow keys adjust the slider, not fire live ship pulses. *@
                        <input type="range" class="form-range" min="@SlingMinRadii" max="@SlingMaxRadii" step="0.5"
                               value="@_slingPassRadii.ToString(CultureInfo.InvariantCulture)"
                               title="Set how close the flyby skims the planet, in radii"
                               @oninput="OnSlingRadiiInput" @onkeydown:stopPropagation="true" />
                        <div class="text-secondary mb-2">@SlingNodeNoteNow() — solver may propose its own node</div>
                        <button type="button" class="btn btn-sm btn-outline-info w-100 mb-2" disabled="@_slingSolving"
                                title="Fly the sling through the real integrator and preview it" @onclick="RunSlingSolveAsync">@(_slingSolving ? "solving…" : "SOLVE the sling")</button>
                        @if (_slingFailure is { } fail)
                        {
                            <div class="text-warning">⚠ @fail</div>
                        }
                        else if (_slingResult is { Ok: true } r)
                        {
                            <div class="map-sling-verdict">
                                <div>@SlingPassLine(r)</div>
                                <div>@SlingBurnLine(r)</div>
                                <div class="@(r.SpeedGain >= 0 ? "text-success" : "text-warning")">@SlingOutcomeLine(r)</div>
                                <div class="text-warning">@SlingLeverLine(r)</div>
                                <button type="button" class="btn btn-sm btn-success w-100 mt-1" title="Commit this solved sling as a burn on the plan" @onclick="AddSlingBurn">Add the burn → commit step</button>
                            </div>
                        }
                    </div>
                }
                @* PR-I · the skim compose editor — SOLVE flies the pass through the real drag model; the
                   three-zone corridor gauge shows what actually flies; "Add the burn" COMMITS the step. *@
                @if (_openEditor == FlightEditorKind.Skim && _skimmablePass is { } skp)
                {
                    <div class="map-step-editor map-skim-body bg-dark bg-opacity-50 rounded p-2 mb-2">
                        <div class="fw-bold small mb-1">🔥 Compose skim @skp.BodyName</div>
                        <div class="mb-1">Periapsis depth:
                            <strong>@_skimAltKm.ToString("0", CultureInfo.InvariantCulture) km</strong>
                            <span class="text-secondary">(shell top @SkimShellTopKm().ToString("0", CultureInfo.InvariantCulture) km)</span>
                        </div>
                        @* stopPropagation: arrow keys move the slider, not fire live ship pulses. *@
                        <input type="range" class="form-range" min="1" max="@SkimShellTopKm().ToString("0", CultureInfo.InvariantCulture)" step="1"
                               value="@_skimAltKm.ToString("0", CultureInfo.InvariantCulture)"
                               title="Set the periapsis depth of the skim, in km"
                               @oninput="OnSkimAltInput" @onkeydown:stopPropagation="true" />
                        <button type="button" class="btn btn-sm btn-outline-danger w-100 mb-2" disabled="@_skimSolving"
                                title="Fly the skim through the drag model and preview it" @onclick="RunSkimSolveAsync">@(_skimSolving ? "flying the pass…" : "SOLVE the skim")</button>
                        @if (_skimFailure is { } fail)
                        {
                            <div class="text-warning">⚠ @fail</div>
                        }
                        else if (_skimResult is { } g)
                        {
                            @* The corridor gauge: three labeled zones read off the flown DragReport. *@
                            <div class="map-skim-gauge">
                                <div class="map-skim-zone @(g.TooShallow ? "fw-bold" : "text-secondary")">
                                    @(g.ArrivalHyperbolic ? "▲ skip — she bounces" : "▲ too shallow") @(g.TooShallow ? "◀" : "")
                                </div>
                                <div class="map-skim-zone @(g.InCorridor ? "text-success fw-bold" : "text-secondary")">
                                    ● the corridor @(g.InCorridor ? "◀" : "")
                                </div>
                                <div class="map-skim-zone @(g.TooDeep ? "text-danger fw-bold" : "text-secondary")">
                                    ▼ too deep — would hole the sail @(g.TooDeep ? "◀" : "")
                                </div>
                            </div>
                            <div class="map-skim-verdict mt-1">
                                <div>@SkimDepthLine(g)</div>
                                <div class="@(g.TooDeep ? "text-danger" : g.InCorridor ? "text-success" : "text-secondary")">@SkimShedLine(g)</div>
                                <div>@SkimOutcomeLine(g)</div>
                                <div class="text-secondary map-skim-fineprint">@SkimFinePrint()</div>
                                <button type="button" class="btn btn-sm @(g.TooDeep ? "btn-danger" : "btn-success") w-100 mt-1"
                                        title="Commit this solved skim as a burn on the plan" @onclick="AddSkimBurn">@(g.TooDeep ? "Add the burn anyway — fly into the red" : "Add the burn → commit step")</button>
                            </div>
                        }
                    </div>
                }
                @if (_destinationBodyId is not null && _ancientCharges > 0)
                {
                    @* M28: the Ancients' pilot — scarce alien auto-plot, found at the pyramids. *@
                    <button type="button" class="btn btn-sm btn-warning w-100 mb-2" title="Spend an Ancients' charge to auto-plot the whole course" @onclick="UseAncientsPilot">
                        ◬ The Ancients' pilot — lay course to @BodyName(_destinationBodyId) (@_ancientCharges left)
                    </button>
                }

                @if (_planNodes.Count == 0 && _armedOrbitBodyId is null)
                {
                    <div class="text-secondary">No maneuver nodes. Scrub to a future time and add a burn.</div>
                }
                else
                {
                    <div class="map-plot-nodes">
                        @foreach (PlanNode node in _planNodes)
                        {
                            @* PR-D2: each burn is a step. Collapsed, it shows a glanceable line (type +
                               direction + countdown); clicking the line expands its editor in place
                               (accordion — one open at a time). The state pip (planned / done / stale)
                               rides the left edge so the plan reads at a glance. *@
                            FlightStepState _bs = FlightPlanStatusBuilder.BurnState(node.Stale, node.Executed);
                            bool _open = _openEditor == FlightEditorKind.Burn && ReferenceEquals(node, _selectedPlanNode);
                            <div class="mb-1 map-plan-step map-plan-step-@_bs.ToString().ToLowerInvariant() @(node.Stale ? "text-decoration-line-through text-secondary" : "") @(_open ? "map-plan-step-open" : "") @(ReferenceEquals(node, _selectedPlanNode) ? "map-plot-node-selected" : "")">
                                <div class="map-plan-step-line" role="button" tabindex="0"
                                     title="Click to @(_open ? "collapse" : "edit") this step"
                                     @onclick="() => ToggleBurnEditor(node)">
                                    <span class="map-plan-step-pip" title="@_bs" aria-hidden="true"></span>
                                    <span class="map-plan-step-caret" aria-hidden="true">@(_open ? "▾" : "▸")</span>
                                    <span class="flex-grow-1">@BurnGlanceLine(node)</span>
                                    <span class="text-secondary small text-nowrap">@FormatSimTime(node.SimTime)</span>
                                </div>
                                @if (_open)
                                {
                                    <div class="map-plan-step-edit d-flex flex-wrap align-items-center gap-1">
                                        @* Mode toggle: ± is the classic prograde/retrograde factor burn; ✚ is
                                           the X-Pilot point-and-burn that aims a heading to chase a climbing pod. *@
                                        <button type="button"
                                                class="btn btn-sm @(node.Mode == BurnMode.Vector ? "btn-info" : "btn-outline-info") map-plot-mode"
                                                title="@(node.Mode == BurnMode.Vector ? "X-Pilot burn (aim a heading) — click for ± factor burn" : "± factor burn (prograde/retrograde) — click for X-Pilot heading burn")"
                                                @onclick="() => ToggleBurnMode(node)">@(node.Mode == BurnMode.Vector ? "✚" : "±")</button>
                                        @if (node.Mode == BurnMode.Vector)
                                        {
                                            @* X-Pilot: a world-space heading in degrees, plus quick ±15° nudges. The glyphs
                                               promise the VISIBLE rotation of the map arrow: heading is math-CCW (Y up) but the
                                               screen draws Y down, so +15° turns the drawn arrow counter-clockwise — ↺ must be
                                               the POSITIVE nudge (#154, both buttons were inverted vs what the player sees). *@
                                            <button type="button" class="btn btn-sm btn-outline-secondary" title="Rotate counter-clockwise (+15°)"
                                                    @onclick="() => NudgeHeading(node, 15)">↺</button>
                                            @* #201: the burn angle is ship-heading-RELATIVE by default — 0 = straight
                                               ahead, +90 = starboard, −90 = port — the lateral-closing move the owner
                                               types mid-chase. The rel/abs toggle keeps the old world heading a click
                                               away; the stored HeadingDegrees is always world-space (BurnHeadingConvention). *@
                                            <div class="input-group input-group-sm map-plot-heading">
                                                <input type="text" inputmode="decimal" class="form-control form-control-sm"
                                                       value="@(_burnAngleAbsolute
                                                           ? node.HeadingDegrees.ToString("0.#", CultureInfo.InvariantCulture)
                                                           : BurnHeadingConvention.WorldToRelative(HeadingAlongCourseAt(node.SimTime), node.HeadingDegrees).ToString("+0.#;-0.#;0", CultureInfo.InvariantCulture))"
                                                       title="@(_burnAngleAbsolute
                                                           ? "Absolute nose heading in degrees (0° = +X, counter-clockwise)"
                                                           : "Burn angle off the ship's heading — 0 = straight ahead, +90 = starboard (right), −90 = port (left)")"
                                                       @onchange="e => SetHeading(node, e)" @onkeydown:stopPropagation="true" />
                                                <span class="input-group-text">°</span>
                                                <button type="button" class="btn btn-outline-secondary"
                                                        title="@(_burnAngleAbsolute ? "Reading absolute world heading — click for ship-relative (±off heading)" : "Reading ship-relative angle (0 ahead, +90 starboard, −90 port) — click for absolute world heading")"
                                                        @onclick="() => _burnAngleAbsolute = !_burnAngleAbsolute">@(_burnAngleAbsolute ? "abs" : "rel")</button>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" title="Rotate clockwise (−15°)"
                                                    @onclick="() => NudgeHeading(node, -15)">↻</button>
                                        }
                                        else
                                        {
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Burn direction">
                                                <button type="button"
                                                        class="btn @(node.Action == ManeuverAction.Accelerate ? "btn-success" : "btn-outline-secondary")"
                                                        title="Burn prograde — speed up along the track"
                                                        @onclick="() => SetAction(node, ManeuverAction.Accelerate)">+</button>
                                                <button type="button"
                                                        class="btn @(node.Action == ManeuverAction.Decelerate ? "btn-warning" : "btn-outline-secondary")"
                                                        title="Burn retrograde — slow down along the track"
                                                        @onclick="() => SetAction(node, ManeuverAction.Decelerate)">&minus;</button>
                                            </div>
                                        }
                                        @* stopPropagation: typing -/+/arrows here must edit the number, not fire live pulses. *@
                                        <input type="number" class="form-control form-control-sm map-plot-pulses"
                                               min="1" max="@MaxNodePulses" value="@node.Pulses"
                                               @onchange="e => SetPulses(node, e)" @onkeydown:stopPropagation="true" />
                                        @* Text (not number) input so the 4-decimal padding actually shows —
                                           browsers strip trailing zeros from type=number. Owner: at least
                                           ".0000" must be visible for fine thrust trims. *@
                                        <div class="input-group input-group-sm map-plot-percent">
                                            <input type="text" inputmode="decimal" class="form-control form-control-sm"
                                                   value="@(node.Percent.ToString("0.0000", CultureInfo.InvariantCulture))"
                                                   title="Per-pulse thrust strength in percent — any decimal, shown to four places"
                                                   @onchange="e => SetPercent(node, e)" @onkeydown:stopPropagation="true" />
                                            <span class="input-group-text">%</span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-info" title="Re-time to scrub"
                                                @onclick="() => RetimeToScrub(node)">@@</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Delete"
                                                @onclick="() => DeleteNode(node)">&times;</button>
                                    </div>
                                }
                            </div>
                        }
                        @* PR-D2: armed auto-orbit is the terminal step. Collapsed it names the body + state
                           (ARMED → ACTIVE while the autopilot flies the approach); expanded it gains its own
                           disarm control, so the insertion's button lives in its step like every other. The
                           docked-guard (NavLockedByDock) still gates arming/disarming. *@
                        @if (_armedOrbitBodyId is not null)
                        {
                            string _armedId = _armedOrbitBodyId;
                            FlightStepState _is = FlightPlanStatusBuilder.InsertionState(AutopilotFlyingApproach);
                            bool _active = _is == FlightStepState.Active;
                            bool _insOpen = _openEditor == FlightEditorKind.Insertion;
                            <div class="mb-1 map-plan-step map-plan-step-@_is.ToString().ToLowerInvariant() @(_insOpen ? "map-plan-step-open" : "")">
                                <div class="map-plan-step-line" role="button" tabindex="0"
                                     title="Click to @(_insOpen ? "collapse" : "manage")the insertion"
                                     @onclick="ToggleInsertionEditor">
                                    <span class="map-plan-step-pip" title="@_is" aria-hidden="true"></span>
                                    <span class="map-plan-step-caret" aria-hidden="true">@(_insOpen ? "▾" : "▸")</span>
                                    <span class="flex-grow-1">
                                        🛰 @(_orbitKept ? "Holding orbit at" : HarborVocabulary.ArmedStepVerb(HarborClassOf(_armedId))) @BodyName(_armedId)
                                        <span class="text-secondary">— @(_orbitKept ? (_keepTrimPulsesPerDay > 0 ? $"keeping · trim ≈{_keepTrimPulsesPerDay} p/day" : "keeping the park") : _active ? "flying the approach" : "armed · waiting for the window")</span>
                                        @* The promise the autopilot quoted at arm time (#146): the whole-journey
                                           budget it proved affordable before committing. *@
                                        @if (_armedBudgetPulses > 0)
                                        {
                                            <span class="text-info small">· budgeted ≈@(_armedBudgetPulses) p</span>
                                        }
                                        @* #146: the in-well transfer plan riding under this arm — the
                                           planner's one-line quote while the cheap Lambert arc is active. *@
                                        @if (_armedTransferSummary is not null)
                                        {
                                            <span class="text-info small d-block">🛰 @_armedTransferSummary</span>
                                        }
                                    </span>
                                    @if (ArmedInsertionSimTime is { } _it)
                                    {
                                        <span class="text-secondary small text-nowrap">@FormatSimTime(_it)</span>
                                    }
                                    <span class="badge @(_orbitKept ? "bg-success" : _active ? "bg-info text-dark" : "bg-secondary")">@(_orbitKept ? "KEEPING" : _active ? "ACTIVE" : "ARMED")</span>
                                </div>
                                @if (_insOpen)
                                {
                                    <div class="map-plan-step-edit">
                                        <button type="button" class="btn btn-sm btn-outline-warning w-100"
                                                disabled="@NavLockedByDock" title="@(NavLockedByDock ? DockNavLockTip : "Stand the autopilot down and fly the ship by hand")"
                                                @onclick="() => ToggleArmedInsertion(_armedId)">
                                            🛰 @(_orbitKept ? "Hand back the ship — release the kept orbit at" : HarborClassOf(_armedId) == HarborClass.Dock ? "Disarm the dock approach to" : "Disarm auto-orbit at") @BodyName(_armedId)
                                        </button>
                                        <div class="text-secondary small mt-1">@(_orbitKept ? "The autopilot is HOLDING this orbit with trims. Release it and you fly by hand — it takes a confirming second click (#179)." : $"Target: {BodyName(_armedId)} — set from the navigation-target panel below; disarm here, then arm a different body.")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @* M25: the navigation-target panel — its own box, plain words. States exactly what the
       plotted course's nearest point to the destination needs before auto-orbit can take over:
       "the whole point of navigation there" (owner). *@
    @if (PlotMode && _destinationBodyId is not null)
    {
        <div class="map-dest-panel bg-dark bg-opacity-75 rounded p-3 text-light">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold fs-6">🎯 Navigation target: @BodyName(_destinationBodyId)</span>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0"
                        title="Clear the navigation target" @onclick="() => SetDestination(null)">clear target</button>
            </div>
            @if (_destinationPass is { } dp && DestinationPassInfo(dp) is { } info)
            {
                <div class="mb-1">
                    Closest approach on the plotted course: <strong>@FormatDistance(dp.Distance)</strong>
                    at @FormatSimTime(dp.SimTime)
                    <button type="button" class="btn btn-sm btn-outline-info py-0 ms-1"
                            title="Jump the scrub clock to the closest approach" @onclick="() => ScrubToDestinationPass(dp)">scrub to it</button>
                </div>
                @if (info.InRange)
                {
                    <div class="text-success mb-1">
                        ✓ This course passes <strong>inside capture range</strong>
                        (@FormatDistance(info.CaptureRange)). Arm the autopilot and the ship parks
                        itself: approach burn, tidal trims, insertion.
                    </div>
                }
                else
                {
                    <div class="text-warning mb-1">
                        ✗ Capture range is @FormatDistance(info.CaptureRange) — this course misses it by
                        <strong>@FormatDistance(dp.Distance - info.CaptureRange)</strong>.
                        Trim a burn (usually brake a touch earlier) until this line turns green.
                    </div>
                }
                <div class="text-secondary mb-2">
                    Speed at the pass: @((info.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s
                    relative — the autopilot's burns from there cost ≈ @info.EstPulses pulses.
                </div>
                <button type="button" class="btn btn-sm @(!NavLockedByDock && _armedOrbitBodyId == dp.BodyId ? "btn-success" : !NavLockedByDock && info.InRange ? "btn-info" : "btn-outline-info")"
                        disabled="@NavLockedByDock" title="@(NavLockedByDock ? DockNavLockTip : ArmMenuHint(dp.BodyId))"
                        @onclick="() => ToggleArmedInsertion(dp.BodyId)">
                    @(_armedOrbitBodyId == dp.BodyId
                        ? $"🛰 Autopilot ARMED for {dp.BodyName} — click to disarm"
                        : HarborClassOf(dp.BodyId) == HarborClass.Dock
                            ? HarborVocabulary.ArmAction(HarborClass.Dock, dp.BodyName)
                            : $"🛰 Arm auto-orbit at {dp.BodyName}")
                </button>
            }
            else
            {
                <div class="text-secondary">Projecting the course… the closest pass appears here in a moment.</div>
            }

            @* #246/#249 🚀 LONG HAUL — the destination's OWN planet is the void mode's stop. The OFFER is the
               solved cheap DEPARTURE (reachable from a berth or any coast), never gated on the current coast
               reaching. The current-coast Reach still speaks the honest PROMISE VERDICT ("does NOT reach —
               closest pass X AU") for a manual coast. Visible-but-disabled with the reason, never hidden (#212). *@
            @if (LongHaulTargetPlanet(_destinationBodyId) is { } lhPlanet)
            {
                string lhDestName = _destinationBodyId is { } lhDestId ? BodyName(lhDestId) : lhPlanet.Name;
                string? lhBlock = LongHaulOfferBlock(_longHaulDeparture, lhPlanet, _longHaulClearanceBlock);
                <div class="mt-2 pt-2 border-top border-secondary">
                    @* The manual-coast verdict: does THIS course reach, or how far does it miss? *@
                    @if (_longHaulReach is { } lhReach)
                    {
                        <div class="@(lhReach.Reaches ? "text-info" : "text-secondary") small mb-1">
                            🚀 @LongHaul.ReachVerdict(lhPlanet.Name, lhReach, SimTime)
                        </div>
                    }
                    @if (_longHaulDeparture is { Ok: true } lhDep)
                    {
                        <div class="text-secondary small mb-1">
                            @LongHaul.Promise(lhPlanet.Name, LongHaulCaptureRange(lhPlanet), FormatSimTime(lhDep.ArrivalCenterTime), lhDep.DeparturePulses, LongHaulLastMilePulses())
                        </div>
                        <button type="button"
                                class="btn btn-sm @(lhBlock is null ? "btn-warning" : "btn-outline-secondary")"
                                disabled="@(lhBlock is not null)"
                                title="@(lhBlock ?? "Autopilot the whole void in one jump — charge the departure, wake at the capture gate; the last mile stays premium")"
                                @onclick="EngageLongHaul">
                            @LongHaul.Offer(lhDestName, lhDep.DeparturePulses, FormatSimTime(lhDep.ArrivalCenterTime))
                        </button>
                    }
                    @if (lhBlock is not null)
                    {
                        <div class="text-warning small mt-1">@lhBlock</div>
                    }
                </div>
            }
        </div>
    }

    @* #266: the adrift lifeline. The old strip rendered UNDER the masthead (z-order behind .map-topstack)
       and hid the one button a stranded captain needs — the #262 stranding proved it. Now the state
       SAYS itself on the shared #166 alert strip (above), the parrot proposes the tow, and the rescue is
       a real pop-up (below) with the terms visible. What remains inline is a clear, viewport-clamped
       re-open affordance (#253) that lives clear of the banner's no-button zone (#236) — shown only while
       adrift with the offer dismissed, so a captain who declined can always call the tug back. *@
    @if (Adrift && !_showRescueOffer)
    {
        <div class="map-adrift">
            <button type="button" class="map-adrift-reopen" title="Adrift — out of reaction mass. Open the rescue offer and read its terms." @onclick="OpenRescueOffer">
                🛟 Adrift — request rescue
            </button>
        </div>
    }

    @* #266: the rescue offer, a piracy-pop-up-style modal (#243 legible-gate family). The terms are
       VISIBLE before accepting — who comes (a tug), what it brings (reaction mass), what it costs (the
       whole hold, confiscated, enumerated with hot cargo marked), and a clear accept/decline. Going
       adrift is a story beat, not a strip. Auto-opens on the rising edge; re-openable while stranded. *@
    @if (_showRescueOffer && Adrift)
    {
        IReadOnlyList<RescueOffer.FeeLine> _rescueLines = RescueFeeLines();
        <div class="rescue-backdrop" @onclick="CloseRescueOffer">
            <div class="rescue-card" @onclick:stopPropagation="true">
                <div class="rescue-hail">🛟 ADRIFT — OUT OF REACTION MASS</div>
                <div class="rescue-quote">"We're dry, captain. Not a pulse left, and no pump in reach. Shall I whistle for a tow?"</div>
                <div class="rescue-terms">
                    <div class="rescue-brings">🚀 @RescueOffer.TowPromise(ReactionMassCapacity)</div>
                    <div class="rescue-fee">💸 @RescueOffer.FeeHeadline(_rescueLines)</div>
                    @if (_rescueLines.Count > 0)
                    {
                        <ul class="rescue-manifest">
                            @foreach (RescueOffer.FeeLine _line in _rescueLines)
                            {
                                <li>@(_line.Hot ? "🔥" : "📦") @_line.Units @_line.CargoClass (@_line.Value.ToString("N0", CultureInfo.InvariantCulture) cr)@(_line.Hot ? " — hot" : "")</li>
                            }
                        </ul>
                    }
                </div>
                <div class="rescue-options">
                    <button type="button" class="btn btn-warning rescue-accept" title="Whistle for the tug — top the tank, surrender the hold" @onclick="AcceptRescue">
                        🛟 Accept the tow — surrender the hold
                    </button>
                    <button type="button" class="btn btn-outline-light rescue-decline" title="Wave the tug off — you stay adrift; the offer stands" @onclick="CloseRescueOffer">
                        Decline — stay adrift
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_showTutorial)
    {
        int activeTrack = ActiveTutorialIndex();
        <div class="map-tutorial">
            <div class="card bg-dark bg-opacity-75 text-light">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    @* The checklist for the active lesson — the picker itself lives in the Captain's
                       Tutorials tab now (starting a lesson IS a captain's order), so this card is a
                       pure progress tracker that rides the map where the hunt actually plays out. *@
                    <span class="fw-bold small">@(activeTrack >= 0 ? TutorialTracks[activeTrack].Title : "Ship's articles")</span>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" title="Close the lesson checklist" @onclick="ToggleTutorial"></button>
                </div>
                <div class="card-body p-2 small">
                    @if (activeTrack >= 0)
                    {
                        for (int i = TutorialTracks[activeTrack].Start; i < TutorialTracks[activeTrack].Start + TutorialTracks[activeTrack].Length; i++)
                        {
                            bool done = _tutorialStep > i;
                            bool current = _tutorialStep == i;
                            <div class="@(done ? "text-secondary" : current ? "fw-bold text-info" : "")">
                                @(done ? "✓" : "•") @TutorialSteps[i]
                            </div>
                        }
                        <div class="text-secondary fst-italic mt-1">Pick another lesson at the Captain's desk (0) → Tutorials.</div>
                    }
                    else
                    {
                        <div class="text-warning">You're a pirate now — the whole system's yours to work.</div>
                        <div class="text-secondary fst-italic mt-1">Replay any lesson at the Captain's desk (0) → Tutorials.</div>
                    }
                </div>
            </div>
        </div>
    }
    }
    @* The scope lives OUTSIDE the Nav-desk if: Blazor must never destroy this canvas — a
       recreated element leaves renderer.js holding a stale 2D context and the scope goes
       permanently dark after any desk switch (M26 fix). CSS hides it off-Nav instead. *@
    <div class="map-scope @(_showScope && _activeDesk == ShipDesk.Nav ? "" : "d-none")">
        <div class="card bg-dark bg-opacity-75 text-light">
            <div class="card-header py-1 d-flex justify-content-between align-items-center gap-1">
                <span class="fw-bold small">Scope 🔭</span>
                <div class="btn-group btn-group-sm" role="group" aria-label="Scope target">
                    <button type="button" class="btn btn-outline-light py-0" title="Point the scope at the previous target" @onclick="() => CycleScopeTarget(-1)">◀</button>
                    <button type="button" class="btn @(_scopeManualId is null ? "btn-info" : "btn-outline-light") py-0" title="Let the scope pick its own target automatically" @onclick="() => _scopeManualId = null">AUTO</button>
                    <button type="button" class="btn btn-outline-light py-0" title="Point the scope at the next target" @onclick="() => CycleScopeTarget(1)">▶</button>
                </div>
                <button type="button" class="btn-close btn-close-white" aria-label="Close" title="Close the scope window" @onclick="ToggleScope"></button>
            </div>
            <div class="card-body p-1">
                <canvas id="@ScopeCanvasId" class="map-scope-canvas"></canvas>
            </div>
        </div>
    </div>

    @* SATURDAY-ANCHOR: panels — the desk layer (PR-11): each non-Nav/Deck desk fills the screen
       (rule 1 — 70% belongs to the desk's own topic) while the map/sim keeps running underneath
       (rule 4). Sensors dims the map through; the rest go near-opaque. Parallel desk lanes
       (PR-12/13/14) touch only their own branch of this if-chain; PR-15 adds the Captain branch. *@
    @* M27: the Sensors desk renders ALWAYS (d-none off-desk) — the tracking post must never be
       destroyed: the ledger, the passive watch, and its live-scope canvas all live in it. A
       conditionally-rendered component forgot every track on desk switch and left renderer.js
       holding a stale canvas context (the same disease the Nav scope had). *@
    @* M29: the target dossier — a box of its own for the tactical target, independent of the
       NAV destination: bound for Mercury with the book open on a hauler. Floats bottom-center
       ABOVE the desk layers so the sensors chief reads the same book the navigator does. *@
    @if (_activeDesk is ShipDesk.Nav or ShipDesk.Sensors && TacticalTargetId is { } dossierId && DossierFor(dossierId) is { } dossier)
    {
        <div class="map-dossier bg-dark bg-opacity-75 rounded p-2 text-light small">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-bold">📖 @dossier.Name <span class="text-secondary">@dossier.Detail</span></span>
                <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Close dossier" title="Close the target dossier"
                        @onclick="CloseDossier"></button>
            </div>
            <div>@dossier.StatusLine</div>
            <div>@FormatDistance(dossier.Distance) · rel @((dossier.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s ·
                 @RelativeMotion.WordedBefore(dossier.Closing)</div>
            @if (dossier.TrackQuality is { } quality)
            {
                <div>📡 telescope fix @((int)(quality * 100))% <span class="text-secondary">— sharpen it at the Sensors desk</span></div>
            }
            else
            {
                <div class="text-secondary">📡 not on the telescope ledger — track her to sharpen the intel</div>
            }
            <div class="@(dossier.InDriverReach ? "text-info" : "text-secondary")">@dossier.FireLine</div>
            @if (dossier.IsPrey)
            {
                @* The autosteal criterion box (owner): both must be green before shuttles launch. *@
                bool rangeOk = dossier.Distance <= CaptureRule.CaptureRadiusMeters;
                bool speedOk = dossier.RelSpeed <= CaptureRule.MaxRelativeSpeed;
                <div class="border border-secondary rounded px-2 py-1 mt-1">
                    <div class="fw-bold">🎯 Autosteal needs BOTH:</div>
                    <div class="@(rangeOk ? "text-success" : "text-warning")">
                        @(rangeOk ? "✅" : "❌") close enough —
                        @FormatDistance(dossier.Distance) @(rangeOk ? "≤" : ">") @FormatDistance(CaptureRule.CaptureRadiusMeters)
                    </div>
                    <div class="@(speedOk ? "text-success" : "text-warning")">
                        @(speedOk ? "✅" : "❌") speed match —
                        @((dossier.RelSpeed / 1000).ToString("F1", CultureInfo.InvariantCulture)) km/s
                        @(speedOk ? "≤" : ">") @((CaptureRule.MaxRelativeSpeed / 1000).ToString("F0", CultureInfo.InvariantCulture)) km/s
                    </div>
                    <div class="@(dossier.BoardReady == 2 ? "text-success fw-bold" : "text-secondary")">
                        @(dossier.BoardReady switch
                        {
                            2 => "→ BOARDABLE NOW — hold the match, shuttles launch on their own",
                            1 => "→ too fast — match her velocity, or hole her sail so she drifts",
                            _ => "→ close the distance, then match her speed",
                        })
                    </div>
                </div>
            }
            @if (_interestTargetId == dossierId && InterceptChipLine() is { } clock)
            {
                <div class="text-warning">@clock</div>
            }
            <div class="d-flex gap-1 mt-1">
                <button type="button" class="btn btn-sm py-0 @(_interestTargetId == dossierId ? "btn-info" : "btn-outline-info")"
                        title="Mark her the target of interest — intercept clock and firing solutions" @onclick="() => SetInterestTarget(dossierId)">🎯 interest</button>
                <button type="button" class="btn btn-sm btn-outline-info py-0"
                        title="Put the telescope on her to sharpen the fix" @onclick="() => TrackShipFromMenu(dossierId)">📡 sharpen fix</button>
                <button type="button" class="btn btn-sm btn-outline-light py-0"
                        title="Take this target to the war room" @onclick="() => SwitchDesk(ShipDesk.WarRoom)">⚔ war room</button>
            </div>
        </div>
    }

    @* M29: desk-layer-passthrough — the sensors chief works the SKY, not a form: pointer
       events fall through the desk's empty space to the live map below (pan, wheel zoom,
       ship click → contact menu), while every actual instrument re-enables its own events. *@
    <div class="desk-layer desk-layer-dimmed desk-layer-passthrough @(_activeDesk == ShipDesk.Sensors ? "" : "d-none")">
        <div class="desk-content">
            <SpaceSails.Client.Pages.Stations.TrackingPost @ref="_trackingPost" Visible="_activeDesk == ShipDesk.Sensors" FullScreen="true"
                SimTime="SimTime" ShipPosition="_ship.Position" ShipVelocity="_ship.Velocity" ShipCharge="_ship.Charge"
                Ephemeris="_ephemeris" Candidates="TrackingCandidates()" MaxTracks="_telescopeLevel + 1"
                TelescopeSpeedFactor="1 + 0.5 * _telescopeLevel"
                RadarActive="_activeRadar" OnRadarToggle="SetActiveRadar"
                Transponder="_transponderMode" OnTransponderChange="SetTransponder"
                Opportunities="_courseOpportunities" OnSetInterest="SetInterestTarget"
                OnZoomMap="ZoomSensorsBackdrop" OnCenterShip="CenterShipOnMap"
                OnAreaScanCompleted="OnAreaScanCovered"
                OnClose="() => SwitchDesk(ShipDesk.Nav)" />
        </div>
    </div>
    @if (_activeDesk is ShipDesk.WarRoom or ShipDesk.Trade or ShipDesk.Comms or ShipDesk.Galley or ShipDesk.Captain)
    {
        @* The war room dims instead of blanking (long-shots PR): the live map behind it IS the
           orrery view for cross-system firing solutions — DrawFirePlan draws the transfer.
           And it's PASSTHROUGH (owner: "the war room map seems dead to mouse clicks") — the
           gunner pans, zooms and clicks contacts on the sky, same as the sensors chief. *@
        <div class="desk-layer @(_activeDesk == ShipDesk.WarRoom ? "desk-layer-dimmed desk-layer-passthrough" : "")">
            <div class="desk-content">
                @if (_activeDesk == ShipDesk.WarRoom)
                {
                    <SpaceSails.Client.Pages.Stations.WarRoom Visible="true" FullScreen="true" SimTime="SimTime" ShipPosition="_ship.Position" ShipVelocity="_ship.Velocity" Contacts="WarRoomContacts()" Hunters="WarRoomHunters()" HeatLevel="_heat.Level" CoolingAtHaven="IsHiddenAtHaven()" Credits="_credits" SensorTracks="WarRoomSensorTracks()" InterestId="@_interestTargetId" Intercept="_intercept" InterceptTargetName="@InterestTargetName()" OnSetInterest="SetInterestTarget"
                        FireAimOffsetSeconds="_fireAimOffsetSeconds" MaxAimOffsetSeconds="MaxFireAimOffsetSeconds" MaxMuzzleSpeedMps="MaxMuzzleSpeed" InterestDistanceMeters="InterestDistanceNow()" FireKind="_fireKind" FireSolution="_fireSolution" FireBlockedBy="@_fireBlockedBy" RoundsInFlight="LiveRounds()" PlannedImpactInSeconds="PlannedImpactEta()" StraightWindowText="@StraightWindowText()" WeaponsAuthorized="WeaponsAuthorized" FireAtWill="_fireAtWill" SlugAmmo="_slugAmmo" MissileAmmo="_missileAmmo" Docked="_docked" CanWarnInterest="CanWarnInterest()" OnBuyAmmo="BuyAmmo" FireDispersionMeters="_fireDispersionMeters" RevealedIterations="_revealedIterations" FireCountdownSeconds="@(FireLocked ? _fireAtSimTime - SimTime : null)" FireTip="@_fireTip" FirePulseCost="@(_fireKind == OrdnanceKind.Missile ? MissilePulseCost : SlugPulseCost)" PulsesAvailable="_reactionMassPulses"
                        OnAimOffsetChanged="SetFireAimOffset" OnFireKindChanged="SetFireKind" OnComputeSolution="ComputeFiringSolution" OnCancelFire="CancelFiringSolution" OnScanWindows="ScanFiringWindows" OnAutoAim="AutoAim" OnArmFire="ArmFire"
                        OnClose="() => SwitchDesk(ShipDesk.Nav)" OnWarningShot="FireWarningShot" OnBribe="BribeShip" />
                }
                else if (_activeDesk == ShipDesk.Trade)
                {
                    @* Trading floor, master–detail edition (owner: "like File Explorer"): the
                       places-of-business TREE + detail pane owns two thirds of the desk, the
                       cargo manifest keeps its column. The dock market is no longer a loose
                       floating panel — it renders as the dockyard node's detail inside the tree
                       (passed down as a fragment so all its bindings stay right here). *@
                    <div class="desk-trade-grid">
                        <SpaceSails.Client.Pages.Stations.LocalSpace @ref="_localSpace" Visible="true" FullScreen="true" BodyName="@(LocalSpaceBodyId is { } lsb ? BodyName(lsb) : null)" OrbitBodyId="@_orbitedBodyId" ContextBodyId="@LocalSpaceBodyId" Contacts="LocalContacts()" ShipPosition="_ship.Position" ShipVelocity="_ship.Velocity" CargoUnits="_cargoUnits" CargoValue="_cargoValue" Credits="_credits" HoldSpaceUnits="CargoCapacity - _cargoUnits" ActiveTradeTargetId="@_localTradeTargetId" TradeProgress="_localTradeProgress" TradeMessage="@_localTradeMessage" DockedBodyId="@(_docked ? _dockBodyId : null)" DockedBodyName="@(_docked && _dockBodyId is { } dbn ? BodyName(dbn) : null)" BodyNameLookup="BodyName" OnStartTrade="StartLocalTrade" OnStartBuy="StartLocalBuy" OnClose="() => SwitchDesk(ShipDesk.Nav)">
                            <DockMarket>
                                <div class="d-flex gap-2 mb-2">
                                    <button type="button" class="btn btn-sm btn-success flex-grow-1" disabled="@(_cargoValue <= 0)" title="Sell the whole hold at this dock's prices" @onclick="SellCargo">
                                        Sell cargo (@_cargoValue.ToString("N0", CultureInfo.InvariantCulture) cr)
                                    </button>
                                </div>
                                @* ⛽ fuel is bought in the always-visible fuel gauge (side panel), so it
                                   answers "how do I fill her up?" (#157) whether or not you're docked. *@
                                <div class="fw-bold mb-1">Upgrades</div>
                                <table class="table table-sm table-dark mb-0">
                                    <tbody>
                                        <tr>
                                            <td>Reaction mass<br /><span class="text-secondary">Lv @_massLevel → cap @(ReactionMassCapacity + 150)</span></td>
                                            <td class="text-end align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_massLevel))" title="Buy the reaction-mass upgrade — a bigger fuel cap" @onclick='() => BuyUpgrade("mass")'>
                                                    @UpgradePrice(_massLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                                </button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Sensor range<br /><span class="text-secondary">Lv @_sensorLevel → @FormatDistance(SensorModel.Default.RangeMeters * Math.Pow(1.4, _sensorLevel + 1))</span></td>
                                            <td class="text-end align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_sensorLevel))" title="Buy the sensor upgrade — a longer detection range" @onclick='() => BuyUpgrade("sensor")'>
                                                    @UpgradePrice(_sensorLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                                </button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Cargo hold<br /><span class="text-secondary">Lv @_holdLevel → @(CargoCapacity + 10) units</span></td>
                                            <td class="text-end align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_credits < UpgradePrice(_holdLevel))" title="Buy the cargo-hold upgrade — more units of space" @onclick='() => BuyUpgrade("hold")'>
                                                    @UpgradePrice(_holdLevel).ToString("N0", CultureInfo.InvariantCulture) cr
                                                </button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Telescope<br /><span class="text-secondary">Lv @_telescopeLevel → @(_telescopeLevel + 2) simultaneous tracks</span></td>
                                            <td class="text-end align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_telescopeLevel >= 3 || _credits < UpgradePrice(_telescopeLevel))" title="Buy the telescope upgrade — track more ships at once" @onclick='() => BuyUpgrade("telescope")'>
                                                    @(_telescopeLevel >= 3 ? "MAX" : $"{UpgradePrice(_telescopeLevel):N0} cr")
                                                </button>
                                            </td>
                                        </tr>
                                        @* PR-BUSTED: the one shipped dice helper — a named +2 on any last stand (the
                                           purchasable-modifier seam; the shop of helpers is a follow-up). *@
                                        <tr>
                                            <td>Boarding-nets jammer<br /><span class="text-secondary">@(_hasNetJammer ? "fitted — +2 on resist" : "+2 on any last stand")</span></td>
                                            <td class="text-end align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-info" disabled="@(_hasNetJammer || _credits < NetJammerPriceCr)" title="A named +2 modifier on resist/Bolivia initiative — proves the dice-helper seam" @onclick="BuyNetJammer">
                                                    @(_hasNetJammer ? "OWNED" : $"{NetJammerPriceCr:N0} cr")
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </DockMarket>
                        </SpaceSails.Client.Pages.Stations.LocalSpace>
                        <div class="desk-side-panel">
                            @* ⛽ FILL HER UP (#157) — the desk's answer to "how do I refuel her?", always
                               shown: a car-gauge fuel meter banded green / amber (<18%) / red (floor),
                               a fat FILL HER UP button + a +10 p top-up when the ship is alongside a pump
                               (FuelReachability.AlongsidePump — the same truth the fuel alarm reads), and an
                               honest "nearest pump N p away" line when it isn't. *@
                            @{
                                int _fuelCap = ReactionMassCapacity;
                                int _fuelPulses = _reactionMassPulses;
                                double _fuelFrac = _fuelCap > 0 ? Math.Clamp((double)_fuelPulses / _fuelCap, 0, 1) : 0;
                                AlertSeverity? _fuelBand = FuelAlertRule.Evaluate(_fuelPulses, _fuelCap);
                                string _fuelBandClass = _fuelBand switch
                                {
                                    AlertSeverity.Red => "fuel-red",
                                    AlertSeverity.Amber => "fuel-amber",
                                    _ => "fuel-green",
                                };
                                CelestialBody? _fuelPump = _ephemeris is not null ? FuelReachability.AlongsidePump(_ephemeris, _ship) : null;
                            }
                            <div class="fuel-desk card bg-dark bg-opacity-50 text-light mb-2">
                                <div class="card-body p-2">
                                    <div class="fuel-desk-title fw-bold">⛽ FUEL</div>
                                    <div class="fuel-gauge @_fuelBandClass" title="Reaction mass: @_fuelPulses of @_fuelCap pulses">
                                        <div class="fuel-gauge-fill" style="width:@(((int)(_fuelFrac * 100)))%"></div>
                                        <div class="fuel-gauge-readout">@_fuelPulses<span class="fuel-gauge-cap"> / @_fuelCap p</span></div>
                                    </div>
                                    @if (_fuelPump is { } _pump)
                                    {
                                        int _fuelPrice = FuelMarket.PricePerPulse(_ephemeris!.Position(_pump.Id, SimTime).Length);
                                        int _fuelRoom = _fuelCap - _fuelPulses;
                                        FuelMarket.Quote _fill = FuelMarket.QuoteFill(_fuelPulses, _fuelCap, _fuelPrice, _credits, int.MaxValue);
                                        FuelMarket.Quote _topUp = FuelMarket.QuoteFill(_fuelPulses, _fuelCap, _fuelPrice, _credits, 10);
                                        <div class="fuel-alongside small mt-1">Alongside @BodyName(_pump.Id) · @_fuelPrice cr/p</div>
                                        <div class="d-flex gap-2 mt-2">
                                            <button type="button" class="btn btn-warning fw-bold fuel-fill-btn flex-grow-1"
                                                    title="@($"Top the tank right off — buys {_fill.Pulses} p for {_fill.Cost:N0} cr")"
                                                    disabled="@(_fuelRoom <= 0 || _fill.Pulses <= 0)" @onclick="() => BuyFuel(int.MaxValue)">
                                                ⛽ FILL HER UP@(_fuelRoom > 0 && _fill.Pulses > 0 ? $" · {_fill.Cost:N0} cr" : "")
                                            </button>
                                            <button type="button" class="btn btn-outline-warning fuel-topup-btn"
                                                    title="@($"Take on {_topUp.Pulses} p for {_topUp.Cost:N0} cr")"
                                                    disabled="@(_fuelRoom <= 0 || _topUp.Pulses <= 0)" @onclick="() => BuyFuel(10)">
                                                +10 p
                                            </button>
                                        </div>
                                        @if (_fuelRoom <= 0)
                                        {
                                            <div class="fuel-note small text-secondary mt-1">Tank's full.</div>
                                        }
                                        else if (_fill.Pulses <= 0)
                                        {
                                            <div class="fuel-note small text-danger mt-1">Not enough credits for even one pulse (@_fuelPrice cr/p).</div>
                                            @* PR-WIRE: broke at the pump — the dream's anonymized favor wire. A trusted
                                               dark-web-native contact wires gas money; you owe them one quiet delivery. *@
                                            @if (BestWireLenderId() is { } lender)
                                            {
                                                <button type="button" class="btn btn-sm btn-warning mt-2 w-100"
                                                        title="@($"Call in a favor — {ContactSheets.For(lender).DisplayName} wires you {PumpLoanPrincipal(_fuelRoom, _fuelPrice):N0} cr for fuel. You'll owe one quiet delivery.")"
                                                        @onclick="CallInFavorAtPump">
                                                    📡 Call in a favor — @ContactSheets.For(lender).DisplayName wires @PumpLoanPrincipal(_fuelRoom, _fuelPrice).ToString("N0", CultureInfo.InvariantCulture) cr
                                                </button>
                                            }
                                        }
                                        else if (_fill.Pulses < _fuelRoom)
                                        {
                                            <div class="fuel-note small text-warning mt-1">Credits cover @_fill.Pulses of the @_fuelRoom p of room.</div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="fuel-directions small mt-1">@FuelDirectionsLine()</div>
                                    }
                                </div>
                            </div>
                            <div class="trade-manifest-panel card bg-dark bg-opacity-50 text-light">
                            <div class="card-header py-1"><span class="fw-bold small">Cargo manifest</span></div>
                            <div class="card-body p-2 small">
                                @if (_localTradeTargetId is not null)
                                {
                                    <div class="trade-manifest-transfer mb-2">
                                        <div class="text-info trade-manifest-transfer-label">@(_localTradeMessage ?? "Drones ferrying…")</div>
                                        <div class="progress trade-manifest-progress">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width:@(((int)(_localTradeProgress * 100)))%"></div>
                                        </div>
                                        <div class="text-info trade-manifest-transfer-pct">@((int)(_localTradeProgress * 100))%</div>
                                    </div>
                                }
                                @{ IReadOnlyList<CargoManifestEntry> manifest = CargoManifest(); }
                                @if (manifest.Count == 0)
                                {
                                    <div class="text-secondary">Hold empty.</div>
                                }
                                else
                                {
                                    <table class="table table-sm table-dark mb-0">
                                        <thead>
                                            <tr>
                                                <th>Class</th>
                                                <th class="text-end">Units</th>
                                                <th class="text-end">Est. value</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (CargoManifestEntry entry in manifest)
                                            {
                                                <tr>
                                                    <td>@entry.CargoClass</td>
                                                    <td class="text-end">@entry.Units</td>
                                                    <td class="text-end">@entry.Value.ToString("N0", CultureInfo.InvariantCulture) cr</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="fw-bold">
                                                <td>Total</td>
                                                <td class="text-end">@_cargoUnits/@CargoCapacity</td>
                                                <td class="text-end">@_cargoValue.ToString("N0", CultureInfo.InvariantCulture) cr</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                }
                            </div>
                            </div>
                        </div>
                    </div>
                }
                else if (_activeDesk == ShipDesk.Comms)
                {
                    @* Comms room, master–detail edition (ui-guidelines.md; validated by the Gemini
                       playtest consult): ticker on top, then the CONTACTS TREE on the left — lean
                       rows, one status badge each, grouped Scheduled / En route / fixtures, plus
                       "Off the books" and the dark web market as first-class nodes — and ONLY the
                       selected node's detail on the right. The three loose consoles are gone:
                       tight-beam and laser ranging were always per-contact actions, so they live
                       in the contact's detail now; the market is the dark-web node's detail. *@
                    <div class="desk-comms-room">
                        <div class="comms-ticker">
                            <span class="comms-ticker-label fw-bold small">News wire 📡</span>
                            @{ IReadOnlyList<NewsWire.NewsItem> wire = NewsFeed(CommsTickerAmbientDays); }
                            @if (wire.Count == 0)
                            {
                                <span class="comms-ticker-item text-secondary small">No whispers yet.</span>
                            }
                            else
                            {
                                @foreach (NewsWire.NewsItem item in wire.Take(CommsTickerItemCount))
                                {
                                    <span class="comms-ticker-item small">@item.Headline</span>
                                }
                            }
                        </div>
                        <div class="desk-comms-grid">
                            <div class="desk-side-panel comms-traffic-panel card bg-dark bg-opacity-50 text-light">
                                <div class="card-header py-1"><span class="fw-bold small">Contacts &amp; intel</span></div>
                                <div class="card-body p-2 small desk-traffic-scroll">
                                    @foreach ((string groupLabel, List<NpcState> members) in CommsGroups())
                                    {
                                        <div class="comms-tree-group text-secondary fw-bold">@groupLabel</div>
                                        @foreach (NpcState npc in members)
                                        {
                                            NpcState row = npc;
                                            <div class="comms-node @(row.Ship.Id == _commsSelectedId ? "comms-node-selected" : "")"
                                                 role="button" tabindex="0" title="Open her file in the comms panel" @onclick="() => SelectCommsShip(row.Ship.Id)">
                                                <span class="flex-grow-1">@row.Ship.Callsign</span>
                                                @if (!row.Ship.PublishesTimetable)
                                                {
                                                    <span class="badge bg-dark border border-secondary" title="Bought intel — off the books">🕸</span>
                                                }
                                                @{ (string rowBadge, string rowBadgeCss) = CommsStatusBadge(row); }
                                                <span class="badge @rowBadgeCss">@rowBadge</span>
                                            </div>
                                        }
                                    }
                                    <div class="comms-tree-group text-secondary fw-bold">Intel</div>
                                    @foreach (ScopeIntel intel in _scopeIntel)
                                    {
                                        ScopeIntel si = intel;
                                        string siNodeId = $"scopeintel:{si.Id}";
                                        <div class="comms-node @(_commsSelectedId == siNodeId ? "comms-node-selected" : "")"
                                             role="button" tabindex="0" title="Open this tip in the comms panel" @onclick="() => _commsSelectedId = siNodeId">
                                            <span class="flex-grow-1">@si.Headline</span>
                                            <span class="badge bg-info text-dark">tip</span>
                                        </div>
                                    }
                                    <div class="comms-node @(_commsSelectedId == "offbooks" ? "comms-node-selected" : "")"
                                         role="button" tabindex="0" title="Open the off-the-books ships in the comms panel" @onclick='() => _commsSelectedId = "offbooks"'>
                                        <span class="flex-grow-1">🕵 Off the books</span>
                                        <span class="badge bg-secondary">@OffBooksCount unknown</span>
                                    </div>
                                    <div class="comms-node @(_commsSelectedId == "darkweb" ? "comms-node-selected" : "")"
                                         role="button" tabindex="0" title="Open the dark-web market in the comms panel" @onclick='() => _commsSelectedId = "darkweb"'>
                                        <span class="flex-grow-1">🕸 Dark web market</span>
                                        <span class="badge @(DarkWebCanTrade() ? "bg-success" : "bg-secondary")">@(DarkWebCanTrade() ? "open" : "offline")</span>
                                    </div>
                                </div>
                            </div>
                            @if (_commsSelectedId == "darkweb")
                            {
                                <SpaceSails.Client.Pages.Stations.DarkWeb Visible="true" FullScreen="true" SimTime="SimTime" ShipPosition="_ship.Position" @bind-Credits="_credits" Ledger="_intelLedger" CanTrade="DarkWebCanTrade()" DisabledReason="@DarkWebDisabledReason()" TradeLocationDistanceFromEarthMeters="DarkWebDistanceFromEarth()" MarketShips="DarkWebMarketShips()" TrackedShips="DarkWebTrackedShips()" WireContacts="DarkWebWireContacts()" OnOpenWireBank="id => OpenBank(id, viaWire: true)" OnIntelPurchased="(string cs) => PushNewsEvent(NewsWire.NewsEventKind.IntelPurchased, cs)" OnClose="() => SwitchDesk(ShipDesk.Nav)" />
                            }
                            else
                            {
                                <div class="desk-side-panel card bg-dark bg-opacity-50 text-light">
                                    @if (_commsSelectedId is { } scSel && scSel.StartsWith("scopeintel:", StringComparison.Ordinal) && ScopeIntelById(scSel) is { } tip)
                                    {
                                        <div class="card-header py-1"><span class="fw-bold small">@tip.Headline</span></div>
                                        <div class="card-body p-2 small">
                                            <div class="comms-breadcrumbs text-secondary mb-1">Intel › orbit fix</div>
                                            @foreach (string line in tip.Lines)
                                            {
                                                <div class="mb-1">@line</div>
                                            }
                                            <div class="d-grid gap-1 mt-2">
                                                <button type="button" class="btn btn-sm btn-info py-0 px-1 text-start"
                                                        title="Slew the scope to where this tip predicts and scan" @onclick="() => PointScopeWhereIntelSays(tip)">
                                                    🔭 Point the scope where this says
                                                </button>
                                            </div>
                                            <div class="text-secondary mt-2">The scope slews to the predicted spot and runs a prioritized area scan. Warp time at the <span class="text-light">Sensors desk</span> until the pass lands — when it sweeps over her, she's charted.</div>
                                        </div>
                                    }
                                    else if (_commsSelectedId == "offbooks")
                                    {
                                        <div class="card-header py-1"><span class="fw-bold small">🕵 Off the books</span></div>
                                        <div class="card-body p-2 small">
                                            <div class="comms-breadcrumbs text-secondary mb-1">Intel › Off the books</div>
                                            <div><span class="fw-bold">@OffBooksCount ship@(OffBooksCount == 1 ? "" : "s")</span> are flying with no published timetable — the board can't list what nobody filed.</div>
                                            <div class="text-secondary mt-2">Two ways to find them:</div>
                                            <div class="text-secondary">🔭 sweep the sky with the telescope at the <span class="text-light">Sensors desk</span> — lane watches and area scans catch dark hulls;</div>
                                            <div class="text-secondary">🕸 buy their route intel at the <span class="text-light">dark web market</span> (open at a haven, or a station past Mars) — bought ships join the contacts tree with a 🕸 badge until the tip goes stale.</div>
                                        </div>
                                    }
                                    else if (_commsSelectedId is { } commsSelId && FindNpc(commsSelId) is { } commsShip)
                                    {
                                        bool commsTracked = _trackingPost is not null && _trackingPost.TryGetTrack(commsShip.Ship.Id, out _);
                                        <div class="card-header py-1 d-flex justify-content-between align-items-center">
                                            <span class="fw-bold small">@commsShip.Ship.Callsign</span>
                                            @{ (string detailBadge, string detailBadgeCss) = CommsStatusBadge(commsShip); }
                                            <span class="badge @detailBadgeCss">@detailBadge</span>
                                        </div>
                                        <div class="card-body p-2 small">
                                            <div class="comms-breadcrumbs text-secondary mb-1">Departures board › @commsShip.Ship.Callsign</div>
                                            <div>@commsShip.Ship.CargoClass (@commsShip.Ship.CargoUnits u) · @RouteLabel(commsShip.Ship)</div>
                                            <div>@DepartureLabel(commsShip.Ship)</div>
                                            <div class="text-secondary">last seen: @(commsShip.LastObservation is { } lastObs ? FormatSimTime(lastObs.SimTime) : "never — not yet inside sensor reach")</div>
                                            @if (!commsShip.Ship.PublishesTimetable)
                                            {
                                                <div class="text-secondary">🕸 bought intel — goes stale in @IntelStaleInDays(commsShip.Ship.Id).ToString("F0") d</div>
                                            }
                                            <div class="d-grid gap-1 mt-2 comms-actions">
                                                @if (commsTracked)
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-info py-0 px-1 text-start"
                                                            title="Hail her on tight-beam and ask her intentions" @onclick="() => CommsHail(commsShip)">
                                                        📻 Hail via tight-beam — ask her intentions
                                                    </button>
                                                    @if (_commsHailAnswer is not null)
                                                    {
                                                        <div class="text-info">@_commsHailAnswer</div>
                                                    }
                                                    <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1 text-start"
                                                            title="Laser-range her for an exact fix — but she learns where we are" @onclick="() => CommsLaserRange(commsShip)">
                                                        ⚡ Laser range — exact fix, but she learns where we are
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-success py-0 px-1 text-start"
                                                            disabled="@(!CommsCanFence(commsShip))"
                                                            title="@(DarkWebCanTrade() ? "Sell this telescope track to the dark-web market for coin" : DarkWebDisabledReason())"
                                                            @onclick="() => CommsSellTrack(commsShip)">
                                                        🕸 Fence this track@(CommsFencePrice(commsShip) is { } fencePrice ? $" — +{fencePrice:N0} cr" : " — needs ≥50% quality at a haven")
                                                    </button>
                                                }
                                                else
                                                {
                                                    <div class="text-secondary">Not on your telescope ledger — track her at the <span class="text-light">Sensors desk</span> to hail, laser-range, or fence the track.</div>
                                                }
                                                @if (SelectedTrackedTarget() is { } pinTarget && pinTarget.Ship.Id == commsShip.Ship.Id)
                                                {
                                                    <button type="button" class="btn btn-sm @(_pinned ? "btn-warning" : "btn-outline-light") py-0 px-1 text-start" title="Pin her so the scope holds her brake point" @onclick="TogglePin">
                                                        📌 Pin: brakes at @BodyName(pinTarget.Ship.DestinationId)
                                                    </button>
                                                }
                                            </div>
                                            @if (_commsActionMessage is not null)
                                            {
                                                <div class="text-warning mt-1">@_commsActionMessage</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="card-body p-2 small text-secondary">
                                            Select a contact in the tree — its dossier and comms actions (hail, laser ranging, fencing the track) show here.
                                            Ships missing from the board are found at the <span class="text-light">Sensors desk</span> or bought at the <span class="text-light">dark web market</span>.
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (_activeDesk == ShipDesk.Galley)
                {
                    <SpaceSails.Client.Pages.Stations.Galley SimTime="SimTime" Feed="NewsFeed(GalleyFeedAmbientDays).Take(GalleyFeedItemCount).ToList()" RumTots="_rumTots" WobbleActive="RumWobbleActive" LastRumLine="@_lastRumLine" OnPourRum="PourRumFromGalley" />
                }
                else if (_activeDesk == ShipDesk.Captain)
                {
                    <SpaceSails.Client.Pages.Stations.Captain CurrentMission="_mission" Options="_missionOptions" OnSelectMission="SetMission"
                                                              StatusChips="AllStationChips()" OnGoToDesk="SwitchDesk"
                                                              ShotAuthorized="_shotAuthorized" FireAtWill="_fireAtWill"
                                                              OnAuthorizeShot="AuthorizeShot" OnToggleFireAtWill="ToggleFireAtWill"
                                                              Tutorials="TutorialCards()" ActiveTutorial="ActiveTutorialIndex()" OnStartTutorial="StartTutorial"
                                                              OpenToTutorials="_openCaptainToTutorials" Quests="QuestCards()"
                                                              OnPointScope="PointScopeForActiveFetch"
                                                              Tips="LedgerTips()" OnScopeTip="PointScopeFromLedger"
                                                              Accounts="LedgerAccounts()"
                                                              OnRouteToDarkWeb="OpenDarkWebFromLedger" OnRouteToDossier="OpenDossierFromLedger"
                                                              Maps="LedgerMaps()" OnViewMap="ViewMapFromLedger"
                                                              OnReopenStartPicker="ReopenStartPicker"
                                                              OnSaveVault="SaveVaultManually" OnExportVault="ExportVault" OnImportVault="ImportVault"
                                                              InitialTab="_captainTab" OnTabChanged="t => { _captainTab = t; }" />
                }
            </div>
        </div>
    }

    <SpaceSails.Client.Pages.Stations.DeskChips Chips="BuildDeskChips()" OnSelect="SwitchDesk" />

    @* #185: the completion fanfare. A finished contract is a CELEBRATION — who paid us, what for,
       the coin, the giver grateful in their own voice, and the parrot singing. The money is shown
       arriving here; it never just silently appears in the ledger. *@
    @if (_celebration is { } party)
    {
        <div class="mission-celebration-backdrop" @onclick="DismissCelebration">
            <div class="mission-celebration" @onclick:stopPropagation="true">
                <div class="mc-fanfare">🎉 CONTRACT COMPLETE 🎉</div>
                <div class="mc-title">@party.Title</div>
                <div class="mc-giver">◈ @party.GiverName</div>
                <div class="mc-thanks">@party.GiverThanks</div>
                <div class="mc-payment">💰 +@party.PaidCredits.ToString("N0", CultureInfo.InvariantCulture) cr received</div>
                <div class="mc-parrot">🦜 @party.ParrotSong</div>
                <div class="mc-history">
                    @(party.MissionsWithGiver <= 1
                        ? $"A new name in your logbook — your first job for {party.GiverName}."
                        : $"Job #{party.MissionsWithGiver} for {party.GiverName}. You've got a history now.")
                </div>
                <button type="button" class="btn btn-warning btn-sm mt-2" title="Toast the payday and clear the fanfare" @onclick="DismissCelebration">Raise a glass 🍻</button>
            </div>
        </div>
    }

    @* PR-BUSTED (owner ruling §5): the catch. A hunter runs you down → warp yanks to 1×, the ship is
       grappled, and this pop-up opens in the collector's voice. SUBMIT / BRIBE / RESIST, GTA-BUSTED
       grammar — never game over (the Bolivia freeze-frame ends in brain-backup resurrection). The dice
       are rolled Core-side and shown here, modifiers listed. Reuses the celebration modal's backdrop
       grammar. *@
    @if (_busted is { } bust)
    {
        <div class="busted-backdrop @(bust.Phase is BustedEncounter.Stage.FreezeFrame or BustedEncounter.Stage.Impact ? "busted-sepia" : "")">
            <div class="busted-card" @onclick:stopPropagation="true">
                @switch (bust.Phase)
                {
                    case BustedEncounter.Stage.Demand:
                        <div class="busted-hail">⛓ CAUGHT — @bust.HunterCallsign has you grappled</div>
                        <div class="busted-heat">Heat @HeatFlames(bust.Heat) · exposure: @BustedRule.ExposurePhrase(bust.Heat)</div>
                        <div class="busted-quote">"Heave to. We're collecting. This goes easy or it goes @(bust.Heat >= EncounterRule.MaxHeatLevel ? "Bolivia" : "hard") — your call, captain."</div>
                        int _hotUnits = _hotCargo.TotalHotUnits;
                        int _coinShare = (int)Math.Round(_credits * BustedRule.CoinFraction(bust.Heat));
                        bool _canBribe = _credits >= bust.Bribe.Total;
                        <div class="busted-options">
                            <button type="button" class="btn btn-warning busted-opt" @onclick="() => BustedSubmit(false)">
                                <span class="bo-title">🤍 SUBMIT</span>
                                <span class="bo-detail">They take @_hotUnits hot cargo unit@(_hotUnits == 1 ? "" : "s") + ~@_coinShare.ToString("N0") cr. Heat clears to 0.</span>
                            </button>
                            <button type="button" class="btn btn-info busted-opt" disabled="@(!_canBribe)" @onclick="BustedBribe">
                                <span class="bo-title">💰 BRIBE — @bust.Bribe.Total.ToString("N0") cr</span>
                                <span class="bo-detail">@bust.Bribe.Describe()@(_canBribe ? " · keep the cargo, heat unchanged" : " · you can't cover it")</span>
                            </button>
                            <button type="button" class="btn btn-danger busted-opt" @onclick="BustedResist">
                                <span class="bo-title">🔫 RESIST@(bust.Heat >= EncounterRule.MaxHeatLevel ? " — THE BOLIVIA" : "")</span>
                                <span class="bo-detail">@(bust.Heat >= EncounterRule.MaxHeatLevel
                                    ? "All guns blazing. A last stand on the dice — you fight clear, or you don't."
                                    : "One opposed roll. Win and they peel off; lose and it's a harsher cut.")@(_hasNetJammer ? " (jammer +2)" : "")</span>
                            </button>
                        </div>
                        break;

                    case BustedEncounter.Stage.Confiscated:
                        <div class="busted-hail">⛓ CONFISCATED</div>
                        @if (bust.Confiscation is { } conf)
                        {
                            <div class="busted-receipt">
                                @if (conf.CoinTaken > 0)
                                {
                                    <div>💰 −@conf.CoinTaken.ToString("N0") cr from the purse</div>
                                }
                                @foreach (BustedRule.CargoSeizure s in conf.Seizures)
                                {
                                    <div>@(s.Hot ? "🔥" : "📦") −@s.Units @s.CargoClass (@s.Value.ToString("N0") cr)@(s.Hot ? " — hot" : " — clean, minimum take")</div>
                                }
                                @if (conf.CoinTaken == 0 && conf.Seizures.Count == 0)
                                {
                                    <div>Nothing to take — you fly clean. They log it and cut you loose.</div>
                                }
                                <div class="busted-math">@string.Join(" · ", conf.Breakdown.Select(m => $"{m.Label}: {m.Value}"))</div>
                            </div>
                        }
                        <div class="busted-quote">"Debt collected. Heat's off the books — for now. Fly straight, captain."</div>
                        <button type="button" class="btn btn-outline-light busted-close" @onclick="CloseBusted">Take the hit</button>
                        break;

                    case BustedEncounter.Stage.BribedOff:
                    case BustedEncounter.Stage.ResistWon:
                    case BustedEncounter.Stage.Fled:
                        <div class="busted-hail">@(bust.Phase == BustedEncounter.Stage.Fled ? "🏴 BROKE CLEAR" : bust.Phase == BustedEncounter.Stage.ResistWon ? "🔫 THEY PEEL OFF" : "💰 PAID OFF")</div>
                        @if (bust.ResistRoll is { } rr)
                        {
                            <div class="busted-roll">You: @rr.Challenger.Describe()</div>
                            <div class="busted-roll">Collector: @rr.Defender.Describe()</div>
                        }
                        <div class="busted-quote">@bust.ResultMessage</div>
                        <button type="button" class="btn btn-outline-light busted-close" @onclick="CloseBusted">Fly on</button>
                        break;

                    case BustedEncounter.Stage.ResistLost:
                        <div class="busted-hail">🔫 THEY BOARD ANYWAY</div>
                        @if (bust.ResistRoll is { } rl)
                        {
                            <div class="busted-roll">You: @rl.Challenger.Describe()</div>
                            <div class="busted-roll">Collector: @rl.Defender.Describe()</div>
                        }
                        <div class="busted-quote">"Nice try. Now it costs extra." — they take the submission terms plus a harsher cut.</div>
                        <button type="button" class="btn btn-danger busted-close" @onclick="BustedResistLostConfirm">Brace for it</button>
                        break;

                    case BustedEncounter.Stage.Bolivia:
                        <div class="busted-hail">🔫 THE BOLIVIA — the last stand</div>
                        @if (bust.BoliviaInitiative is { } init)
                        {
                            <div class="busted-roll">Initiative — You: @init.Challenger.Total vs Collector: @init.Defender.Total</div>
                        }
                        @if (bust.BoliviaBeatIndex < BoliviaEncounter.Script.Count)
                        {
                            EncounterBeat beat = BoliviaEncounter.Script[bust.BoliviaBeatIndex];
                            <div class="busted-quote">@beat.Narration</div>
                            <div class="busted-options">
                                @foreach (EncounterChoice choice in beat.Choices)
                                {
                                    string cid = choice.Id;
                                    <button type="button" class="btn btn-outline-danger busted-opt" @onclick="() => BustedBoliviaChoose(cid)">
                                        <span class="bo-title">@choice.Label</span>
                                        <span class="bo-detail">@choice.Hint (@(choice.Modifier.Value >= 0 ? "+" : "−")@Math.Abs(choice.Modifier.Value))</span>
                                    </button>
                                }
                            </div>
                            @if (bust.BoliviaOutcomes.Count > 0)
                            {
                                <div class="busted-math">Running: net @bust.BoliviaNet — @(bust.BoliviaNet >= 0 ? "holding the line" : "going under")</div>
                            }
                        }
                        break;

                    case BustedEncounter.Stage.Impact:
                        @* #264: the surface collected the ship. Reuses the freeze-frame grammar (sepia
                           backdrop, one held beat) and hands off to the SAME brain-backup resurrection —
                           no collector, no dice; "impact coming" finally arrives. *@
                        <div class="busted-freeze">
                            <div class="busted-freeze-art busted-explosion" title="art: the ship folding into the surface at periapsis — the kerosene-explosion budget">
                                <span class="bf-flash">💥</span>
                            </div>
                            <div class="busted-freeze-caption">"…the periapsis said 'under the surface'. It wasn't bluffing."</div>
                            <div class="busted-quote">The hull meets @bust.ImpactBodyName at speed. No corridor, no atmosphere to catch you — just rock. The freeze-frame holds.</div>
                            <button type="button" class="btn btn-light busted-close" @onclick="BustedResurrect">…wake up</button>
                        </div>
                        break;

                    case BustedEncounter.Stage.FreezeFrame:
                        <div class="busted-freeze">
                            <div class="busted-freeze-art" title="art: two silhouetted rogues charging into blinding muzzle-flash light — homage, sepia freeze">
                                <span class="bf-silhouettes">🏴‍☠️🔫</span>
                                <span class="bf-flash">✷</span>
                            </div>
                            <div class="busted-freeze-caption">"…and here we thought this was the easy money."</div>
                            <div class="busted-quote">One massive volley. The freeze-frame holds. Sepia.</div>
                            <button type="button" class="btn btn-light busted-close" @onclick="BustedResurrect">…wake up</button>
                        </div>
                        break;

                    case BustedEncounter.Stage.Resurrected:
                        <div class="busted-hail">🧠 BRAIN-BACKUP RESTORED</div>
                        <div class="busted-freeze-art busted-explosion" title="art: the old ship blowing up — the kerosene-explosion budget">
                            <span class="bf-flash">💥</span>
                        </div>
                        <div class="busted-quote">
                            You wake at @bust.ClinicName's clinic in @bust.HullDescription. The old ship and
                            everything visible aboard is gone — but nothing buried or banked was ever on it.
                            The tank's at the mercy floor: enough to crawl to a pump, not a metre more.
                        </div>
                        <div class="busted-receipt">
                            <div>💰 @BustedRule.InsuranceCredits.ToString("N0") cr insurance stake</div>
                            <div>🏥 −@bust.ClinicBillCr.ToString("N0") cr clinic bill (the rebirth tax)</div>
                            <div>👛 @_credits.ToString("N0") cr in hand</div>
                            <div>⛽ @_reactionMassPulses p — the reach-a-pump reserve</div>
                            <div>🔧 all upgrades reset to starter grade</div>
                        </div>
                        <button type="button" class="btn btn-light busted-close" @onclick="CloseBusted">Board the rustbucket</button>
                        break;
                }
            </div>
        </div>
    }

    @* M28: the ship's parrot — a small perch visible on every desk, one squawk at a time. *@
    <div class="parrot-perch" aria-live="polite" title="the ship's parrot">
        @if (_parrotSquawk is not null)
        {
            <div class="parrot-bubble">@_parrotSquawk</div>
        }
        <span class="parrot-bird">🦜</span>
    </div>
</div>

@code {

    private void DrawPyramids()
    {
        for (int i = 0; i < AncientsRule.PyramidCount; i++)
        {
            if (!AncientsRule.Revealed(i, _ship.Position, SimTime))
            {
                continue;
            }

            Vector2d position = AncientsRule.PyramidPosition(i, SimTime);
            (float sx, float sy) = _camera.WorldToScreen(position);
            Span<float> triangle = stackalloc float[8];
            triangle[0] = sx; triangle[1] = sy - 6;
            triangle[2] = sx - 5; triangle[3] = sy + 4;
            triangle[4] = sx + 5; triangle[5] = sy + 4;
            triangle[6] = sx; triangle[7] = sy - 6;
            _renderer!.DrawPolyline(triangle, PyramidColor, 1.6f);
            _renderer.DrawText(sx + 8, sy - 6, "◬ ???", PyramidColor);
        }
    }

    private void DrawOrdnance()
    {
        foreach (OrdnanceState round in _ordnance)
        {
            if (round.Spent)
            {
                continue;
            }

            (float sx, float sy) = _camera.WorldToScreen(round.State.Position);
            _renderer!.DrawCircle(sx, sy, round.Round.Kind == OrdnanceKind.Missile ? 2.5f : 1.8f,
                OrdnanceColor, OrdnanceColor);
            // A short streak along the velocity so a round reads as MOVING at map zoom.
            Vector2d tail = round.State.Position - round.State.Velocity.Normalized() * (_camera.MetersPerPixel * 6);
            (float tx, float ty) = _camera.WorldToScreen(tail);
            Span<float> streak = stackalloc float[4];
            streak[0] = sx; streak[1] = sy; streak[2] = tx; streak[3] = ty;
            _renderer.DrawPolyline(streak, OrdnanceColor with { A = 120 }, 1f);
        }
    }
}
