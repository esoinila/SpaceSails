    private (Vector2d Position, Vector2d Velocity)? InterestTargetState()
    {
        if (_interestTargetId is null)
        {
            return null;
        }

        if (FindNpc(_interestTargetId) is { Active: true, Arrived: false } npc)
        {
            return (npc.State.Position, npc.State.Velocity);
