@page "/map"
@implements IDisposable
@inject HttpClient Http
@using SpaceSails.Client.Rendering
@using SpaceSails.Contracts
@using SpaceSails.Core

<PageTitle>SpaceSails — Map</PageTitle>

<div class="map-page">
    <canvas id="@CanvasId" class="map-canvas"
            @onwheel="OnWheel" @onwheel:preventDefault="true"
            @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove"
            @onpointerup="OnPointerUp" @onpointerleave="OnPointerUp">
    </canvas>

    <div class="map-hud">
        <div class="btn-toolbar bg-dark bg-opacity-75 rounded p-2 gap-2 align-items-center" role="toolbar" aria-label="Time warp controls">
            <div class="btn-group me-2" role="group" aria-label="Warp level">
                @foreach (int level in WarpLevels)
                {
                    <button type="button"
                            class="btn btn-sm @(!Paused && Warp == level ? "btn-primary" : "btn-outline-light")"
                            @onclick="() => SetWarp(level)">
                        @level&times;
                    </button>
                }
            </div>
            <button type="button" class="btn btn-sm @(Paused ? "btn-warning" : "btn-outline-light") me-2" @onclick="TogglePause">
                @(Paused ? "Resume" : "Pause")
            </button>
            <button type="button" class="btn btn-sm @(FollowShip ? "btn-info" : "btn-outline-light")" @onclick="ToggleFollow">
                Follow Ship
            </button>
        </div>

        <div class="map-readouts bg-dark bg-opacity-75 rounded p-2 mt-2 text-light small">
            <div>Sim time: @FormatSimTime(SimTime)</div>
            <div>Warp: @(Paused ? "paused" : $"{Warp}×")</div>
            <div>Zoom: @FormatZoom(_camera.MetersPerPixel)</div>
        </div>
    </div>
</div>

@code {
    private const string CanvasId = "map-canvas";
    private static readonly int[] WarpLevels = [1, 10, 100, 1000, 10000];

    private const int OrbitSegments = 128;
    private const int TrajectoryCount = 500;
    private const int TrajectoryPoints = 48;

    private static readonly RgbaColor Background = new(6, 9, 18);
    private static readonly RgbaColor OrbitColor = new(80, 100, 130, 130);
    private static readonly RgbaColor TrajectoryColor = new(60, 140, 170, 55);
    private static readonly RgbaColor ShipColor = new(255, 210, 80);
    private static readonly RgbaColor LabelColor = new(224, 228, 236);

    private readonly Camera _camera = new();
    private CanvasRenderer? _renderer;
    private ICelestialEphemeris? _ephemeris;
    private Vector2d[][] _dummyTrajectories = [];
    private float[] _scratch = [];
    private bool _started;

    private int _viewportWidth = 1280;
    private int _viewportHeight = 800;

    private double SimTime;
    private int Warp = 1;
    private bool Paused;
    private bool FollowShip;

    private double? _lastTimestampMs;
    private double _lastHudUpdateMs;
    private bool _dragging;
    private double _lastPointerX;
    private double _lastPointerY;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started)
        {
            return;
        }

        _started = true;

        string json = await Http.GetStringAsync("scenarios/sol.json");
        ScenarioDefinition scenario = ScenarioLoader.Parse(json);
        _ephemeris = CircularOrbitEphemeris.FromScenario(scenario);

        _dummyTrajectories = GenerateDummyTrajectories(TrajectoryCount, TrajectoryPoints);
        _scratch = new float[TrajectoryPoints * 2];

        _camera.MetersPerPixel = 1.2e10; // whole-system default: outer planets near the viewport edge.
        _camera.CenterOn(Vector2d.Zero);

        await RendererInterop.EnsureModuleLoadedAsync();

        _renderer = new CanvasRenderer(CanvasId);
        RendererInterop.FrameTick += OnTick;
        RendererInterop.CanvasResized += OnCanvasResized;

        RendererInterop.InitCanvas(CanvasId);
        RendererInterop.StartLoop(CanvasId);
    }

    private void OnCanvasResized(double widthPx, double heightPx)
    {
        if (widthPx <= 0 || heightPx <= 0)
        {
            return;
        }

        _viewportWidth = (int)Math.Round(widthPx);
        _viewportHeight = (int)Math.Round(heightPx);
    }

    private void OnTick(double highResTimestampMs)
    {
        if (_renderer is null || _ephemeris is null)
        {
            return;
        }

        double dtRealSeconds = _lastTimestampMs is null
            ? 0
            : Math.Max(0, (highResTimestampMs - _lastTimestampMs.Value) / 1000.0);
        _lastTimestampMs = highResTimestampMs;

        if (!Paused)
        {
            SimTime += dtRealSeconds * Warp;
        }

        Vector2d shipPosition = DummyShipPosition(SimTime);
        if (FollowShip)
        {
            _camera.CenterOn(shipPosition);
        }

        _camera.SetViewport(_viewportWidth, _viewportHeight);
        _renderer.BeginFrame(_viewportWidth, _viewportHeight, Background);

        DrawDummyTrajectories();
        DrawCelestialBodies();
        DrawShip(shipPosition);

        _renderer.EndFrame();

        // Redrawing the canvas happens every animation frame (the perf gate); re-rendering the
        // Bootstrap HUD text every frame would add Blazor diffing cost for no visible benefit, so
        // it's throttled to a few times a second instead.
        if (highResTimestampMs - _lastHudUpdateMs > 200)
        {
            _lastHudUpdateMs = highResTimestampMs;
            InvokeAsync(StateHasChanged);
        }
    }

    private void DrawDummyTrajectories()
    {
        foreach (Vector2d[] trajectory in _dummyTrajectories)
        {
            for (int i = 0; i < trajectory.Length; i++)
            {
                (float x, float y) = _camera.WorldToScreen(trajectory[i]);
                _scratch[i * 2] = x;
                _scratch[i * 2 + 1] = y;
            }

            _renderer!.DrawPolyline(_scratch.AsSpan(0, trajectory.Length * 2), TrajectoryColor);
        }
    }

    private void DrawCelestialBodies()
    {
        ICelestialEphemeris ephemeris = _ephemeris!;
        Span<float> ring = stackalloc float[(OrbitSegments + 1) * 2];

        foreach (CelestialBody body in ephemeris.Bodies)
        {
            if (body.OrbitPeriod != 0 && body.OrbitRadius > 0)
            {
                Vector2d parentPosition = body.ParentId is null ? Vector2d.Zero : ephemeris.Position(body.ParentId, SimTime);
                for (int i = 0; i <= OrbitSegments; i++)
                {
                    double angle = Math.Tau * i / OrbitSegments;
                    Vector2d world = parentPosition + new Vector2d(body.OrbitRadius * Math.Cos(angle), body.OrbitRadius * Math.Sin(angle));
                    (float x, float y) = _camera.WorldToScreen(world);
                    ring[i * 2] = x;
                    ring[i * 2 + 1] = y;
                }

                _renderer!.DrawPolyline(ring, OrbitColor);
            }

            Vector2d position = ephemeris.Position(body.Id, SimTime);
            (float sx, float sy) = _camera.WorldToScreen(position);
            float radiusPx = (float)Math.Max(2.0, body.BodyRadius / _camera.MetersPerPixel);
            RgbaColor color = BodyColor(body.Id);

            _renderer!.DrawCircle(sx, sy, radiusPx, color, color);
            _renderer!.DrawText(sx + radiusPx + 4, sy - radiusPx, body.Name, LabelColor);
        }
    }

    private void DrawShip(Vector2d shipPosition)
    {
        (float sx, float sy) = _camera.WorldToScreen(shipPosition);
        _renderer!.DrawCircle(sx, sy, 4f, ShipColor, ShipColor);
        _renderer!.DrawText(sx + 8, sy - 6, "Ship", ShipColor);
    }

    /// <summary>
    /// A dummy ship for the follow-toggle: a simple analytic circular orbit (no gravity
    /// integration) between Earth and Mars. Good enough for M2 per the spec — Simulator-driven
    /// ships arrive with the flight-plotting milestone.
    /// </summary>
    private static Vector2d DummyShipPosition(double simTime)
    {
        const double radius = 1.9e11;
        const double period = 4.6e7;
        double angle = 1.2 + Math.Tau * simTime / period;
        return new Vector2d(radius * Math.Cos(angle), radius * Math.Sin(angle));
    }

    /// <summary>
    /// 500 real multi-point polylines, generated once (deterministic — fixed seed) and redrawn
    /// every frame: the M2 perf gate. Sine-wobbled rings scattered across the system's radial span.
    /// </summary>
    private static Vector2d[][] GenerateDummyTrajectories(int count, int pointsPerLine)
    {
        var rng = new Random(20260702);
        var trajectories = new Vector2d[count][];

        for (int t = 0; t < count; t++)
        {
            double baseRadius = 3e10 + rng.NextDouble() * 4.4e12;
            double phase = rng.NextDouble() * Math.Tau;
            double wobbleAmplitude = baseRadius * (0.01 + rng.NextDouble() * 0.05);
            double wobbleFrequency = 3 + rng.NextDouble() * 9;

            var points = new Vector2d[pointsPerLine];
            for (int i = 0; i < pointsPerLine; i++)
            {
                double fraction = (double)i / (pointsPerLine - 1);
                double angle = phase + fraction * Math.Tau;
                double radius = baseRadius + wobbleAmplitude * Math.Sin(angle * wobbleFrequency);
                points[i] = new Vector2d(radius * Math.Cos(angle), radius * Math.Sin(angle));
            }

            trajectories[t] = points;
        }

        return trajectories;
    }

    private static RgbaColor BodyColor(string id) => id switch
    {
        "sun" => new RgbaColor(255, 214, 10),
        "mercury" => new RgbaColor(160, 160, 160),
        "venus" => new RgbaColor(230, 200, 140),
        "earth" => new RgbaColor(70, 130, 230),
        "mars" => new RgbaColor(210, 100, 60),
        "jupiter" => new RgbaColor(210, 170, 120),
        "saturn" => new RgbaColor(220, 200, 150),
        "uranus" => new RgbaColor(150, 220, 230),
        "neptune" => new RgbaColor(90, 110, 230),
        _ => new RgbaColor(200, 200, 200),
    };

    private static string FormatSimTime(double simTime)
    {
        TimeSpan span = TimeSpan.FromSeconds(Math.Clamp(simTime, 0, TimeSpan.MaxValue.TotalSeconds - 1));
        return $"{(int)span.TotalDays}d {span.Hours:00}h {span.Minutes:00}m";
    }

    private static string FormatZoom(double metersPerPixel)
    {
        const double metersPerAu = 1.495978707e11;
        return metersPerPixel >= metersPerAu / 100
            ? $"{metersPerPixel / metersPerAu:F4} AU/px"
            : $"{metersPerPixel:E2} m/px";
    }

    private void SetWarp(int level)
    {
        Warp = level;
        Paused = false;
    }

    private void TogglePause() => Paused = !Paused;

    private void ToggleFollow() => FollowShip = !FollowShip;

    private void OnWheel(WheelEventArgs e)
    {
        double factor = e.DeltaY > 0 ? 1.15 : 1 / 1.15;
        _camera.ZoomBy(factor, e.OffsetX, e.OffsetY);
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        _dragging = true;
        _lastPointerX = e.ClientX;
        _lastPointerY = e.ClientY;
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_dragging)
        {
            return;
        }

        double dx = e.ClientX - _lastPointerX;
        double dy = e.ClientY - _lastPointerY;
        _lastPointerX = e.ClientX;
        _lastPointerY = e.ClientY;

        _camera.PanByPixels(dx, dy);
        FollowShip = false; // manual pan disengages follow-ship, same as most space-game maps.
    }

    private void OnPointerUp(PointerEventArgs e) => _dragging = false;

    public void Dispose()
    {
        RendererInterop.FrameTick -= OnTick;
        RendererInterop.CanvasResized -= OnCanvasResized;

        if (_started)
        {
            RendererInterop.StopLoop(CanvasId);
        }
    }
}
