    // Written on a hub callback thread, read on the render-loop thread — volatile publishes the
    // reference safely; OnTick marshals it into fields (no per-update InvokeAsync).
    private volatile WorldUpdateDto? _latestUpdate;
    private WorldUpdateDto? _appliedUpdate;
