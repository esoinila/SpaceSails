@* The Galley desk (StationDesks.md #6, PR-11 v1): "sitting in the Galley fills the screen with
   galley stuff (news etc.) plus summaries of the rest" — the summaries are Map.razor's shared
   DeskChips strip, rendered on every desk; this component only owns the galley's own two things:
   the news wire stub and the rum locker. The rum locker is wired through OnPourRum to the exact
   same PourRum method the deck cantina console calls (Map.razor) — one rum ledger, two doors in.
   The full news/rumor economy (deterministic generator feeding both Comms and here) is PR-14;
   this is a pure, deterministic-by-sim-day flavor stub. *@

<div class="galley-desk text-light">
    <div class="galley-news">
        <div class="fw-bold mb-2">News wire 📰</div>
        <div class="galley-headline mb-2">@NewsLineFor(SimTime)</div>
        <div class="text-secondary small mb-3">
            Flavor only for now — the full news &amp; rumor economy (feeding this wire and the
            Comms desk together) arrives in PR-14. One deterministic headline per sim-day.
        </div>
        <div class="fw-bold mb-1 text-secondary small">Earlier on the wire</div>
        <ul class="list-unstyled galley-wire-list">
            @for (int daysAgo = 1; daysAgo <= 4; daysAgo++)
            {
                <li class="text-secondary small mb-1">@NewsLineFor(SimTime - daysAgo * SecondsPerDay)</li>
            }
        </ul>
    </div>
    <div class="galley-rum">
        <div class="fw-bold mb-2">The rum locker 🍹</div>
        <div class="mb-1">Tots poured: @RumTots</div>
        <div class="mb-2 @(WobbleActive ? "text-warning fw-bold" : "text-secondary")">
            @(WobbleActive ? "Deck's tilty — steady on. 🍹" : "Steady legs, for now.")
        </div>
        <button type="button" class="btn btn-sm btn-outline-warning w-100 mb-2" @onclick="() => OnPourRum.InvokeAsync()">
            Pour a tot
        </button>
        @if (LastRumLine is not null)
        {
            <div class="fst-italic text-info small">@LastRumLine</div>
        }
    </div>
</div>

@code {
    private const double SecondsPerDay = 86400.0;

    [Parameter, EditorRequired] public double SimTime { get; set; }
    [Parameter] public int RumTots { get; set; }
    [Parameter] public bool WobbleActive { get; set; }
    [Parameter] public string? LastRumLine { get; set; }
    [Parameter] public EventCallback OnPourRum { get; set; }

    // Deterministic flavor lines (pure function of sim-day, no randomness) referencing real
    // scenario names — He3/outer-reaches gossip in the spirit of worldbuilding-notes.md.
    private static readonly string[] NewsLines =
    [
        "Ringside Exchange reports a glut of He3 futures — Titan haulers grumble about margins.",
        "Word from the Mercury Compute Farms: a polar array went dark for six hours. Coincidence, surely.",
        "A masked freighter cleared customs at Ganymede without a manifest. Nobody asked twice.",
        "The Enceladus haven quietly doubled its docking fees. The regulars are not amused.",
        "Rumor: a captain out of the Belt is buying old mass-driver pods for scrap — or spares.",
        "Luna exchange prices for compute cores ticked up on 'security concerns' nobody will name.",
        "Saturn-side gossip: the He3 route past Ringside Exchange has a new toll collector.",
        "A trading post near the outer moons is paying premium for stale intel — no questions asked.",
        "The Titan haulers' union is 'reviewing' its timetable policy. Read: going quiet.",
        "Someone laser-ranged a pirate haven last week. The haven laser-ranged back.",
        "Mercury Compute Farms hiring 'discreet' couriers. Pay in credits, not questions.",
        "A quiet corner of the dark web is offering route intel at half price. Feels like bait.",
    ];

    private static string NewsLineFor(double simTime)
    {
        long day = (long)Math.Floor(simTime / SecondsPerDay);
        int index = (int)(((day % NewsLines.Length) + NewsLines.Length) % NewsLines.Length);
        return NewsLines[index];
    }
}
