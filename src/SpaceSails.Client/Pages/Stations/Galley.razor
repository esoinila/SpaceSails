@using SpaceSails.Core

@* The Galley desk (StationDesks.md #6, PR-11 v1 → PR-14 real wire): "sitting in the Galley fills
   the screen with galley stuff (news etc.) plus summaries of the rest" — the summaries are
   Map.razor's shared DeskChips strip, rendered on every desk; this component only owns the
   galley's own two things: the news wire and the rum locker. The rum locker is wired through
   OnPourRum to the exact same PourRum method the deck cantina console calls (Map.razor) — one rum
   ledger, two doors in. The news wire is now the real deal (Core/NewsWire.cs): Map.razor blends
   its bounded NewsEvent ledger with NewsWire.Ambient's rotating scenario flavor and hands this
   component the long feed, newest first — the Comms desk's ticker draws from the exact same
   Map.razor helper, just a shorter slice. *@

<div class="galley-desk text-light">
    <div class="galley-news">
        <div class="fw-bold mb-2">News wire 📰</div>
        @if (Feed.Count == 0)
        {
            <div class="text-secondary">No word from the wire today.</div>
        }
        else
        {
            <div class="galley-headline mb-2">@Feed[0].Headline</div>
            <div class="fw-bold mb-1 text-secondary small">Earlier on the wire</div>
            <ul class="list-unstyled galley-wire-list">
                @foreach (NewsWire.NewsItem item in Feed.Skip(1))
                {
                    <li class="text-secondary small mb-1"><span class="text-info">@DayLabel(item.SimTime)</span> — @item.Headline</li>
                }
            </ul>
        }
    </div>
    <div class="galley-rum">
        <div class="fw-bold mb-2">The rum locker 🍹</div>
        <div class="mb-1">Tots poured: @RumTots</div>
        <div class="mb-2 @(WobbleActive ? "text-warning fw-bold" : "text-secondary")">
            @(WobbleActive ? "Deck's tilty — steady on. 🍹" : "Steady legs, for now.")
        </div>
        <button type="button" class="btn btn-sm btn-outline-warning w-100 mb-2" @onclick="() => OnPourRum.InvokeAsync()">
            Pour a tot
        </button>
        @if (LastRumLine is not null)
        {
            <div class="fst-italic text-info small">@LastRumLine</div>
        }
    </div>
</div>

@code {
    private const double SecondsPerDay = 86400.0;

    [Parameter, EditorRequired] public double SimTime { get; set; }

    /// <summary>The blended news feed (player events + ambient flavor), newest first — built by
    /// Map.razor's NewsFeed helper so Comms and Galley always read from one source of truth.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<NewsWire.NewsItem> Feed { get; set; } = [];

    [Parameter] public int RumTots { get; set; }
    [Parameter] public bool WobbleActive { get; set; }
    [Parameter] public string? LastRumLine { get; set; }
    [Parameter] public EventCallback OnPourRum { get; set; }

    /// <summary>"today" / "yesterday" / "Nd ago", relative to the current sim-day — pure
    /// arithmetic, no wall-clock, matching the determinism rule the wire itself follows.</summary>
    private string DayLabel(double itemSimTime)
    {
        long today = (long)Math.Floor(SimTime / SecondsPerDay);
        long day = (long)Math.Floor(itemSimTime / SecondsPerDay);
        long delta = today - day;
        return delta <= 0 ? "today" : delta == 1 ? "yesterday" : $"{delta}d ago";
    }
}
