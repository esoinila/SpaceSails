@using SpaceSails.Core
@using SpaceSails.Client.Rendering
@implements IDisposable

@* The tracking post (worldbuilding notes §5; vision ¶12/¶14/¶16): aim the ship's telescope at a
   sky region, sweep it over sim time, and hold a ledger of found ships that don't advertise
   themselves. Entirely self-contained: Map.razor only ever passes it the shared clock/geometry
   and reads back the ledger for its own emphasis pass — no engine logic lives in Map.razor.

   PR-12 (the scope wall): the specialist position shows every tracked target live at once
   instead of one small inset — one ScopeView canvas per ledger slot (max 4), redrawn straight
   off SpaceSails.Client.Rendering.RendererInterop.FrameTick, the exact same global rAF-driven
   event Map.razor's own scope inset rides. No new timer, no new interop — just more canvases
   subscribed to the render loop that's already running. *@

<div class="tracking-post-card @(FullScreen ? "tracking-post-desk text-light" : "card bg-dark bg-opacity-75 text-light") @(Visible ? "" : "d-none")">
    <div class="card-header py-1 d-flex justify-content-between align-items-center gap-1">
        <span class="fw-bold small">Tracking post 📡</span>
        @if (FullScreen)
        {
            @* M27: the backdrop sun diagram is the live map — give the sensors chief its zoom. *@
            <div class="btn-group btn-group-sm" role="group" aria-label="Backdrop map zoom">
                <button type="button" class="btn btn-outline-light py-0" title="Zoom map out"
                        @onclick="() => OnZoomMap.InvokeAsync(1.6)">🔍−</button>
                <button type="button" class="btn btn-outline-light py-0" title="Zoom map in"
                        @onclick="() => OnZoomMap.InvokeAsync(1 / 1.6)">🔍+</button>
                <button type="button" class="btn btn-outline-light py-0" title="Center the ship"
                        @onclick="() => OnCenterShip.InvokeAsync()">⌖ ship</button>
            </div>
        }
        else
        {
            <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="() => OnClose.InvokeAsync()"></button>
        }
    </div>
    <div class="card-body p-2 small @(FullScreen ? "tracking-post-desk-body" : "")">
        <div class="d-flex gap-2 @(FullScreen ? "tracking-post-desk-top" : "")">
            <div class="tracking-rosette flex-shrink-0 @(FullScreen ? "tracking-rosette-big" : "")">
                <svg viewBox="0 0 200 200" class="tracking-rosette-svg" aria-label="Sun-relative detection range">
                    <polygon points="@RosettePolygonPoints()" class="tracking-rosette-envelope" />
                    <polygon points="@WedgePolygonPoints()" class="tracking-rosette-wedge @(_activeJob is not null ? "tracking-rosette-wedge-active" : "")" />
                    @* M27: bearing vectors from the ship to every tracked target — threats dashed red. *@
                    @foreach ((double x, double y, string color, bool threat) in TrackedTargetDots())
                    {
                        <line x1="100" y1="100" x2="@x" y2="@y"
                              class="@(threat ? "tracking-vector tracking-vector-threat" : "tracking-vector")"
                              stroke="@color" />
                    }
                    @foreach ((double x, double y, string color, bool threat) in TrackedTargetDots())
                    {
                        <circle cx="@x" cy="@y" r="@(threat ? 4 : 3)" fill="@color" />
                    }
                    @* M27: the prograde arrow — which way the ship is actually flying. *@
                    @if (ProgradePoint() is { } fwd)
                    {
                        <line x1="100" y1="100" x2="@fwd.X" y2="@fwd.Y" class="tracking-prograde-line" />
                        <circle cx="@fwd.X" cy="@fwd.Y" r="2.5" class="tracking-prograde-tip" />
                    }
                    <line x1="100" y1="100" x2="100" y2="14" class="tracking-rosette-sunline" />
                    <text x="100" y="10" class="tracking-rosette-label" text-anchor="middle">☉</text>
                    <circle cx="100" cy="100" r="4" class="tracking-rosette-ship" />
                </svg>
                <div class="text-secondary tracking-heading-line">@HeadingLine()</div>
            </div>
            <div class="flex-grow-1">
                <label class="form-label mb-0 d-block">Bearing @((int)_centerBearingDeg)°</label>
                <input type="range" class="form-range" min="0" max="359" step="1" value="@_centerBearingDeg"
                       @oninput="OnBearingInput" @onkeydown:stopPropagation="true" />
                <label class="form-label mb-0 d-block">Arc width @((int)_arcWidthDeg)°</label>
                <input type="range" class="form-range" min="5" max="360" step="1" value="@_arcWidthDeg"
                       @oninput="OnArcInput" @onkeydown:stopPropagation="true" />
                <select class="form-select form-select-sm mb-1" @onchange="OnProgramSelected">
                    <option value="">— manual aim —</option>
                    @for (int i = 0; i < _programs.Count; i++)
                    {
                        <option value="@i">@_programs[i].Name</option>
                    }
                </select>
                @if (_activeJob is null)
                {
                    <button type="button" class="btn btn-sm btn-info w-100" @onclick="StartSweep">Start sweep</button>
                }
                else
                {
                    <button type="button" class="btn btn-sm btn-outline-warning w-100" @onclick="StopSweep">Stop sweep</button>
                }
                @* M27: the eyes are open by default — a passive watch keeps a full-circle sweep
                   running whenever nothing manual is queued. *@
                <button type="button" class="btn btn-sm w-100 mt-1 @(_passiveWatch ? "btn-success" : "btn-outline-secondary")"
                        @onclick="TogglePassiveWatch">
                    👁 Passive watch: @(_passiveWatch ? "ON — always scanning" : "off")
                </button>
                <button type="button" class="btn btn-sm w-100 mt-1 @(RadarActive ? "btn-danger" : "btn-outline-danger")"
                        @onclick="() => OnRadarToggle.InvokeAsync(!RadarActive)">
                    📡 @(RadarActive ? "ACTIVE RADAR ON — LOUD" : "Active radar (close range — loud)")
                </button>
            </div>
        </div>

        @if (FullScreen && Opportunities.Count > 0)
        {
            @* M29: the cover-story instrument — what the CURRENT plotted course conveniently
               brushes by. Fly somewhere innocent; the sensors quietly note who drifts close. *@
            <div class="sensors-opportunity-box mt-2">
                <div class="fw-bold">🧭 En-route passes — this course brushes by:</div>
                @foreach (CourseOpportunity opp in Opportunities)
                {
                    <div class="d-flex justify-content-between align-items-center">
                        <span>@(opp.Tracked ? "📡 " : "")@opp.Callsign</span>
                        <span class="text-secondary">min @FormatWallDistance(opp.MinDistance) @FormatOppDuration(opp.MinSimTime - SimTime)</span>
                        <button type="button" class="btn btn-sm btn-outline-info py-0 px-1"
                                title="War-room target of interest — intercept clock & firing solutions"
                                @onclick="() => OnSetInterest.InvokeAsync(opp.Id)">🎯</button>
                    </div>
                }
            </div>
        }

        @if (FullScreen && RadarActive)
        {
            <div class="sensors-radar-box mt-2">
                <div class="fw-bold text-danger">📡 Radar returns — exact fixes inside @FormatWallDistance(RadarRule.RangeMeters); every ship in earshot now knows where we are.</div>
                @{ List<TrackingCandidate> returns = RadarReturns(); }
                @if (returns.Count == 0)
                {
                    <div class="text-secondary">No returns — nothing inside radar range.</div>
                }
                else
                {
                    @foreach (TrackingCandidate c in returns)
                    {
                        double rd = (c.State.Position - ShipPosition).Length;
                        double rv = (c.State.Velocity - ShipVelocity).Length;
                        <div class="d-flex justify-content-between">
                            <span>@(c.IsThreat ? "🐺 " : "")@c.Callsign</span>
                            <span class="text-secondary">@FormatWallDistance(rd) · rel @((rv / 1000).ToString("F2")) km/s</span>
                        </div>
                    }
                }
            </div>
        }

        @if (_activeJob is not null)
        {
            <div class="progress tracking-progress mt-2" role="progressbar" aria-label="Sweep progress">
                <div class="progress-bar bg-info" style="width:@(SweepProgressPercent.ToString("F0"))%"></div>
            </div>
        }
        @if (_lastSweepMessage is not null)
        {
            <div class="text-secondary mt-1">@_lastSweepMessage</div>
        }

        <hr class="my-2" />

        @if (FullScreen)
        {
            @* M27: one LIVE telescope that cycles through the ledger (owner: "not all of them
               would be live viewed but it would cycle between them"), beside a card per track
               carrying the full nav-grade picture: range, closing, bearing, and the eyes race —
               who sees whom first, our own signature included. Click a card to pin the scope. *@
            <div class="fw-bold mb-1">Tracked targets (@_ledger.Entries.Count / @_ledger.MaxTracks)</div>
            <div class="sensors-main">
                <div class="sensors-live flex-shrink-0">
                    <canvas id="@LiveCanvasId" class="scope-wall-canvas"></canvas>
                    <div class="text-secondary sensors-live-caption">
                        @(_pinnedLiveId is not null ? "pinned — click the card again to resume cycling" : "cycling the ledger every 6 s")
                    </div>
                </div>
                <div class="sensors-cards flex-grow-1">
                    @{
                        List<TrackedTarget> orderedCards = OrderedTracks();
                        string? liveId = CurrentLiveId(orderedCards);
                    }
                    @if (orderedCards.Count == 0)
                    {
                        <div class="text-secondary">Ledger empty — the passive watch is scanning; contacts appear here as the sweep finds them.</div>
                    }
                    @foreach (TrackedTarget entry in orderedCards)
                    {
                        TrackingCandidate? candidate = FindCandidate(entry.ShipId);
                        double quality = entry.EffectiveQuality(SimTime);
                        double daysAgo = (SimTime - entry.LastConfirmedTime) / 86400.0;
                        Vector2d position = candidate?.State.Position ?? entry.LastObservation.Position;
                        Vector2d velocity = candidate?.State.Velocity ?? entry.LastObservation.Velocity;
                        double distance = (position - ShipPosition).Length;
                        double relSpeed = (velocity - ShipVelocity).Length;
                        double closing = distance > 0 ? (ShipVelocity - velocity).Dot((position - ShipPosition) / distance) : 0;
                        double bearingDeg = TrackingStation.Bearing(position - ShipPosition) * 180.0 / Math.PI;
                        if (bearingDeg < 0) { bearingDeg += 360; }
                        bool isThreat = candidate?.IsThreat ?? false;
                        bool isLive = entry.ShipId == liveId;
                        SightAdvantage sight = SensorModel.Default.Advantage(
                            new ShipState(ShipPosition, ShipVelocity, SimTime, ShipCharge),
                            new ShipState(position, velocity, SimTime));
                        <div class="sensor-card @(isLive ? "sensor-card-live" : "") @(isThreat ? "sensor-card-threat" : "")"
                             role="button" tabindex="0" @onclick="() => PinLive(entry.ShipId)">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">@(isThreat ? "🐺 " : "")@(candidate?.Callsign ?? entry.ShipId)@(_aware.Contains(entry.ShipId) ? " · aware ⚠" : "")</span>
                                <span>@(isLive ? "● LIVE" : "")</span>
                            </div>
                            <div>@FormatWallDistance(distance) · rel @((relSpeed / 1000).ToString("F2")) km/s ·
                                 @(closing >= 0 ? $"closing {closing / 1000:F2}" : $"opening {-closing / 1000:F2}") km/s</div>
                            <div class="text-secondary">brg @((int)bearingDeg)° · @daysAgo.ToString("F1")d since fix@(candidate?.CargoDetail is { } cd ? $" · {cd}" : "")</div>
                            <div class="@(sight.TheySeeUs ? "text-warning" : "text-info")">@SightLine(sight)</div>
                            <div class="tracking-quality-bar"><div class="tracking-quality-fill" style="width:@((int)(quality * 100))%"></div></div>
                            <div class="d-flex justify-content-end gap-1 mt-1">
                                <button type="button" class="btn btn-sm btn-outline-info py-0 px-1"
                                        title="War-room target of interest — a DIFFERENT slot than the nav destination"
                                        @onclick="() => OnSetInterest.InvokeAsync(entry.ShipId)" @onclick:stopPropagation="true">🎯</button>
                                <button type="button" class="btn btn-sm btn-outline-info py-0 px-1" disabled="@(candidate is null)"
                                        @onclick="() => ConfirmNow(entry.ShipId)" @onclick:stopPropagation="true">Confirm</button>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1"
                                        @onclick="() => Drop(entry.ShipId)" @onclick:stopPropagation="true">Drop</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="fw-bold mb-1">Tracked targets (@_ledger.Entries.Count / @_ledger.MaxTracks)</div>
            @if (_ledger.Entries.Count == 0)
            {
                <div class="text-secondary">Nothing on the ledger yet — sweep a region to find contacts.</div>
            }
            else
            {
                <table class="table table-sm table-dark mb-0">
                    <tbody>
                        @foreach (TrackedTarget entry in OrderedTracks())
                        {
                            double quality = entry.EffectiveQuality(SimTime);
                            double daysAgo = (SimTime - entry.LastConfirmedTime) / 86400.0;
                            TrackingCandidate? candidate = FindCandidate(entry.ShipId);
                            <tr>
                                <td>
                                    @(candidate?.Callsign ?? entry.ShipId)@(_aware.Contains(entry.ShipId) ? " aware ⚠" : "")
                                    <div class="tracking-quality-bar"><div class="tracking-quality-fill" style="width:@((int)(quality * 100))%"></div></div>
                                </td>
                                <td class="text-end align-middle">@daysAgo.ToString("F1")d</td>
                                <td class="text-end align-middle text-nowrap">
                                    <button type="button" class="btn btn-sm btn-outline-info py-0 px-1" disabled="@(candidate is null)"
                                            @onclick="() => ConfirmNow(entry.ShipId)">Confirm</button>
                                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => Drop(entry.ShipId)">Drop</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</div>

@code {
    /// <summary>A candidate ship the tracking post can sweep for — a thin projection of
    /// Map.razor's own NPC state so this component never needs to know its private type.
    /// <see cref="IsPod"/>/<see cref="CargoDetail"/> (PR-12) let the scope wall draw the right
    /// silhouette and detail line for a tracked target, same as Map.razor's own scope inset.</summary>
    public readonly record struct TrackingCandidate(string Id, string Callsign, ShipState State, bool IsPod = false, string? CargoDetail = null, bool IsThreat = false);

    /// <summary>M29: a known contact whose predicted coast the plotted course passes near —
    /// the target-of-opportunity row (the cover-story seed: fly an innocent course, watch who
    /// drifts conveniently close along it).</summary>
    public readonly record struct CourseOpportunity(
        string Id, string Callsign, double MinDistance, double MinSimTime, bool Tracked);

    [Parameter, EditorRequired] public double SimTime { get; set; }
    [Parameter, EditorRequired] public Vector2d ShipPosition { get; set; }
    [Parameter, EditorRequired] public Vector2d ShipVelocity { get; set; }
    [Parameter] public double ShipCharge { get; set; }
    [Parameter] public ICelestialEphemeris? Ephemeris { get; set; }
    [Parameter] public IReadOnlyList<TrackingCandidate> Candidates { get; set; } = [];
    [Parameter] public int MaxTracks { get; set; } = 1;
    [Parameter] public bool Visible { get; set; }
    [Parameter] public bool FullScreen { get; set; }
    [Parameter] public bool RadarActive { get; set; }
    [Parameter] public IReadOnlyList<CourseOpportunity> Opportunities { get; set; } = [];
    [Parameter] public EventCallback<string> OnSetInterest { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnRadarToggle { get; set; }
    [Parameter] public EventCallback<double> OnZoomMap { get; set; }
    [Parameter] public EventCallback OnCenterShip { get; set; }

    private const double RosetteCenterPx = 100;
    private const double RosetteMaxRadiusPx = 82;
    private const int RosetteSteps = 48;

    // M27: ONE live telescope tile cycling the ledger (was PR-12's wall of four) — drawn off
    // the same shared render loop as Map.razor's scope inset.
    private const int WallTileSizePx = 280;
    private const double LiveCycleMs = 6000;
    private static readonly RgbaColor WallTargetColor = new(200, 120, 255); // mirrors Map.razor's NpcColor
    private static readonly ScopeView.Target EmptyWallTarget =
        new(ScopeView.TargetKind.None, "", null, Vector2d.Zero, Vector2d.Zero, 0, default, false);

    private ScopeView? _liveScope;
    private bool _wallFrameTickSubscribed;
    private int _liveIndex;
    private double _lastCycleMs;
    private string? _pinnedLiveId;

    // M27: the passive watch — the eyes are open by default. Whenever no sweep is running (and
    // the player hasn't switched the watch off), a full-circle survey starts by itself.
    private bool _passiveWatch = true;
    private bool _passiveJobRunning;

    private readonly TelescopeModel _telescope = new();
    private readonly TrackedTargetLedger _ledger = new();

    // PR-6 (dark space web): ships the player has laser-ranged. Purely a UI-side warning flag —
    // Core's ledger doesn't need to know about it (PR-7 will consume "aware" for real).
    private readonly HashSet<string> _aware = new();

    private double _centerBearingDeg;
    private double _arcWidthDeg = 30;
    private ScanJob? _activeJob;
    private double _sweepStartSimTime;
    private double _lastSimTime;
    private bool _hasLastSimTime;
    private string? _lastSweepMessage;
    private IReadOnlyList<ScanProgram> _programs = [];
    private double _programsBuiltAtSimTime = double.NegativeInfinity;
    private string? _lastProgramName;

    /// <summary>The Sensors chip's objective line (addendum, 2026-07-04 evening): what we're
    /// looking for right now, not raw stats — a sweep in progress, else the best-quality track,
    /// else nothing set.</summary>
    public string ObjectiveSummary(double simTime)
    {
        if (RadarActive)
        {
            return "RADAR ACTIVE — loud";
        }

        string? callsign = BestTrackCallsign(simTime);
        if (callsign is not null)
        {
            return $"Tracking {callsign}";
        }

        if (_activeJob is not null)
        {
            return _passiveJobRunning ? "Passive watch — scanning" : $"Sweeping {_lastProgramName ?? "custom region"}";
        }

        return "No watch set";
    }

    private string? BestTrackCallsign(double simTime)
    {
        TrackedTarget? best = null;
        double bestQuality = -1;
        foreach (TrackedTarget entry in _ledger.Entries)
        {
            double quality = entry.EffectiveQuality(simTime);
            if (quality > bestQuality)
            {
                bestQuality = quality;
                best = entry;
            }
        }

        if (best is not { } target)
        {
            return null;
        }

        return FindCandidate(target.ShipId)?.Callsign ?? target.ShipId;
    }

    /// <summary>Exposed so Map.razor's NPC-draw pass can key emphasis and the tightened
    /// prediction cone off the ledger without either side reaching into the other's internals.</summary>
    public bool TryGetTrack(string shipId, out TrackedTarget track) => _ledger.TryGet(shipId, out track);

    /// <summary>Read-only view of every current track (PR-6: the dark web sells these).</summary>
    public IReadOnlyCollection<TrackedTarget> Entries => _ledger.Entries;

    /// <summary>
    /// Injects a confirmed observation from outside the sweep/confirm loop (PR-6: laser ranging).
    /// Reuses the exact same reconfirm path a passive sweep hit takes, so the prediction cone
    /// tightens through the one code path everything else already goes through — a perfect,
    /// zero-age observation resets the elapsed-time term PathPredictor grows its cone from.
    /// </summary>
    public bool ApplyObservation(Observation observation) => _ledger.Add(observation);

    /// <summary>Flags a target as aware it's been actively pinged (PR-6: laser ranging gives away
    /// your position). UI-only bookkeeping — see <see cref="_aware"/>.</summary>
    public void MarkAware(string shipId) => _aware.Add(shipId);

    protected override void OnParametersSet()
    {
        _ledger.MaxTracks = Math.Max(1, MaxTracks);

        bool timeAdvanced = _hasLastSimTime && SimTime > _lastSimTime;
        _lastSimTime = SimTime;
        _hasLastSimTime = true;

        // Corridor programs are a pure function of (bodies, ship position, time) — cheap to
        // recompute, but there's no reason to redo it every render tick either.
        if (Ephemeris is not null && SimTime - _programsBuiltAtSimTime > 3600)
        {
            _programs = ScanPrograms.BuildPrograms(Ephemeris, ShipPosition, SimTime);
            _programsBuiltAtSimTime = SimTime;
        }

        if (timeAdvanced && _activeJob is { } job)
        {
            double elapsed = SimTime - _sweepStartSimTime;
            if (elapsed >= job.DurationSeconds)
            {
                CompleteSweep(job);
            }
        }

        // M27: the passive watch — restart the full-circle survey whenever the post is idle.
        if (_passiveWatch && _activeJob is null)
        {
            _activeJob = new ScanJob(0, Math.Tau);
            _sweepStartSimTime = SimTime;
            _passiveJobRunning = true;
        }

        _ledger.AdvanceTime(SimTime);
    }

    // ---- The live telescope (M27, replaces PR-12's wall of tiles) ----

    private const string LiveCanvasId = "scope-live";

    /// <summary>Ledger entries sorted best-quality-first — stable card order.</summary>
    private List<TrackedTarget> OrderedTracks() =>
        _ledger.Entries.OrderByDescending(e => e.EffectiveQuality(SimTime)).ToList();

    /// <summary>Which track the live telescope is on: the pinned one if set and still on the
    /// ledger, else the cycling index.</summary>
    private string? CurrentLiveId(List<TrackedTarget> ordered)
    {
        if (ordered.Count == 0)
        {
            return null;
        }

        if (_pinnedLiveId is not null && ordered.Any(e => e.ShipId == _pinnedLiveId))
        {
            return _pinnedLiveId;
        }

        return ordered[_liveIndex % ordered.Count].ShipId;
    }

    private void PinLive(string shipId) =>
        _pinnedLiveId = _pinnedLiveId == shipId ? null : shipId;

    private void TogglePassiveWatch()
    {
        _passiveWatch = !_passiveWatch;
        if (!_passiveWatch && _passiveJobRunning)
        {
            _activeJob = null;
            _passiveJobRunning = false;
        }
    }

    private List<TrackingCandidate> RadarReturns()
    {
        var list = new List<TrackingCandidate>();
        foreach (TrackingCandidate c in Candidates)
        {
            if (RadarRule.InRange(ShipPosition, c.State.Position))
            {
                list.Add(c);
            }
        }

        list.Sort((a, b) => (a.State.Position - ShipPosition).LengthSquared
            .CompareTo((b.State.Position - ShipPosition).LengthSquared));
        return list;
    }

    private static string SightLine(SightAdvantage s) =>
        s.WeSeeThem && s.TheySeeUs ? "👁 mutual — both inside detection"
        : s.TheySeeUs ? "⚠ THEY see us — we're the loud one"
        : s.WeSeeThem ? "👁 we see them — they're blind to us"
        : s.Edge >= 0 ? $"eyes race: we'd spot them first (+{FormatWallDistance(s.Edge)})"
        : $"eyes race: they'd spot us first ({FormatWallDistance(-s.Edge)} edge)";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!FullScreen || _liveScope is not null)
        {
            return;
        }

        await RendererInterop.EnsureModuleLoadedAsync();
        // observeResize:false — CRITICAL (same note as Map.razor's own scope inset): a
        // resize-observing tile canvas would report its own small size back as the map
        // viewport and shrink it.
        RendererInterop.InitCanvas(LiveCanvasId, observeResize: false);
        _liveScope = new ScopeView(new CanvasRenderer(LiveCanvasId));

        if (!_wallFrameTickSubscribed)
        {
            _wallFrameTickSubscribed = true;
            RendererInterop.FrameTick += OnWallFrameTick;
        }
    }

    /// <summary>Redraws the live tile once per animation frame and advances the cycle — riding
    /// the same global <see cref="RendererInterop.FrameTick"/> event Map.razor's scope inset
    /// uses, so it stays live at full frame rate independent of Blazor's HUD render throttle.</summary>
    private void OnWallFrameTick(double highResTimestampMs)
    {
        if (!FullScreen || !Visible || _liveScope is null)
        {
            return;
        }

        List<TrackedTarget> ordered = OrderedTracks();
        if (_pinnedLiveId is null && highResTimestampMs - _lastCycleMs > LiveCycleMs)
        {
            _lastCycleMs = highResTimestampMs;
            _liveIndex++;
        }

        string? liveId = CurrentLiveId(ordered);
        ScopeView.Target target = EmptyWallTarget;
        if (liveId is not null)
        {
            foreach (TrackedTarget entry in ordered)
            {
                if (entry.ShipId == liveId)
                {
                    target = BuildWallTarget(entry);
                    break;
                }
            }
        }

        _liveScope.Draw(WallTileSizePx, SimTime, ShipPosition, ShipVelocity, target);
    }

    private ScopeView.Target BuildWallTarget(TrackedTarget entry)
    {
        TrackingCandidate? candidate = FindCandidate(entry.ShipId);
        Vector2d position = candidate?.State.Position ?? entry.LastObservation.Position;
        Vector2d velocity = candidate?.State.Velocity ?? entry.LastObservation.Velocity;
        bool isPod = candidate?.IsPod ?? false;
        string name = candidate?.Callsign ?? entry.ShipId;

        return new ScopeView.Target(
            isPod ? ScopeView.TargetKind.Pod : ScopeView.TargetKind.Freighter,
            name, candidate?.CargoDetail, position, velocity, 0, WallTargetColor, false);
    }

    private static string FormatOppDuration(double seconds) =>
        seconds < 3600 ? "now" : seconds < 86400 ? $"in {seconds / 3600:F0} h" : $"in {seconds / 86400:F0} d";

    private static string FormatWallDistance(double meters)
    {
        const double au = 1.495978707e11;
        if (meters >= au / 10) return $"{meters / au:F2} AU";
        if (meters >= 1e9) return $"{meters / 1e9:F1} M km";
        return $"{meters / 1000:N0} km";
    }

    public void Dispose()
    {
        if (_wallFrameTickSubscribed)
        {
            RendererInterop.FrameTick -= OnWallFrameTick;
            _wallFrameTickSubscribed = false;
        }
    }

    // ---- Sweep controls ----

    private double SweepProgressPercent
    {
        get
        {
            if (_activeJob is not { } job || job.DurationSeconds <= 0)
            {
                return 0;
            }

            double elapsed = SimTime - _sweepStartSimTime;
            return Math.Clamp(elapsed / job.DurationSeconds * 100.0, 0, 100);
        }
    }

    private void OnBearingInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double v))
        {
            _centerBearingDeg = v;
        }
    }

    private void OnArcInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double v))
        {
            _arcWidthDeg = v;
        }
    }

    private void OnProgramSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int index) && index >= 0 && index < _programs.Count)
        {
            ScanJob job = _programs[index].Job;
            double deg = job.CenterBearingRad * 180.0 / Math.PI;
            if (deg < 0)
            {
                deg += 360;
            }

            _centerBearingDeg = deg;
            _arcWidthDeg = Math.Clamp(job.ArcWidthRad * 180.0 / Math.PI, 5, 360);
            _lastProgramName = _programs[index].Name;
        }
    }

    private void StartSweep()
    {
        double bearingRad = _centerBearingDeg * Math.PI / 180.0;
        double arcRad = Math.Clamp(_arcWidthDeg, 1, 360) * Math.PI / 180.0;
        _activeJob = new ScanJob(bearingRad, arcRad);
        _sweepStartSimTime = SimTime;
        _passiveJobRunning = false; // a manual sweep takes the instrument
        _lastSweepMessage = "Sweeping…";
    }

    private void StopSweep()
    {
        if (_passiveJobRunning)
        {
            // Stopping the watch itself — otherwise it would just restart next tick.
            _passiveWatch = false;
            _passiveJobRunning = false;
            _lastSweepMessage = "Passive watch stood down";
        }
        else
        {
            _lastSweepMessage = "Sweep aborted";
        }

        _activeJob = null;
    }

    private void CompleteSweep(ScanJob job)
    {
        bool wasPassive = _passiveJobRunning;
        _activeJob = null;
        _passiveJobRunning = false;
        IEnumerable<(string Id, ShipState State)> candidates = Candidates.Select(c => (c.Id, c.State));
        IReadOnlyList<Observation> found = TrackingStation.Sweep(_telescope, job, ShipPosition, candidates, SimTime);

        int added = 0, refused = 0;
        foreach (Observation obs in found)
        {
            if (_ledger.Add(obs))
            {
                added++;
            }
            else
            {
                refused++;
            }
        }

        // The passive watch stays quiet unless it actually found something new.
        _lastSweepMessage = found.Count == 0
            ? wasPassive ? _lastSweepMessage : "Sweep complete — nothing found"
            : refused > 0
                ? $"{(wasPassive ? "Passive watch" : "Sweep complete")} — {added} tracked, {refused} slipped (telescopes full)"
                : $"{(wasPassive ? "Passive watch" : "Sweep complete")} — {added} contact(s) found";
    }

    private TrackingCandidate? FindCandidate(string id)
    {
        foreach (TrackingCandidate c in Candidates)
        {
            if (c.Id == id)
            {
                return c;
            }
        }

        return null;
    }

    private void ConfirmNow(string shipId)
    {
        if (Ephemeris is null)
        {
            return;
        }

        TrackingCandidate? candidate = FindCandidate(shipId);
        if (candidate is null)
        {
            _lastSweepMessage = "Can't confirm — contact isn't in range of the sim right now";
            return;
        }

        bool ok = _ledger.TryConfirm(shipId, Ephemeris, _telescope, ShipPosition, candidate.Value.State, SimTime);
        _lastSweepMessage = ok
            ? $"Reconfirmed {candidate.Value.Callsign}"
            : $"Lost the fix on {candidate.Value.Callsign} — try a fresh sweep";
    }

    private void Drop(string shipId) => _ledger.Drop(shipId);

    // ---- Rosette (SVG) ----

    // The envelope is drawn in a LOCAL frame where angle 0 = straight up = sunward (worst range)
    // and angle π = straight down = anti-sunward (best range) — the "sun-direction egg" from the
    // worldbuilding notes. Reusing TelescopeModel.Range itself (rather than re-deriving the
    // formula here) means the picture can never drift from what the sweep logic actually does:
    // a synthetic ship position on +X has its sunward direction dead on -X, so sampling look
    // directions around that circle traces exactly the same envelope Range() would compute for
    // any real ship, just re-expressed in sun-relative angle instead of world bearing.
    private double EnvelopeFraction(double localAngleRad)
    {
        var syntheticShip = new Vector2d(1, 0);
        var lookDir = new Vector2d(-Math.Cos(localAngleRad), Math.Sin(localAngleRad));
        return _telescope.Range(syntheticShip, lookDir) / _telescope.BaseRange;
    }

    private double SunwardBearingRad => TrackingStation.Bearing(Vector2d.Zero - ShipPosition);

    /// <summary>World bearing converted into the rosette's sun-relative local angle.</summary>
    private double ToLocalAngle(double worldBearingRad)
    {
        double diff = (worldBearingRad - SunwardBearingRad) % Math.Tau;
        if (diff < 0)
        {
            diff += Math.Tau;
        }

        return diff;
    }

    private (double X, double Y) RosettePoint(double localAngleRad, double radiusFraction)
    {
        double a = localAngleRad - Math.PI / 2; // 0 => straight up on screen
        double r = radiusFraction * RosetteMaxRadiusPx;
        return (RosetteCenterPx + r * Math.Cos(a), RosetteCenterPx + r * Math.Sin(a));
    }

    private string RosettePolygonPoints()
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i <= RosetteSteps; i++)
        {
            double localAngle = Math.Tau * i / RosetteSteps;
            (double x, double y) = RosettePoint(localAngle, EnvelopeFraction(localAngle));
            sb.Append(x.ToString("F1")).Append(',').Append(y.ToString("F1")).Append(' ');
        }

        return sb.ToString();
    }

    private string WedgePolygonPoints()
    {
        double bearingDeg = _activeJob?.CenterBearingRad * 180.0 / Math.PI ?? _centerBearingDeg;
        double arcDeg = _activeJob?.ArcWidthRad * 180.0 / Math.PI ?? _arcWidthDeg;
        double bearingRad = _activeJob?.CenterBearingRad ?? bearingDeg * Math.PI / 180.0;
        double halfArc = (arcDeg * Math.PI / 180.0) / 2;

        double centerLocal = ToLocalAngle(bearingRad);

        var sb = new System.Text.StringBuilder();
        sb.Append(RosetteCenterPx.ToString("F1")).Append(',').Append(RosetteCenterPx.ToString("F1")).Append(' ');
        const int wedgeSteps = 16;
        for (int i = 0; i <= wedgeSteps; i++)
        {
            double localAngle = centerLocal - halfArc + (2 * halfArc) * i / wedgeSteps;
            (double x, double y) = RosettePoint(localAngle, EnvelopeFraction(localAngle));
            sb.Append(x.ToString("F1")).Append(',').Append(y.ToString("F1")).Append(' ');
        }

        return sb.ToString();
    }

    private IEnumerable<(double X, double Y, string Color, bool Threat)> TrackedTargetDots()
    {
        foreach (TrackedTarget entry in _ledger.Entries)
        {
            TrackingCandidate? candidate = FindCandidate(entry.ShipId);
            Vector2d position = candidate?.State.Position ?? entry.LastObservation.Position;
            Vector2d toTarget = position - ShipPosition;
            if (toTarget.LengthSquared == 0)
            {
                continue;
            }

            double bearing = TrackingStation.Bearing(toTarget);
            double localAngle = ToLocalAngle(bearing);
            double range = _telescope.Range(ShipPosition, toTarget);
            double fraction = range > 0 ? Math.Clamp(toTarget.Length / range, 0, 1) : 1;
            (double x, double y) = RosettePoint(localAngle, fraction);

            bool threat = candidate?.IsThreat ?? false;
            double quality = entry.EffectiveQuality(SimTime);
            string color = threat ? "#ff5a5a" : quality > 0.5 ? "#7dffb0" : quality > 0.2 ? "#ffd27d" : "#ff8d7d";
            yield return (x, y, color, threat);
        }
    }

    // M27: the prograde arrow — where the ship's nose actually points on the rosette.
    private (double X, double Y)? ProgradePoint()
    {
        if (ShipVelocity.LengthSquared == 0)
        {
            return null;
        }

        double localAngle = ToLocalAngle(TrackingStation.Bearing(ShipVelocity));
        return RosettePoint(localAngle, 0.55);
    }

    // M27: are we looking ahead or astern? The scope aim vs the velocity vector, in words.
    private string HeadingLine()
    {
        if (ShipVelocity.LengthSquared == 0)
        {
            return $"scope {(int)_centerBearingDeg}° · ship adrift";
        }

        double progradeDeg = TrackingStation.Bearing(ShipVelocity) * 180.0 / Math.PI;
        if (progradeDeg < 0)
        {
            progradeDeg += 360;
        }

        double off = Math.Abs(_centerBearingDeg - progradeDeg) % 360;
        if (off > 180)
        {
            off = 360 - off;
        }

        return $"scope {(int)_centerBearingDeg}° · prograde {(int)progradeDeg}° — looking {(int)off}° off the bow ({(off <= 90 ? "ahead" : "astern")})";
    }
}
