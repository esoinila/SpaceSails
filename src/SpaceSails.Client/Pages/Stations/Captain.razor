@using SpaceSails.Core
@using SpaceSails.Client.Pages

@* The captain's position (PR-15, docs/SaturdayPlan/StationDesks.md addendum, owner: "the mission
   of the ship could be the captain's position... he selects the goal of the ship"). A stately,
   uncluttered room — one big statement of the current mission, then the catalog of selectable
   missions grouped by kind. One click selects; no confirm dialog — the captain's word is final the
   moment it's given. *@

@{
    RenderFragment<ShipMission> Card = m =>
        @<div class="captain-card @(IsSelected(m) ? "captain-card-selected" : "")" role="button" tabindex="0"
              title="Give this order — the ship makes for it at once, and the captain's word is final the moment it's given"
              @onclick="() => Pick(m)" @onkeydown="e => OnCardKeyDown(e, m)">
            @m.Describe()
        </div>;
}

<div class="captain-desk text-light">
    @* M26: two displays (owner) — the orders catalog, and a status board: every station's chip
       writ large, the whole ship at a glance from the captain's chair. *@
    <div class="captain-view-toggle">
        <div class="btn-group btn-group-sm" role="group" aria-label="Captain view">
            <button type="button" class="btn @(_view == CaptainView.Orders ? "btn-info" : "btn-outline-light")"
                    title="Show the orders catalog — pick the ship's mission"
                    @onclick="() => SetView(CaptainView.Orders)">⚓ Orders</button>
            <button type="button" class="btn @(_view == CaptainView.Status ? "btn-info" : "btn-outline-light")"
                    title="Show the whole ship at a glance — every station's board writ large"
                    @onclick="() => SetView(CaptainView.Status)">🧭 Ship status</button>
            <button type="button" class="btn @(_view == CaptainView.Tutorials ? "btn-info" : "btn-outline-light")"
                    title="Put the crew to school — pick a lesson that plays out at the helm"
                    @onclick="() => SetView(CaptainView.Tutorials)">🎓 Tutorials</button>
            <button type="button" class="btn @(_view == CaptainView.Ledger ? "btn-info" : "btn-outline-light")"
                    title="Open the captain's ledger — every job in hand and every whisper worth keeping"
                    @onclick="() => SetView(CaptainView.Ledger)">📜 Ledger</button>
        </div>
    </div>

    @* Set course from the chart-room: reopens the start-point picker so the captain can begin (or
       resume) a run at another locale — the same chooser the game offers at boot. *@
    @if (OnReopenStartPicker.HasDelegate)
    {
        <div class="captain-start-jump">
            <button type="button" class="btn btn-sm btn-outline-info"
                    title="Choose a start point — Earth, a gas giant, or already ashore at a haven"
                    @onclick="() => OnReopenStartPicker.InvokeAsync()">🧭 Set course to a start point…</button>
        </div>
    }

    @* The mission statement and weapons authority belong to the working desk (Orders / Status);
       the reference tabs (Tutorials, Quests) stand on their own. *@
    @if (_view is CaptainView.Orders or CaptainView.Status)
    {
        <div class="captain-articles">
            <div class="captain-articles-label">@(_view == CaptainView.Status ? "The ship at a glance" : "The ship's articles")</div>
            <div class="captain-articles-mission">@CurrentMission.Describe()</div>
        </div>
    }

    @* Weapons authority (owner, The Expanse consult): the gun deck cannot pull the trigger
       without the captain's word — one shot per authorization, or the standing order. *@
    @if (_view is CaptainView.Orders or CaptainView.Status)
    {
        <div class="captain-articles captain-weapons-authority">
            <div class="captain-articles-label">Weapons authority</div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <button type="button" class="btn btn-sm @(ShotAuthorized ? "btn-success" : "btn-outline-success")"
                        title="Authorizes exactly one shot from the war room; withdrawn automatically when it fires"
                        @onclick="() => OnAuthorizeShot.InvokeAsync()">
                    @(ShotAuthorized ? "✅ NEXT SHOT AUTHORIZED — click to withdraw" : "✍ AUTHORIZE NEXT SHOT")
                </button>
                <label class="text-light captain-fire-at-will">
                    <input type="checkbox" checked="@FireAtWill" title="Standing order — let the gun deck fire on hostiles without waiting on your word each time" @onchange="() => OnToggleFireAtWill.InvokeAsync()" />
                    ⚓ fire at will (standing order)
                </label>
            </div>
            <div class="text-secondary small">Warning shots need no word — they ARE the captain talking.</div>
            @* #205: the owner authorized the next shot and reasonably assumed the boarding was declared
               too. It isn't — guns and shuttles are separate consents. Say so, right where the shot is cleared. *@
            <div class="text-secondary small">Guns cleared ≠ boarding authorized — a boarding is a separate word (the 🏴 window prompt, or the ship-wide alert on any desk).</div>
        </div>
    }

    @if (_view == CaptainView.Status)
    {
        <div class="captain-status-grid">
            @foreach (DeskChips.ChipData chip in StatusChips)
            {
                <div class="captain-status-card" role="button" tabindex="0"
                     title="Take the chair at this station"
                     @onclick="() => OnGoToDesk.InvokeAsync(chip.Desk)"
                     @onkeydown="e => OnStatusKeyDown(e, chip.Desk)">
                    <div class="captain-group-header"><span class="captain-group-icon">@chip.Icon</span> @chip.Label</div>
                    <div class="captain-status-line">@chip.Line1</div>
                    @if (chip.Line2 is not null)
                    {
                        <div class="captain-status-line captain-status-dim">@chip.Line2</div>
                    }
                    @if (chip.Line3 is not null)
                    {
                        <div class="captain-status-line captain-status-dim">@chip.Line3</div>
                    }
                </div>
            }
        </div>
    }
    else if (_view == CaptainView.Tutorials)
    {
        <div class="captain-groups">
            <div class="captain-group">
                <div class="captain-group-header"><span class="captain-group-icon">🎓</span> Learn the ropes</div>
                <div class="captain-group-flavor">The captain puts the crew to school. Pick a lesson — it plays out at the helm, with a checklist to follow. Start any one; you can replay them in any order.</div>
                <div class="captain-group-cards">
                    @if (Tutorials.Count == 0)
                    {
                        <div class="captain-empty">No lessons on the slate.</div>
                    }
                    else
                    {
                        @for (int i = 0; i < Tutorials.Count; i++)
                        {
                            int idx = i;
                            bool active = ActiveTutorial == idx;
                            bool done = ActiveTutorial < 0 || idx < ActiveTutorial;
                            <div class="captain-card @(active ? "captain-card-selected" : "")" role="button" tabindex="0"
                                 title="Begin this lesson — it plays out at the helm with a checklist to follow"
                                 @onclick="() => OnStartTutorial.InvokeAsync(idx)" @onkeydown="e => OnTutorialKeyDown(e, idx)">
                                <div class="fw-bold">@(active ? "▶ " : done ? "✓ " : "")@Tutorials[idx].Title</div>
                                <div class="captain-card-blurb text-secondary small">@Tutorials[idx].Blurb</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
    else if (_view == CaptainView.Ledger)
    {
        @* The Captain's ledger (PR-J, UIUsabilityNotes "The Captain's ledger"): jobs and every whisper
           worth keeping in one brief. The ledger never does the task — each line jumps you to the desk
           that acts on it (the intel card's 🔭 pattern, generalized). *@
        <div class="captain-groups">
            <div class="captain-group">
                <div class="captain-group-header"><span class="captain-group-icon">📜</span> THE CAPTAIN'S LEDGER</div>
                <div class="captain-group-flavor">Every job in hand and every whisper worth keeping — in one place. The ledger never does the work; each line points you to the desk that does.</div>

                <div class="captain-ledger-section-label text-info fw-bold small mt-2">⚓ Jobs</div>
                <div class="captain-group-cards">
                    @if (Quests.Count == 0)
                    {
                        <div class="captain-empty">No contracts in hand. Dock at a haven and go ashore — someone at the bar always has work.</div>
                    }
                    else
                    {
                        @foreach (QuestItem q in Quests)
                        {
                            <div class="captain-card captain-quest-@q.StatusKind">
                                <div class="fw-bold">@q.Title</div>
                                <div class="captain-card-blurb text-secondary small">@q.Detail</div>
                                @if (q.NextAction is { } next)
                                {
                                    @* #175: the live next action, read off ship state — so the card
                                       tells the captain what to do RIGHT NOW, not just what the job is. *@
                                    <div class="captain-quest-next small mt-1">▶ @next</div>
                                }
                                @if (q.Steps.Count > 0)
                                {
                                    <div class="captain-quest-steps small mt-1">
                                        @foreach (QuestStep step in q.Steps)
                                        {
                                            <div class="text-secondary">@step.Icon @step.Text</div>
                                        }
                                    </div>
                                }
                                @if (q.ShowScopeButton)
                                {
                                    <button type="button" class="btn btn-sm btn-info py-0 px-1 mt-1 text-start"
                                            title="Aim the scope where the tip points and jump to Sensors to run the scan"
                                            @onclick="() => OnPointScope.InvokeAsync()">
                                        🔭 Point the scope where the tip says
                                    </button>
                                }
                                <div class="captain-quest-foot">
                                    <span class="captain-quest-status captain-quest-status-@q.StatusKind">@q.StatusLabel</span>
                                    <span class="captain-quest-reward">@q.RewardText</span>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="captain-ledger-section-label text-info fw-bold small mt-3">🔭 Tips &amp; intel</div>
                <div class="captain-group-cards">
                    @if (Tips.Count == 0)
                    {
                        <div class="captain-empty">No tips yet — buy someone a round ashore.</div>
                    }
                    else
                    {
                        @foreach (LedgerTip tip in Tips)
                        {
                            LedgerTip t = tip;
                            bool actionable = t.ScopeTipId is not null || t.ShowDarkWeb || t.DossierShipId is not null;
                            <div class="captain-card captain-ledger-tip">
                                <div class="fw-bold">@t.Title</div>
                                @foreach (string line in t.Lines)
                                {
                                    <div class="captain-card-blurb text-secondary small">@line</div>
                                }
                                @if (t.Provenance is not null)
                                {
                                    <div class="captain-ledger-prov text-secondary small fst-italic">@t.Provenance</div>
                                }
                                @if (t.ScopeTipId is { } scopeId)
                                {
                                    <button type="button" class="btn btn-sm btn-info py-0 px-1 mt-1 text-start"
                                            title="Aim the scope where this tip points and jump to Sensors to run the scan"
                                            @onclick="() => OnScopeTip.InvokeAsync(scopeId)">
                                        🔭 Point the scope where this says
                                    </button>
                                }
                                @if (t.ShowDarkWeb || t.DossierShipId is not null)
                                {
                                    <div class="captain-ledger-links mt-1 d-flex gap-2 flex-wrap">
                                        @if (t.ShowDarkWeb)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info py-0 px-1"
                                                    title="Jump to Comms and open the dark-web node this tip points to"
                                                    @onclick="() => OnRouteToDarkWeb.InvokeAsync()">→ dark web</button>
                                        }
                                        @if (t.DossierShipId is { } dossierId)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info py-0 px-1"
                                                    title="Jump to Comms and open this ship's dossier"
                                                    @onclick="() => OnRouteToDossier.InvokeAsync(dossierId)">→ dossier</button>
                                        }
                                    </div>
                                }
                                @if (!actionable)
                                {
                                    <div class="captain-quest-status text-secondary small mt-1">background — may matter later</div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
    else
    {
    <div class="captain-groups">
        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">⛵</span> Free sailing</div>
            <div class="captain-group-flavor">No orders given. The crew keeps her trim and waits on your word.</div>
            <div class="captain-group-cards">
                @Card(ShipMission.Default)
            </div>
        </div>

        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">🎯</span> Fly to</div>
            <div class="captain-group-flavor">Set the helm for a world — Nav plots the course, the autopilot parks us in orbit.</div>
            <div class="captain-group-cards">
                @if (Options.FlyTo.Count == 0)
                {
                    <div class="captain-empty">No worlds charted to make for.</div>
                }
                else
                {
                    @foreach (ShipMission m in Options.FlyTo)
                    {
                        @Card(m)
                    }
                }
            </div>
        </div>

        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">☠</span> Hunt</div>
            <div class="captain-group-flavor">Name the cargo, and we'll run down every hauler carrying it.</div>
            <div class="captain-group-cards">
                @if (Options.Hunt.Count == 0)
                {
                    <div class="captain-empty">No haulers worth the name in these waters.</div>
                }
                else
                {
                    @foreach (ShipMission m in Options.Hunt)
                    {
                        @Card(m)
                    }
                }
            </div>
        </div>

        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">🛰</span> Trade run</div>
            <div class="captain-group-flavor">Honest cargo, honest coin — and the safest way to grow the hold.</div>
            <div class="captain-group-cards">
                @if (Options.TradeRuns.Count == 0)
                {
                    <div class="captain-empty">No charted trade lanes yet.</div>
                }
                else
                {
                    @foreach (ShipMission m in Options.TradeRuns)
                    {
                        @Card(m)
                    }
                }
            </div>
        </div>

        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">🍹</span> Lay low</div>
            <div class="captain-group-flavor">Heat's rising. Find a haven, cool the trail, and let the fuss pass.</div>
            <div class="captain-group-cards">
                @if (Options.LayLow.Count == 0)
                {
                    <div class="captain-empty">No havens charted — nowhere quiet to run to.</div>
                }
                else
                {
                    @foreach (ShipMission m in Options.LayLow)
                    {
                        @Card(m)
                    }
                }
            </div>
        </div>

        <div class="captain-group">
            <div class="captain-group-header"><span class="captain-group-icon">🔭</span> Survey</div>
            <div class="captain-group-flavor">Chart the corridor end to end — every hull that passes it becomes known to us.</div>
            <div class="captain-group-cards">
                @if (Options.Survey.Count == 0)
                {
                    <div class="captain-empty">No corridor worth the watch yet.</div>
                }
                else
                {
                    @foreach (ShipMission m in Options.Survey)
                    {
                        @Card(m)
                    }
                }
            </div>
        </div>
    </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ShipMission CurrentMission { get; set; } = ShipMission.Default;
    [Parameter, EditorRequired] public MissionOptions Options { get; set; } = new([], [], [], [], []);
    [Parameter] public EventCallback<ShipMission> OnSelectMission { get; set; }
    [Parameter] public IReadOnlyList<DeskChips.ChipData> StatusChips { get; set; } = [];
    [Parameter] public EventCallback<ShipDesk> OnGoToDesk { get; set; }
    [Parameter] public bool ShotAuthorized { get; set; }
    [Parameter] public bool FireAtWill { get; set; }
    [Parameter] public EventCallback OnAuthorizeShot { get; set; }
    [Parameter] public EventCallback OnToggleFireAtWill { get; set; }
    // Reopens Map's start-point picker (playtest / "begin elsewhere" jump). Optional — the button
    // only shows when Map wires it.
    [Parameter] public EventCallback OnReopenStartPicker { get; set; }

    // Tutorials tab (the picker used to float on the Nav map; starting a lesson is a captain's order).
    [Parameter] public IReadOnlyList<TutorialItem> Tutorials { get; set; } = [];
    [Parameter] public int ActiveTutorial { get; set; } = -1; // index of the in-progress lesson, -1 = none
    [Parameter] public EventCallback<int> OnStartTutorial { get; set; }
    // Set by the Nav "New here? Learn the ropes" banner so the desk opens straight on the lessons.
    [Parameter] public bool OpenToTutorials { get; set; }

    // #124/#125 playtest: the desk component is re-created on every desk switch (see the note by
    // _view below), so the active tab used to reset to Orders each return. Map now OWNS the last
    // tab: it seeds this desk with InitialTab on creation and the desk reports every tab change
    // back through OnTabChanged, so "find the tab where I left it" holds across desk switches.
    [Parameter] public CaptainView InitialTab { get; set; } = CaptainView.Orders;
    [Parameter] public EventCallback<CaptainView> OnTabChanged { get; set; }

    /// <summary>One lesson on the Tutorials tab — title + one-line blurb. Map owns the actual steps.</summary>
    public sealed record TutorialItem(string Title, string Blurb);

    // Quests tab (go-ashore contracts, M-Q2): a read-only ledger of work picked up at haven bars.
    // Accepted at the table, tracked in Map, paid on docking — this desk is the crew's copy.
    [Parameter] public IReadOnlyList<QuestItem> Quests { get; set; } = [];

    /// <summary>Raised by a quest card's 🔭 button (Tuesday plan PR-A): the intel-fed fetch hunt is
    /// reachable from the quest card too, not just the Comms desk. Map aims the scope and jumps to
    /// Sensors.</summary>
    [Parameter] public EventCallback OnPointScope { get; set; }

    /// <summary>One contract on the Quests tab. <paramref name="StatusKind"/> is a css slug
    /// (active / complete / paid); Map owns the live quest state. <paramref name="Steps"/> is the
    /// staged plan (empty for quests without one); <paramref name="ShowScopeButton"/> surfaces the
    /// 🔭 "point the scope" hook while the fetch hunt is at its pre-scan stage.</summary>
    public sealed record QuestItem(
        string Title, string Detail, string RewardText, string StatusLabel, string StatusKind,
        IReadOnlyList<QuestStep> Steps, bool ShowScopeButton, string? NextAction = null)
    {
        public QuestItem(string title, string detail, string rewardText, string statusLabel, string statusKind)
            : this(title, detail, rewardText, statusLabel, statusKind, [], false) { }
    }

    /// <summary>One line of a staged quest plan — an icon (✅ done / ▶ current / ▪ ahead) and its text.</summary>
    public sealed record QuestStep(string Icon, string Text);

    // The ledger's "Tips & intel" section (PR-J): every scope/route tip, projected by Map so this
    // desk only renders. A scope tip carries <paramref name="ScopeTipId"/> (its 🔭 action jumps to
    // Sensors with the scan queued); a route tip carries <paramref name="ShowDarkWeb"/> and, when the
    // ship is a known contact, <paramref name="DossierShipId"/> (the two "→" links onto Comms). A tip
    // with none of the three is background — "may matter later".
    [Parameter] public IReadOnlyList<LedgerTip> Tips { get; set; } = [];

    /// <summary>A scope tip's 🔭 button (by tip id): Map aims the prioritized scan and jumps to Sensors,
    /// exactly like the Comms intel card.</summary>
    [Parameter] public EventCallback<string> OnScopeTip { get; set; }

    /// <summary>A route tip's "→ dark web" link: Map switches to Comms and selects the dark-web node.</summary>
    [Parameter] public EventCallback OnRouteToDarkWeb { get; set; }

    /// <summary>A route tip's "→ dossier" link (by ship id): Map switches to Comms and selects the contact.</summary>
    [Parameter] public EventCallback<string> OnRouteToDossier { get; set; }

    /// <summary>One line in the ledger's Tips &amp; intel section. <paramref name="Lines"/> is the
    /// grounded numbers (scope) or the route in plain words (route); <paramref name="Provenance"/> is
    /// "&lt;giver&gt; · &lt;station&gt; · day N" or null when unknown. Exactly the actions that apply
    /// are non-null/true; a tip with no action renders as background.</summary>
    public sealed record LedgerTip(
        string Title, IReadOnlyList<string> Lines, string? Provenance,
        string? ScopeTipId, bool ShowDarkWeb, string? DossierShipId);

    public enum CaptainView { Orders, Status, Tutorials, Ledger }
    private CaptainView _view;

    // The component is re-created each time you switch to the Captain desk. The banner's one-shot
    // "open on Tutorials" wins for that single arrival; otherwise we restore the last tab Map kept
    // for us (InitialTab), so a manual return lands where you left rather than always on Orders.
    protected override void OnInitialized()
    {
        _view = OpenToTutorials ? CaptainView.Tutorials : InitialTab;
    }

    // Set the active tab and let Map remember it (it survives this desk's re-creation).
    private async Task SetView(CaptainView view)
    {
        _view = view;
        await OnTabChanged.InvokeAsync(view);
    }

    private async Task OnStatusKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, ShipDesk desk)
    {
        if (e.Key is "Enter" or " ")
        {
            await OnGoToDesk.InvokeAsync(desk);
        }
    }

    private async Task OnTutorialKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, int index)
    {
        if (e.Key is "Enter" or " ")
        {
            await OnStartTutorial.InvokeAsync(index);
        }
    }

    private bool IsSelected(ShipMission m) => CurrentMission == m;

    private Task Pick(ShipMission m) => OnSelectMission.InvokeAsync(m);

    private async Task OnCardKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, ShipMission m)
    {
        if (e.Key is "Enter" or " ")
        {
            await Pick(m);
        }
    }
}
