@using System.Globalization
@using SpaceSails.Core

@* The gun deck / war-room (vision par. 18): a top-down local tactical view centered on the
   player, weapon-range rings, warning shots, threats/bribery and the heat gauge that tracks the
   hired muscle a robbery calls down. Entirely self-contained like TrackingPost — Map.razor only
   feeds it contacts + heat/hunter state (thin DTOs, never its private NpcState) and reads back
   which button the player pressed via the OnWarningShot/OnBribe callbacks. All the compliance,
   threat-line and bribe-price math is Core's EncounterRule — this component only renders it.

   Desk layout (PR-13, StationDesks.md's 70% rule): full-screen, the tactical circle owns the
   left ~60% of the desk (range-scale selector above it, the heat gauge blown up large in its
   bottom-left corner), and the right column holds a menacing hunter readout plus a roomy
   contact side-list — hail/warn/bribe stay exactly where they were, just given room to breathe. *@

<div class="war-room-card @(FullScreen ? "war-room-desk text-light" : "card bg-dark bg-opacity-75 text-light") @(Visible ? "" : "d-none")">
    <div class="card-header py-1 d-flex justify-content-between align-items-center gap-1">
        <span class="fw-bold small">Gun deck ⚔</span>
        @if (!FullScreen)
        {
            <span class="war-room-heat-gauge" title="Heat level @HeatLevel/@EncounterRule.MaxHeatLevel">@HeatGaugeText()</span>
            <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="() => OnClose.InvokeAsync()"></button>
        }
    </div>
    <div class="card-body p-2 small @(FullScreen ? "war-room-desk-body" : "")">
        @{ IReadOnlyList<RenderContact> contacts = VisibleContacts(); }
        @{ IReadOnlyList<RenderHunter> renderHunters = RenderHunters(); }

        @if (!FullScreen)
        {
            <div class="text-secondary mb-1">@CoolingLabel()</div>
            @if (NearestHunter() is { } nhCompact)
            {
                <div class="war-room-hunter-warning mb-2">
                    🐺 @nhCompact.Callsign closing — @FormatRange(nhCompact.Distance) at bearing @((int)nhCompact.BearingDeg)°
                </div>
            }
        }
        else
        {
            <div class="war-room-range-group btn-group btn-group-sm mb-2" role="group" aria-label="Tactical view range">
                @foreach (double range in RangePresets)
                {
                    <button type="button" class="btn @(range == _viewRangeMeters ? "btn-info" : "btn-outline-info")"
                            @onclick="() => _viewRangeMeters = range">
                        @FormatRange(range)
                    </button>
                }
            </div>
        }

        <div class="@(FullScreen ? "war-room-desk-grid" : "d-flex gap-2 align-items-start")">
            <div class="@(FullScreen ? "war-room-tactical-col" : "")">
                <div class="war-room-scope flex-shrink-0 @(FullScreen ? "war-room-scope-big" : "")">
                    <svg viewBox="0 0 200 200" class="war-room-scope-svg" aria-label="Local tactical view">
                        <circle cx="100" cy="100" r="@Fmt(MaxRadiusPx)" class="war-room-view-ring" />
                        <circle cx="100" cy="100" r="@Fmt(WeaponRingPx)" class="war-room-weapon-ring" />
                        @* Labeled rings (Gemini blind playtest: "unlabeled ring — is it weapon
                           range?"). Raw markup because Razor reserves the bare <text> tag. *@
                        @RingLabelMarkup(MaxRadiusPx, $"view {FormatRange(_viewRangeMeters)}")
                        @if (WeaponRingPx > 18)
                        {
                            @RingLabelMarkup(WeaponRingPx, $"weapon {FormatRange(EncounterRule.WeaponRangeMeters)}")
                        }
                        @foreach (RenderHunter h in renderHunters)
                        {
                            <circle cx="@Fmt(h.X)" cy="@Fmt(h.Y)" r="@Fmt(MetersToPx(EncounterRule.CatchRadiusMeters))" class="war-room-hunter-ring" />
                        }
                        @foreach (RenderHunter h in renderHunters)
                        {
                            @if (h.ThreatLine)
                            {
                                <line x1="100" y1="100" x2="@Fmt(h.X)" y2="@Fmt(h.Y)" class="war-room-threat-line" />
                            }
                        }
                        @* M27: the sensor room's tracks, drawn as bearing vectors — the war room
                           consumes what the tracking post screens (owner). *@
                        @* The gunner's ray: scope center (us) to the target of interest, so the
                           basic geometry is never invisible on the tactical circle either. *@
                        @foreach (RenderTrack aimRay in RenderTracks())
                        {
                            @if (aimRay.Track.Id == InterestId)
                            {
                                <line x1="100" y1="100" x2="@Fmt(aimRay.X)" y2="@Fmt(aimRay.Y)" class="war-room-aim-ray" />
                            }
                        }
                        @foreach (RenderTrack rt in RenderTracks())
                        {
                            <line x1="100" y1="100" x2="@Fmt(rt.X)" y2="@Fmt(rt.Y)"
                                  class="@(rt.Track.IsThreat ? "war-room-track-line war-room-track-line-threat" : "war-room-track-line")" />
                            <rect x="@Fmt(rt.X - 3)" y="@Fmt(rt.Y - 3)" width="6" height="6"
                                  class="@(rt.Track.Id == InterestId ? "war-room-track-dot war-room-track-dot-interest" : "war-room-track-dot")" />
                        }
                        @foreach (RenderContact rc in contacts)
                        {
                            @* M27: everyone shoots back eventually — an estimated weapon-range
                               ring around every crewed contact, visible when the scale allows. *@
                            @if (!rc.Contact.Ship.IsPod && WeaponRingPx > 4)
                            {
                                <circle cx="@Fmt(rc.X)" cy="@Fmt(rc.Y)" r="@Fmt(WeaponRingPx)" class="war-room-contact-weapon-ring" />
                            }
                            <circle cx="@Fmt(rc.X)" cy="@Fmt(rc.Y)" r="4" class="@ContactDotClass(rc)" />
                        }
                        @foreach (RenderHunter h in renderHunters)
                        {
                            <circle cx="@Fmt(h.X)" cy="@Fmt(h.Y)" r="6" class="war-room-hunter-dot" />
                            @HunterLabelMarkup(h)
                        }
                        <circle cx="100" cy="100" r="4" class="war-room-ship" />
                    </svg>
                    @if (FullScreen)
                    {
                        <div class="war-room-heat-corner">
                            <div class="war-room-heat-gauge war-room-heat-gauge-big @(HeatLevel > 0 ? "war-room-heat-hot" : "")" title="Heat level @HeatLevel/@EncounterRule.MaxHeatLevel — rises with crimes, hunters come at high heat, cools at havens">@HeatGaugeText()</div>
                            <div class="war-room-heat-level-label">Heat @HeatLevel/@EncounterRule.MaxHeatLevel</div>
                            <div class="text-secondary war-room-heat-cooling">@CoolingLabel()</div>
                            @if (CoolingAtHaven)
                            {
                                <div class="badge bg-danger-subtle text-danger-emphasis mt-1">🏴 hiding at haven</div>
                            }
                        </div>
                    }
                </div>
                @if (FullScreen)
                {
                    <div class="text-secondary mt-2">
                        Contacts within @FormatRange(_viewRangeMeters) · Weapon range @FormatRange(EncounterRule.WeaponRangeMeters)
                    </div>
                }
            </div>
            <div class="@(FullScreen ? "war-room-side-col" : "flex-grow-1 text-secondary")">
                @if (!FullScreen)
                {
                    <div>Contacts within @FormatRange(_viewRangeMeters)</div>
                    <div>Weapon range: @FormatRange(EncounterRule.WeaponRangeMeters)</div>
                }
                else
                {
                    @* M28: the Norden moment — pick the point on the prey's predicted track,
                       watch the shooting method converge, the solution locks T-60 s, the ship
                       slews, fires, and hands control back. *@
                    @if (InterestId is null)
                    {
                        @* The empty state IS most of a new gunner's experience (Gemini playtest +
                           owner: "there was never any target shown or selected"). Teach the kill
                           chain and point at where each step happens. *@
                        <div class="war-room-firecontrol mb-2">
                            <div class="fw-bold">🎖 Fire control — no target of interest yet</div>
                            <div class="text-secondary mb-1">The gun deck shoots what the sensors feed it. The kill chain:</div>
                            <div class="war-room-chain">
                                <div>1️⃣ <span class="text-light">Track</span> a ship — Sensors desk (<kbd>2</kbd>): the passive watch or a scan finds her.</div>
                                <div>2️⃣ <span class="text-light">Mark interest</span> — 🎯 on a sensor track below, on a Sensors card, or click her on the map.</div>
                                <div>3️⃣ <span class="text-light">Aim &amp; solve</span> — 🎯 AUTO-AIM does both; the map behind this desk draws the whole transfer. Computing is safe.</div>
                                <div>4️⃣ <span class="text-light">🔥 FIRE</span> — the only button that shoots: locks the barrel, round away 60 s later (or hold the lock as a threat).</div>
                                <div>5️⃣ <span class="text-light">Board the drift</span> — a hit holes her sail; close in and take the cargo.</div>
                            </div>
                            @if (SensorTracks.Count == 0)
                            {
                                <div class="text-secondary mt-1">No sensor tracks yet — start at the <span class="text-light">Sensors desk (2)</span>.</div>
                            }
                            else
                            {
                                <div class="text-info mt-1">⬇ pick a target from the sensor tracks below</div>
                            }
                        </div>
                    }
                    @if (InterestId is not null)
                    {
                        <div class="war-room-firecontrol mb-2">
                            <div class="fw-bold">🎖 Fire control — @(InterceptTargetName ?? InterestId)</div>
                            @if (FireCountdownSeconds is { } countdown)
                            {
                                @if (FireSolution is { } fs)
                                {
                                    <div class="war-room-verdict war-room-verdict-armed">🔥 ROUND AWAY IN @Math.Max(0, (int)countdown) s — fires itself, hands off</div>
                                    <div class="text-secondary">
                                        bearing @((fs.BearingRad * 180 / Math.PI).ToString("F1"))° ·
                                        charge @((fs.MuzzleSpeed / 1000).ToString("F2")) km/s ·
                                        flight @FormatDuration(fs.TimeOfFlightSeconds) ·
                                        solver miss @FormatRange(fs.ExpectedMissMeters) ·
                                        dispersion ±@FormatRange(FireDispersionMeters)
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-warning mt-1" @onclick="() => OnCancelFire.InvokeAsync()">SCRUB — abort the shot</button>
                                }
                            }
                            else
                            {
                                @* Owner: "the aim and the fire solution should definitely be
                                   separated" — three stages, and only the LAST one shoots. *@
                                <div class="war-room-stage-label">① AIM — when the round meets their track</div>
                                <button type="button" class="btn btn-sm btn-info w-100 fw-bold"
                                        title="Jump to the shortest physical flight, solve there; sweep launch windows if the geometry refuses. Computes only — never fires."
                                        @onclick="() => OnAutoAim.InvokeAsync()">
                                    🎯 AUTO-AIM — point the gun for me
                                </button>
                                <label class="form-label mb-0 mt-1 war-room-round-hint">or by hand: meet their predicted track <strong>+@FormatDuration(FireAimOffsetSeconds)</strong> from now</label>
                                @* Log-scale (long-shots PR): ten minutes and half a year on one slider —
                                   a linear track made week-long orbital shots one-pixel affairs. *@
                                <input type="range" class="form-range" min="0" max="1000" step="2" value="@AimToSlider(FireAimOffsetSeconds)"
                                       @oninput="OnAimInput" @onkeydown:stopPropagation="true" />
                                <div class="d-flex gap-1 align-items-center mb-1">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Round type">
                                        <button type="button" class="btn @(FireKind == OrdnanceKind.Slug ? "btn-info" : "btn-outline-info") py-0"
                                                @onclick="() => OnFireKindChanged.InvokeAsync(OrdnanceKind.Slug)">slug</button>
                                        <button type="button" class="btn @(FireKind == OrdnanceKind.Missile ? "btn-info" : "btn-outline-info") py-0"
                                                @onclick="() => OnFireKindChanged.InvokeAsync(OrdnanceKind.Missile)">missile</button>
                                    </div>
                                    <span class="text-secondary">@FirePulseCost pulses / shot · lives @FormatDuration(MaxAimOffsetSeconds) · magazine: slug ×@SlugAmmo / missile ×@MissileAmmo</span>
                                </div>
                                @if (InterestDistanceMeters is { } targetDistance)
                                {
                                    double roundLegs = MaxMuzzleSpeedMps * Math.Max(0, FireAimOffsetSeconds - 60);
                                    <div class="@(roundLegs < targetDistance ? "text-warning" : "text-secondary") war-room-round-hint">
                                        round legs ≈ @FormatRange(roundLegs) at this aim · target now @FormatRange(targetDistance)
                                    </div>
                                }
                                @if (StraightWindowText is not null)
                                {
                                    <div class="text-info war-room-round-hint">straight-shot window: <strong>@StraightWindowText</strong> — auto-aim solves inside it</div>
                                }
                                else
                                {
                                    <div class="text-secondary war-room-round-hint">no straight window — their drift outruns the muzzle; 🔭 scan hunts gravity-assisted windows</div>
                                }

                                <div class="war-room-stage-label mt-2">② SOLUTION — the shooting method's verdict</div>
                                @if (FireSolution is { } solution && RevealedIterations < solution.Trace.Count)
                                {
                                    <div class="war-room-calc text-info">CALCULATING FIRING SOLUTION…</div>
                                    @foreach (FireControl.IterationStep step in solution.Trace.Take(RevealedIterations))
                                    {
                                        <div class="war-room-calc-row">iter @step.Iteration · bearing @((step.BearingRad * 180 / Math.PI).ToString("F2"))° · miss @FormatRange(step.MissMeters)</div>
                                    }
                                }
                                else if (FireSolution is { Converged: true } good)
                                {
                                    @if (FireBlockedBy is not null)
                                    {
                                        <div class="war-room-verdict war-room-verdict-bad">⛔ BLOCKED — the transfer passes through @FireBlockedBy</div>
                                        <div class="text-secondary war-room-round-hint">🔭 scan for a window that clears it, or aim a different time</div>
                                    }
                                    else
                                    {
                                        <div class="war-room-verdict war-room-verdict-good">✅ SOLUTION — impact in @FormatDuration(good.TimeOfFlightSeconds) · ±@FormatRange(FireDispersionMeters)</div>
                                        <div class="text-secondary war-room-round-hint">the map behind this desk draws the whole transfer — nothing flies until you FIRE</div>
                                    }
                                }
                                else if (FireSolution is { Converged: false })
                                {
                                    <div class="war-room-verdict war-room-verdict-bad">❌ NO SHOT at +@FormatDuration(FireAimOffsetSeconds)@NeedsAimHint()</div>
                                }
                                else
                                {
                                    <div class="text-secondary">no solution computed yet — auto-aim, or solve at this aim:</div>
                                }
                                <button type="button" class="btn btn-sm btn-outline-light w-100"
                                        title="Runs the solver at the chosen aim time. Safe — computing never fires."
                                        @onclick="() => OnComputeSolution.InvokeAsync()">
                                    🧮 SOLVE AT THIS AIM
                                </button>
                                <div class="text-secondary war-room-round-hint">cross-system solves grind the whole deck for a minute or more — the shooting method flies real trajectories</div>
                                <button type="button" class="btn btn-sm btn-outline-info w-100 mt-1"
                                        title="Orbital mechanics decides when the geometry aligns — sweep candidate aim times and solve at the best one"
                                        @onclick="() => OnScanWindows.InvokeAsync()">
                                    🔭 SCAN FOR A WINDOW
                                </button>

                                <div class="war-room-stage-label mt-2">③ FIRE — the captain's word, then the trigger</div>
                                int roundsLeft = FireKind == OrdnanceKind.Missile ? MissileAmmo : SlugAmmo;
                                <button type="button" class="btn btn-danger w-100 fw-bold"
                                        disabled="@(FireSolution is not { Converged: true } || FireBlockedBy is not null || PulsesAvailable < FirePulseCost || !WeaponsAuthorized || roundsLeft <= 0)"
                                        title="Commits the computed solution: the barrel locks and the round leaves at the calculated moment (60 s). Scrub during the countdown to abort."
                                        @onclick="() => OnArmFire.InvokeAsync()">
                                    🔥 FIRE — round away in 60 s
                                </button>
                                @if (!WeaponsAuthorized)
                                {
                                    <div class="text-warning war-room-round-hint">⚓ needs the captain's word — desk 0 authorizes a shot, or orders fire at will</div>
                                }
                                else if (FireAtWill)
                                {
                                    <div class="text-secondary war-room-round-hint">⚓ fire at will stands — the trigger is yours</div>
                                }
                                @if (roundsLeft <= 0)
                                {
                                    <div class="text-warning war-room-round-hint">magazine empty — resupply dockside below</div>
                                }
                                else if (FireSolution is not { Converged: true })
                                {
                                    <div class="text-secondary war-room-round-hint">needs a converged solution — a lock you never fire is also a THREAT they can hear about</div>
                                }
                                else if (PulsesAvailable < FirePulseCost)
                                {
                                    <div class="text-warning war-room-round-hint">not enough reaction mass (@PulsesAvailable/@FirePulseCost pulses) — sail to recharge</div>
                                }
                                <button type="button" class="btn btn-sm btn-outline-warning w-100 mt-1"
                                        disabled="@(!CanWarnInterest || SlugAmmo <= 0)"
                                        title="A real slug flung wide on purpose — the captain's voice, no authorization needed. Compliant crews heave to."
                                        @onclick="() => OnWarningShot.InvokeAsync(InterestId)">
                                    ⚠ WARNING SHOT — across her bow (no authorization needed)
                                </button>
                                @if (!CanWarnInterest)
                                {
                                    <div class="text-secondary war-room-round-hint">warning shots need weapon range (@FormatRange(EncounterRule.WeaponRangeMeters)) and a crewed hull</div>
                                }
                                <div class="d-flex gap-1 mt-1">
                                    <button type="button" class="btn btn-sm btn-outline-secondary flex-fill" disabled="@(!Docked)"
                                            @onclick="() => OnBuyAmmo.InvokeAsync(OrdnanceKind.Slug)">＋6 slugs · 300 cr</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary flex-fill" disabled="@(!Docked)"
                                            @onclick="() => OnBuyAmmo.InvokeAsync(OrdnanceKind.Missile)">＋2 missiles · 500 cr</button>
                                </div>
                                @if (!Docked)
                                {
                                    <div class="text-secondary war-room-round-hint">resupply needs a dock — rounds are bought, not conjured</div>
                                }
                            }
                            @if (FireTip is not null)
                            {
                                <div class="war-room-tip fst-italic text-secondary mt-1">@FireTip</div>
                            }
                        </div>
                    }

                    @* Rounds in flight (owner: "shots / missiles away is also good to track") —
                       every live round, its prey, and its clock; the map draws the ride. *@
                    @if (RoundsInFlight.Count > 0)
                    {
                        <div class="war-room-firecontrol mb-2">
                            <div class="fw-bold">🚀 Rounds in flight (@RoundsInFlight.Count)</div>
                            @if (PlannedImpactInSeconds is { } eta)
                            {
                                <div class="text-info">planned impact in <strong>@FormatDuration(eta)</strong> — hit or miss, you'll hear it</div>
                            }
                            @foreach (LiveRound liveRound in RoundsInFlight)
                            {
                                <div class="war-room-round-hint">@(liveRound.Kind == "missile" ? "🚀" : "▪") @liveRound.Kind → @liveRound.Target · expires in @FormatDuration(liveRound.ExpiresIn)</div>
                            }
                        </div>
                    }

                    @* M27: the intercept clock — the plotted course vs the target of interest,
                       and the countdown to the boarding envelope: the initiative roll. *@
                    @if (InterestId is not null)
                    {
                        <div class="war-room-intercept mb-2">
                            <div class="fw-bold">🎯 Interest: @(InterceptTargetName ?? InterestId)</div>
                            @if (Intercept is { } ic)
                            {
                                <div>Plotted course min distance: <strong>@FormatRange(ic.MinDistance)</strong> in @FormatDuration(ic.MinSimTime - SimTime)</div>
                                @if (ic.FirstWithinThresholdSimTime is { } t0)
                                {
                                    @if (t0 <= SimTime)
                                    {
                                        <div class="text-danger fw-bold">⚔ ENCOUNTER WINDOW — inside the boarding envelope now</div>
                                    }
                                    else
                                    {
                                        <div class="text-warning">⏱ Encounter begins in <strong>@FormatDuration(t0 - SimTime)</strong> (range ≤ @FormatRange(CaptureRule.CaptureRadiusMeters))</div>
                                    }
                                }
                                else
                                {
                                    <div class="text-secondary">Course never enters the boarding envelope — tighten the plot at Nav.</div>
                                }
                                <div class="text-secondary">estimate assumes the target coasts (no burns)</div>
                            }
                            else
                            {
                                <div class="text-secondary">No intercept solution yet — needs a plotted course and a live fix.</div>
                            }
                        </div>
                    }
                    @if (NearestHunter() is { } nh)
                    {
                        <div class="war-room-hunter-warning mb-2">
                            🐺 @nh.Callsign closing — @FormatRange(nh.Distance) at bearing @((int)nh.BearingDeg)°
                        </div>
                    }
                    @if (SensorTracks.Count > 0)
                    {
                        <div class="war-room-track-list mb-2">
                            <div class="fw-bold mb-1">📡 Sensor tracks</div>
                            @foreach (SensorTrack track in SensorTracks)
                            {
                                Vector2d relT = track.State.Position - ShipPosition;
                                double td = relT.Length;
                                double tb = Math.Atan2(relT.Y, relT.X) * 180.0 / Math.PI;
                                if (tb < 0) { tb += 360; }
                                <div class="war-room-track-row d-flex justify-content-between align-items-center">
                                    <span>@(track.IsThreat ? "🐺 " : "")@track.Callsign</span>
                                    <span class="text-secondary">@FormatRange(td) · brg @((int)tb)°</span>
                                    <button type="button" class="btn btn-sm py-0 px-1 @(track.Id == InterestId ? "btn-info" : "btn-outline-info")"
                                            @onclick="() => OnSetInterest.InvokeAsync(track.Id)">🎯</button>
                                </div>
                            }
                        </div>
                    }
                    @if (renderHunters.Count > 0)
                    {
                        <div class="war-room-hunter-list mb-2">
                            @foreach (RenderHunter h in renderHunters)
                            {
                                <div class="war-room-hunter-row">
                                    <span class="war-room-hunter-row-name">🐺 @h.Callsign</span>
                                    <span class="text-secondary">@FormatRange(h.Distance) · brg @((int)h.BearingDeg)° · @FormatClosingSpeed(h.ClosingSpeed)</span>
                                </div>
                            }
                        </div>
                    }
                    <div class="war-room-contact-list">
                        @if (contacts.Count == 0)
                        {
                            <div class="text-secondary">Nothing close enough to aim at.</div>
                        }
                        else
                        {
                            @foreach (RenderContact rc in contacts)
                            {
                                bool inWeaponRangeDesk = EncounterRule.InWeaponRange(new ShipState(ShipPosition, ShipVelocity, SimTime), rc.Contact.State);
                                int bribePriceDesk = EncounterRule.BribePrice(rc.Contact.Ship);
                                <div class="war-room-contact-row mb-2 pb-2">
                                    <div class="d-flex justify-content-between align-items-center gap-1">
                                        <span class="fw-bold">@rc.Contact.Ship.Callsign</span>
                                        <span class="@StatusBadgeClass(rc)">@StatusBadge(rc)</span>
                                    </div>
                                    <div class="text-secondary">@FormatRange(rc.Distance)</div>
                                    <div class="d-flex gap-1 mt-1">
                                        <button type="button" class="btn btn-sm py-0 px-1 @(rc.Contact.Ship.Id == InterestId ? "btn-info" : "btn-outline-info")"
                                                title="Target of interest — track the intercept clock"
                                                @onclick="() => OnSetInterest.InvokeAsync(rc.Contact.Ship.Id)">🎯</button>
                                        <button type="button" class="btn btn-sm btn-outline-info py-0 px-1" @onclick="() => Hail(rc)">Hail</button>
                                        <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1"
                                                disabled="@(!inWeaponRangeDesk || rc.Contact.Ship.IsPod)"
                                                @onclick="() => OnWarningShot.InvokeAsync(rc.Contact.Ship.Id)">
                                            Warn
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-success py-0 px-1"
                                                disabled="@(rc.Contact.Bribed || rc.Contact.Ship.IsPod || Credits < bribePriceDesk)"
                                                @onclick="() => OnBribe.InvokeAsync(rc.Contact.Ship.Id)">
                                            Bribe (@bribePriceDesk cr)
                                        </button>
                                    </div>
                                    @if (_hailLines.TryGetValue(rc.Contact.Ship.Id, out string? lineDesk))
                                    {
                                        <div class="war-room-hail-line fst-italic mt-1">@lineDesk</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        @if (!FullScreen)
        {
            @if (contacts.Count == 0)
            {
                <div class="text-secondary mt-2">Nothing close enough to aim at.</div>
            }
            else
            {
                <table class="table table-sm table-dark mb-0 mt-2">
                    <tbody>
                        @foreach (RenderContact rc in contacts)
                        {
                            bool inWeaponRange = EncounterRule.InWeaponRange(new ShipState(ShipPosition, ShipVelocity, SimTime), rc.Contact.State);
                            int bribePrice = EncounterRule.BribePrice(rc.Contact.Ship);
                            <tr>
                                <td>
                                    @rc.Contact.Ship.Callsign
                                    <div class="text-secondary">@FormatRange(rc.Distance) — @StatusBadge(rc)</div>
                                </td>
                                <td class="text-end align-middle text-nowrap">
                                    <button type="button" class="btn btn-sm btn-outline-info py-0 px-1" @onclick="() => Hail(rc)">Hail</button>
                                    <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1"
                                            disabled="@(!inWeaponRange || rc.Contact.Ship.IsPod)"
                                            @onclick="() => OnWarningShot.InvokeAsync(rc.Contact.Ship.Id)">
                                        Warn
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-success py-0 px-1"
                                            disabled="@(rc.Contact.Bribed || rc.Contact.Ship.IsPod || Credits < bribePrice)"
                                            @onclick="() => OnBribe.InvokeAsync(rc.Contact.Ship.Id)">
                                        Bribe (@bribePrice cr)
                                    </button>
                                </td>
                            </tr>
                            @if (_hailLines.TryGetValue(rc.Contact.Ship.Id, out string? line))
                            {
                                <tr><td colspan="2" class="war-room-hail-line fst-italic">@line</td></tr>
                            }
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</div>

@code {
    /// <summary>A boardable/rob-able ship the war-room can aim at — a thin projection of
    /// Map.razor's own NPC state, mirroring TrackingPost's TrackingCandidate.</summary>
    public readonly record struct Contact(NpcShip Ship, ShipState State, bool WarningShotFired, bool Bribed);

    /// <summary>Hired muscle, hunting. Map.razor's HunterState roster, thinned to what the
    /// display needs.</summary>
    public readonly record struct HunterContact(string Id, string Callsign, ShipState State);

    /// <summary>M27: a tracking-post ledger entry, thinned for the war room — the sensor room
    /// screens the data, this desk consumes it.</summary>
    public readonly record struct SensorTrack(string Id, string Callsign, ShipState State, double Quality, bool IsThreat);

    private readonly record struct RenderTrack(SensorTrack Track, double X, double Y);

    private readonly record struct RenderContact(Contact Contact, ComplianceState Compliance, double Distance, double X, double Y);

    private readonly record struct NearestHunterInfo(string Callsign, double Distance, double BearingDeg);

    /// <summary>A hunter, ready to draw: screen position, bearing, distance, closing speed and
    /// whether it's close enough (within 2x weapon range) to earn a threat line on the circle.</summary>
    private readonly record struct RenderHunter(string Callsign, double Distance, double BearingDeg, double ClosingSpeed, double X, double Y, bool ThreatLine);

    [Parameter, EditorRequired] public double SimTime { get; set; }
    [Parameter, EditorRequired] public Vector2d ShipPosition { get; set; }
    [Parameter, EditorRequired] public Vector2d ShipVelocity { get; set; }
    [Parameter] public IReadOnlyList<Contact> Contacts { get; set; } = [];
    [Parameter] public IReadOnlyList<HunterContact> Hunters { get; set; } = [];
    [Parameter] public int HeatLevel { get; set; }
    [Parameter] public bool CoolingAtHaven { get; set; }
    [Parameter] public int Credits { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public bool FullScreen { get; set; }
    [Parameter] public IReadOnlyList<SensorTrack> SensorTracks { get; set; } = [];
    [Parameter] public string? InterestId { get; set; }
    [Parameter] public InterceptEstimate.Result? Intercept { get; set; }
    [Parameter] public string? InterceptTargetName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnWarningShot { get; set; }
    [Parameter] public EventCallback<string> OnBribe { get; set; }
    [Parameter] public EventCallback<string> OnSetInterest { get; set; }

    // M28: gun-deck fire control — Map.razor owns the state, this desk renders the drama.
    [Parameter] public double FireAimOffsetSeconds { get; set; } = 3600;
    [Parameter] public double MaxAimOffsetSeconds { get; set; } = 86400;
    [Parameter] public double MaxMuzzleSpeedMps { get; set; } = 8000;
    [Parameter] public double? InterestDistanceMeters { get; set; }
    [Parameter] public OrdnanceKind FireKind { get; set; }
    [Parameter] public FireControl.Solution? FireSolution { get; set; }
    [Parameter] public double FireDispersionMeters { get; set; }
    [Parameter] public int RevealedIterations { get; set; }
    [Parameter] public double? FireCountdownSeconds { get; set; }
    [Parameter] public string? FireTip { get; set; }
    [Parameter] public int FirePulseCost { get; set; }
    [Parameter] public int PulsesAvailable { get; set; }
    [Parameter] public EventCallback<double> OnAimOffsetChanged { get; set; }
    [Parameter] public EventCallback<OrdnanceKind> OnFireKindChanged { get; set; }
    [Parameter] public EventCallback OnComputeSolution { get; set; }
    [Parameter] public EventCallback OnCancelFire { get; set; }
    [Parameter] public EventCallback OnScanWindows { get; set; }
    [Parameter] public EventCallback OnAutoAim { get; set; }
    [Parameter] public EventCallback OnArmFire { get; set; }
    [Parameter] public string? FireBlockedBy { get; set; }
    [Parameter] public string? StraightWindowText { get; set; }
    [Parameter] public bool WeaponsAuthorized { get; set; }
    [Parameter] public bool FireAtWill { get; set; }
    [Parameter] public int SlugAmmo { get; set; }
    [Parameter] public int MissileAmmo { get; set; }
    [Parameter] public bool Docked { get; set; }
    [Parameter] public bool CanWarnInterest { get; set; }
    [Parameter] public EventCallback<OrdnanceKind> OnBuyAmmo { get; set; }
    [Parameter] public IReadOnlyList<LiveRound> RoundsInFlight { get; set; } = [];
    [Parameter] public double? PlannedImpactInSeconds { get; set; }

    /// <summary>One live round for the in-flight tracker.</summary>
    public readonly record struct LiveRound(string Kind, string Target, double ExpiresIn);

    /// <summary>What the NO SHOT banner appends: the honest kinematic window, so the verdict
    /// teaches the fix instead of just refusing (the naive distance/muzzle hint was 25× off
    /// against a receding target).</summary>
    private string NeedsAimHint() =>
        StraightWindowText is not null
            ? $" — the straight window is {StraightWindowText}"
            : " — no straight window at any flight time; 🔭 scan for a gravity assist";

    // The aim slider is logarithmic: position 0..1000 maps exponentially over
    // [MinAimSeconds, MaxAimOffsetSeconds] so ten-minute knife-fights and forty-five-day
    // orbital shots share one usable control (same trick as the warp and horizon sliders).
    private const double MinAimSeconds = 600;

    private double AimToSlider(double seconds) =>
        1000 * Math.Log(Math.Clamp(seconds, MinAimSeconds, MaxAimOffsetSeconds) / MinAimSeconds)
            / Math.Log(Math.Max(MaxAimOffsetSeconds / MinAimSeconds, 1.0001));

    private double SliderToAim(double position) =>
        MinAimSeconds * Math.Exp(position / 1000 * Math.Log(Math.Max(MaxAimOffsetSeconds / MinAimSeconds, 1.0001)));

    private Task OnAimInput(ChangeEventArgs e) =>
        double.TryParse(e.Value?.ToString(), out double v)
            ? OnAimOffsetChanged.InvokeAsync(SliderToAim(v))
            : Task.CompletedTask;

    // The desk's range-scale selector (StationDesks.md PR-13): how far out the tactical circle
    // reaches. Purely a display choice — weapon/catch rings are always drawn at their true
    // physical radius, scaled to whichever of these the player picked.
    private static readonly double[] RangePresets = [1e8, 5e8, 1e9, 5e9];
    private double _viewRangeMeters = 1e9; // matches the pre-PR-13 fixed view range by default
    private const double CenterPx = 100;
    private const double MaxRadiusPx = 90;

    private readonly Dictionary<string, string> _hailLines = [];

    private double WeaponRingPx => MetersToPx(EncounterRule.WeaponRangeMeters);

    private double MetersToPx(double meters) => Math.Clamp(meters / _viewRangeMeters * MaxRadiusPx, 0, MaxRadiusPx);

    private (double X, double Y) ScreenPoint(Vector2d worldPosition)
    {
        Vector2d rel = worldPosition - ShipPosition;
        double scale = MaxRadiusPx / _viewRangeMeters;
        // Screen Y grows downward; flip so "+Y in world" reads as "up" on the tactical circle.
        return (CenterPx + rel.X * scale, CenterPx - rel.Y * scale);
    }

    private IReadOnlyList<RenderContact> VisibleContacts()
    {
        var list = new List<RenderContact>();
        foreach (Contact c in Contacts)
        {
            double distance = (c.State.Position - ShipPosition).Length;
            if (distance > _viewRangeMeters)
            {
                continue;
            }

            ComplianceState compliance = EncounterRule.ComplianceOf(c.Ship, HeatLevel);
            (double x, double y) = ScreenPoint(c.State.Position);
            list.Add(new RenderContact(c, compliance, distance, x, y));
        }

        list.Sort((a, b) => a.Distance.CompareTo(b.Distance));
        return list;
    }

    /// <summary>Every hunter, closing-speed and bearing computed once — regardless of view
    /// range, so the side list and the "closing" warning line always reflect true geometry even
    /// when a hunter is beyond the tactical circle's current zoom.</summary>
    private IReadOnlyList<RenderHunter> RenderHunters()
    {
        var list = new List<RenderHunter>();
        foreach (HunterContact h in Hunters)
        {
            Vector2d rel = h.State.Position - ShipPosition;
            double distance = rel.Length;
            double bearingDeg = Math.Atan2(rel.Y, rel.X) * 180.0 / Math.PI;
            if (bearingDeg < 0)
            {
                bearingDeg += 360;
            }

            double closingSpeed = ClosingSpeedMps(rel, distance, h.State.Velocity);
            (double x, double y) = ScreenPoint(h.State.Position);
            bool threatLine = distance <= EncounterRule.WeaponRangeMeters * 2;
            list.Add(new RenderHunter(h.Callsign, distance, bearingDeg, closingSpeed, x, y, threatLine));
        }

        list.Sort((a, b) => a.Distance.CompareTo(b.Distance));
        return list;
    }

    /// <summary>Positive = the range is shrinking (the hunter is closing); negative = opening.
    /// The radial component of relative velocity along the ship→hunter line.</summary>
    private double ClosingSpeedMps(Vector2d shipToHunter, double distance, Vector2d hunterVelocity)
    {
        if (distance <= 0)
        {
            return 0;
        }

        Vector2d relVel = hunterVelocity - ShipVelocity;
        return -relVel.Dot(shipToHunter / distance);
    }

    /// <summary>M27: sensor tracks inside the current view range, projected to the circle.</summary>
    private IReadOnlyList<RenderTrack> RenderTracks()
    {
        var list = new List<RenderTrack>();
        foreach (SensorTrack track in SensorTracks)
        {
            double distance = (track.State.Position - ShipPosition).Length;
            if (distance > _viewRangeMeters)
            {
                continue;
            }

            (double x, double y) = ScreenPoint(track.State.Position);
            list.Add(new RenderTrack(track, x, y));
        }

        return list;
    }

    private static string FormatDuration(double seconds) =>
        seconds < 3600 ? $"{seconds / 60:F0} min"
        : seconds < 86400 ? $"{seconds / 3600:F1} h"
        : seconds / 86400 >= 365 ? $"{seconds / 86400 / 365:F1} yr"
        : $"{seconds / 86400:F1} d";

    private static string FormatClosingSpeed(double metersPerSecond)
    {
        double kms = metersPerSecond / 1000.0;
        return kms >= 0 ? $"closing {kms:F2} km/s" : $"opening {-kms:F2} km/s";
    }

    private NearestHunterInfo? NearestHunter()
    {
        HunterContact? best = null;
        double bestDistance = double.MaxValue;
        foreach (HunterContact h in Hunters)
        {
            double d = (h.State.Position - ShipPosition).Length;
            if (d < bestDistance)
            {
                bestDistance = d;
                best = h;
            }
        }

        if (best is not { } hunter)
        {
            return null;
        }

        Vector2d rel = hunter.State.Position - ShipPosition;
        double bearingDeg = Math.Atan2(rel.Y, rel.X) * 180.0 / Math.PI;
        if (bearingDeg < 0)
        {
            bearingDeg += 360;
        }

        return new NearestHunterInfo(hunter.Callsign, bestDistance, bearingDeg);
    }

    private void Hail(RenderContact rc) =>
        _hailLines[rc.Contact.Ship.Id] = EncounterRule.ThreatOutcome(rc.Contact.Ship, rc.Compliance);

    private static string StatusBadge(RenderContact rc)
    {
        if (rc.Contact.Bribed)
        {
            return "🤝 bribed";
        }

        if (rc.Contact.Ship.IsPod)
        {
            return "— unmanned pod";
        }

        return rc.Compliance == ComplianceState.Stubborn ? "⚔ stubborn" : "🏳 compliant";
    }

    /// <summary>Bootstrap badge classes for the desk's roomier contact side-list — same three
    /// states as <see cref="StatusBadge"/>, colored so the list reads at a glance.</summary>
    private static string StatusBadgeClass(RenderContact rc)
    {
        if (rc.Contact.Bribed)
        {
            return "badge bg-warning text-dark";
        }

        if (rc.Contact.Ship.IsPod)
        {
            return "badge bg-secondary";
        }

        return rc.Compliance == ComplianceState.Stubborn ? "badge bg-danger" : "badge bg-success";
    }

    private static string ContactDotClass(RenderContact rc)
    {
        if (rc.Contact.Bribed)
        {
            return "war-room-dot-bribed";
        }

        return rc.Compliance switch
        {
            ComplianceState.Stubborn => "war-room-dot-stubborn",
            ComplianceState.NothingToComply => "war-room-dot-pod",
            _ => "war-room-dot-compliant",
        };
    }

    private string HeatGaugeText()
    {
        // 0-3 flames; unlit levels shown dim via the CSS class on the whole span (simplest —
        // no per-glyph markup needed for four discrete states).
        return HeatLevel switch
        {
            <= 0 => "◌◌◌",
            1 => "🔥◌◌",
            2 => "🔥🔥◌",
            _ => "🔥🔥🔥",
        };
    }

    private string CoolingLabel()
    {
        if (HeatLevel <= 0)
        {
            return "Heat: none. Quiet lanes.";
        }

        double days = CoolingAtHaven ? EncounterRule.HeatDecayDays / EncounterRule.HavenDecayMultiplier : EncounterRule.HeatDecayDays;
        string where = CoolingAtHaven ? " (haven — 4× faster)" : "";
        return $"Cooling at 1 level / {days:F0}d{where}";
    }

    // Razor reserves the bare <text> tag name for literal markup sections and refuses attributes
    // on it, even inside an <svg> — so the SVG <text> label for a hunter's wolf glyph has to be
    // built as raw markup instead of written as a normal element.
    private static Microsoft.AspNetCore.Components.MarkupString HunterLabelMarkup(RenderHunter h) =>
        new($"<text x=\"{Fmt(h.X + 7)}\" y=\"{Fmt(h.Y - 6)}\" class=\"war-room-hunter-label\">🐺</text>");

    /// <summary>A ring's name, sitting just inside its top edge (same raw-markup workaround).
    /// Styles are INLINE: Blazor's scoped CSS can't tag MarkupString-injected elements, so a
    /// stylesheet class would silently not match and the label renders at giant default size.</summary>
    private static Microsoft.AspNetCore.Components.MarkupString RingLabelMarkup(double radiusPx, string label) =>
        new($"<text x=\"100\" y=\"{Fmt(100 - radiusPx + 7)}\" text-anchor=\"middle\" style=\"font-size:6px;fill:rgba(180,200,220,0.55)\">{System.Net.WebUtility.HtmlEncode(label)}</text>");

    private static string Fmt(double v) => v.ToString("F1", CultureInfo.InvariantCulture);

    // Same scale as Map.razor's FormatDistance — kept local since components stay decoupled.
    private static string FormatRange(double meters)
    {
        const double metersPerAu = 1.495978707e11;
        if (meters >= metersPerAu / 10)
        {
            return $"{meters / metersPerAu:F2} AU";
        }

        if (meters >= 1e9)
        {
            return $"{meters / 1e9:F2} M km";
        }

        return $"{meters / 1000:F0} km";
    }
}
