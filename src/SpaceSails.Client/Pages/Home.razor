@page "/"

<PageTitle>SpaceSails</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4">SpaceSails 🏴‍☠️</h1>
        <p class="lead">Solar-system sailing &amp; piracy. Plot your course — everything is moving.</p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-lg-8 mb-3">
            <div class="card bg-dark text-light border-info">
                <div class="card-body d-flex flex-wrap align-items-center gap-2">
                    <span class="fw-bold">Single-player 🏴‍☠️</span>
                    <span class="small text-secondary flex-grow-1">
                        Runs entirely in your browser — no server, no signup. Pick a scenario below
                        and set sail. Playable right here at
                        <a href="https://esoinila.github.io/SpaceSails/">esoinila.github.io/SpaceSails</a>.
                    </span>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <a class="btn btn-outline-info btn-sm mb-2" href="/guide">📖 Captain's Guide — every feature, how to fly, how to steal</a>
            <details class="bg-dark text-light border border-secondary rounded p-3">
                <summary class="fw-bold">How to play — the pirate's primer</summary>
                <div class="small mt-2">
                    <p><b>Everything is moving.</b> Your ship obeys gravity; your only engine fires
                    ±10% velocity pulses (<kbd>+</kbd>/<kbd>−</kbd> or <kbd>↑</kbd>/<kbd>↓</kbd>).
                    Warp time with the toolbar — it auto-drops near encounters.</p>
                    <p><b>Plot, don't chase.</b> <kbd>Plot</kbd> pauses the sky: scrub the future,
                    drop burn nodes, and watch your ribbon bend until it crosses your prey's
                    predicted cone. Press Play and let the plan fly itself.</p>
                    <p><b>Hunt.</b> The Traffic board lists departures. Select a target to see its
                    prediction cone — it tightens while you shadow it, opens when you lose it.
                    Match velocity within the boarding envelope and your shuttles do the rest:
                    the tighter the pass, the faster the boarding.</p>
                    <p><b>Sell, refit, repeat.</b> Dock inside a market's port zone to fence cargo
                    and buy upgrades. Run dry of reaction mass in deep space and the rescue fee is
                    everything in your hold.</p>
                    <p><b>Electric skies</b> (⚡ scenarios): hull charge builds near the Sun and in
                    plasma streams. Vent it (<kbd>v</kbd>) or glow on every sensor in the system —
                    but a charged hull rides the streams for free momentum.</p>
                </div>
            </details>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        @foreach ((string slug, string title, string tag, string blurb) in Scenarios)
        {
            <div class="col-md-4">
                <div class="card h-100 bg-dark text-light border-secondary">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            @title
                            @if (tag.Length > 0)
                            {
                                <span class="badge bg-info text-dark ms-1">@tag</span>
                            }
                        </h5>
                        <p class="card-text small flex-grow-1">@blurb</p>
                        <a class="btn btn-primary mt-2" href="map?scenario=@slug">Launch</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly (string Slug, string Title, string Tag, string Blurb)[] Scenarios =
    [
        ("sol", "Sol", "",
         "The real solar system, pure Newtonian. Nine worlds on rails, He3 haulers inbound from Saturn, " +
         "and Luna's mass drivers lobbing compute-core pods. Where every pirate learns the trade."),
        ("sol-eu", "Sol (Electric)", "EU ⚡",
         "The same sky, awake. Hull charge builds near the Sun and inside plasma streams; vent it or glow " +
         "on every sensor in the system. Ride the Saturn–Jupiter river — fast, bright, and watched."),
        ("wheel", "Wheel of the World", "EU ⚡",
         "The ancients' cosmology. Venus, Earth and Mars ride a rigid spoke around Saturn the hub. The " +
         "spoke is not gravity's work — but your ship still obeys Newton. Harder than it looks. It looks hard."),
    ];
}
